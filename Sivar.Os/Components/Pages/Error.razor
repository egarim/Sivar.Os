@page "/app/error"
@using Microsoft.Extensions.Localization
@using System.Diagnostics
@inject IStringLocalizer<Error> Localizer

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<h1 class="text-danger">@Localizer["ErrorHeading"]</h1>
<h2 class="text-danger">@Localizer["ErrorMessage"]</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@Localizer["RequestIdLabel"]</strong> <code>@RequestId</code>
    </p>
}

<h3>@Localizer["DevelopmentModeHeading"]</h3>
<p>
    @((MarkupString)Localizer["DevelopmentModeInfo"].Value)
</p>
<p>
    @((MarkupString)Localizer["DevelopmentWarning"].Value)
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
