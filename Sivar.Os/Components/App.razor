<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />  
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href=@Assets["_content/MudBlazor/MudBlazor.min.css"] rel="stylesheet" />
    <!-- Leaflet.js CSS for interactive maps -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
    <link href="_content/PSC.Blazor.Components.MarkdownEditor/css/easymde.min.css" rel="stylesheet" />
    <link href="_content/PSC.Blazor.Components.MarkdownEditor/css/markdowneditor.css" rel="stylesheet" />
    <link href="css/app.css" rel="stylesheet" />
    <link href="css/comment-replies.css" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/ico" href="favicon.ico" />
    <HeadOutlet />
</head>

<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="InteractiveServer" />
    </CascadingAuthenticationState>
    <script>
        // Helper used by the WasmAuthenticationStateProvider to fetch server-side auth profile
        window.fetchWithCredentials = async function (url) {
            try {
                const resp = await fetch(url, { credentials: 'include' });
                if (!resp.ok) return '';
                return await resp.text();
            }
            catch (e) {
                console.error('fetchWithCredentials error', e);
                return '';
            }
        };
        // Central redirect helper used by client services when a 401 is detected
        window.redirectTo = function (url) {
            try {
                window.location.href = url;
            }
            catch (e) {
                console.error('redirectTo failed', e);
            }
        };
    </script>
    <script src="_framework/blazor.web.js"></script>
    <script src=@Assets["_content/MudBlazor/MudBlazor.min.js"]></script>
    <!-- Leaflet.js for interactive maps -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <!-- Leaflet JavaScript interop for Blazor -->
    <script src="js/leaflet-interop.js"></script>
    <script src="_content/PSC.Blazor.Components.MarkdownEditor/js/easymde.min.js"></script>
    <script src="_content/PSC.Blazor.Components.MarkdownEditor/js/markdownEditor.js"></script>
    
    <!-- Client-side sentiment analysis module (Transformers.js) -->
    <script type="module" src="js/sentiment-analyzer.js"></script>
    
    <!-- Client-side embedding generation module (Transformers.js) -->
    <!-- Loaded as ES6 module for browser-based text embeddings -->
    <script type="module">
        // Pre-load the embeddings module for faster first use
        // This is optional but improves UX by caching the model
        import { isSupported, getModelInfo } from './js/embeddings.js';
        
        // Check support on page load
        isSupported().then(supported => {
            if (supported) {
                console.log('[App] Client-side embeddings: SUPPORTED');
                const info = getModelInfo();
                console.log('[App] Model:', info.name, '- Dimensions:', info.dimensions);
            } else {
                console.log('[App] Client-side embeddings: NOT SUPPORTED (will use server fallback)');
            }
        });
    </script>
</body>

</html>
