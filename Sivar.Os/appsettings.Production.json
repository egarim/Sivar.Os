{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "Sivar.Os": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sivar-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentName" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "os.sivar.lat;*.sivar.lat",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=SivarOsProd;Username=sivaros_user;Password=YOUR_SECURE_DB_PASSWORD;SSL Mode=Require;"
  },
  "Keycloak": {
    "Authority": "https://auth.sivar.lat/realms/sivar-os",
    "MetadataAddress": "https://auth.sivar.lat/realms/sivar-os/.well-known/openid-configuration",
    "ClientIdServer": "sivaros-server",
    "ClientIdClient": "sivaros-client",
    "ClientSecret": "wpUaB6GdMN1lODUehMw1k07nO1uKQhLC"
  },
  "AzureBlobStorage": {
    "ConnectionString": "YOUR_AZURE_PRODUCTION_CONNECTION_STRING",
    "BaseContainer": "sivaros",
    "AutoCreateContainers": false,
    "MaxConcurrentUploads": 4,
    "UseHierarchicalNamespace": true,
    "DefaultPublicAccessType": "Blob"
  },
  "Embeddings": {
    "PreferClientSide": true,
    "EnableServerFallback": true,
    "ModelName": "Xenova/all-MiniLM-L6-v2",
    "ExpectedDimensions": 384,
    "WarmupOnStartup": true,
    "ClientTimeout": 30000
  },
  "AIServices": {
    "SentimentAnalysis": {
      "Mode": "Adaptive",
      "Description": "Adaptive mode for production"
    },
    "Embeddings": {
      "Mode": "Adaptive",
      "Description": "Adaptive = Smart routing"
    }
  },
  "LocationServices": {
    "Provider": "Nominatim",
    "Nominatim": {
      "BaseUrl": "https://nominatim.openstreetmap.org",
      "UserAgent": "Sivar.Os/1.0 (Contact: support@sivar.sv)",
      "RateLimitPerSecond": 1.0
    }
  }
}
