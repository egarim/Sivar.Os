<?xml version="1.0" encoding="utf-8"?>
<root>
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:element name="root" msdata:IsDataSet="true">
      <xsd:complexType>
        <xsd:choice maxOccurs="unbounded">
          <xsd:element name="data">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" type="xsd:string" minOccurs="0" msdata:Ordinal="1" />
                <xsd:element name="comment" type="xsd:string" minOccurs="0" msdata:Ordinal="2" />
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string" use="required" />
            </xsd:complexType>
          </xsd:element>
        </xsd:choice>
      </xsd:complexType>
    </xsd:element>
  </xsd:schema>
  
  <!-- Menu Item Labels -->
  <data name="MenuItem_Edit" xml:space="preserve">
    <value>Edit</value>
  </data>
  <data name="MenuItem_Delete" xml:space="preserve">
    <value>Delete</value>
  </data>
  <data name="MenuItem_Share" xml:space="preserve">
    <value>Share</value>
  </data>
  <data name="MenuItem_CopyLink" xml:space="preserve">
    <value>Copy Link</value>
  </data>
  <data name="MenuItem_Save" xml:space="preserve">
    <value>Save</value>
  </data>
  <data name="MenuItem_Report" xml:space="preserve">
    <value>Report</value>
  </data>
  <data name="MenuItem_Hide" xml:space="preserve">
    <value>Hide</value>
  </data>
  <data name="MenuItem_Reply" xml:space="preserve">
    <value>Reply</value>
  </data>
  <data name="MenuItem_EditProfile" xml:space="preserve">
    <value>Edit Profile</value>
  </data>
  <data name="MenuItem_Settings" xml:space="preserve">
    <value>Settings</value>
  </data>
  <data name="MenuItem_ShareProfile" xml:space="preserve">
    <value>Share Profile</value>
  </data>
  <data name="MenuItem_Block" xml:space="preserve">
    <value>Block</value>
  </data>
  
  <!-- Confirmation Messages -->
  <data name="Confirm" xml:space="preserve">
    <value>Confirm</value>
  </data>
  <data name="Confirm_DeletePost" xml:space="preserve">
    <value>Are you sure you want to delete this post? This action cannot be undone.</value>
  </data>
  <data name="Confirm_DeleteComment" xml:space="preserve">
    <value>Are you sure you want to delete this comment?</value>
  </data>
  <data name="Confirm_DeleteBlog" xml:space="preserve">
    <value>Are you sure you want to delete this blog post? This action cannot be undone.</value>
  </data>
  <data name="Confirm_BlockProfile" xml:space="preserve">
    <value>Are you sure you want to block this profile? They won't be able to see your content or contact you.</value>
  </data>
  
  <!-- Dialog Buttons -->
  <data name="Yes" xml:space="preserve">
    <value>Yes</value>
  </data>
  <data name="Cancel" xml:space="preserve">
    <value>Cancel</value>
  </data>
</root>
