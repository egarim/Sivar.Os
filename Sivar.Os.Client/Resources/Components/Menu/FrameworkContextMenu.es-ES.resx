  </data>
  <data name="MenuItem_Hide" xml:space="preserve">
    <value>Ocultar</value>
  </data>
  <data name="MenuItem_Reply" xml:space="preserve">
    <value>Responder</value>
  </data>
  <data name="MenuItem_EditProfile" xml:space="preserve">
