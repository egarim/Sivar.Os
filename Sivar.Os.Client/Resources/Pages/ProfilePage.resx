  <!-- Page Header -->
  <data name="ProfileTitle" xml:space="preserve">
    <value>Profile</value>
    <comment>Profile page header title</comment>
  </data>
  
  <!-- Coming Soon Section -->
  <data name="ComingSoonTitle" xml:space="preserve">
    <value>Profile Features Coming Soon</value>
    <comment>Coming soon alert title</comment>
  </data>
  <data name="ComingSoonMessage" xml:space="preserve">
    <value>Full profile details, activity feed, and customization options will be available soon.</value>
    <comment>Coming soon alert message</comment>
  </data>
  
  <!-- Posts Section -->
  <data name="PostsSectionTitle" xml:space="preserve">
    <value>Posts</value>
    <comment>Posts section header</comment>
  </data>
  <data name="LoadingPosts" xml:space="preserve">
    <value>Loading posts...</value>
    <comment>Loading indicator for posts</comment>
  </data>
  <data name="LoadMoreButton" xml:space="preserve">
    <value>Load More Posts ({0} of {1})</value>
    <comment>Load more button with post count. {0} = current count, {1} = total count</comment>
  </data>
  <data name="NoPostsYet" xml:space="preserve">
    <value>No posts yet from this profile.</value>
    <comment>Empty state message when profile has no posts</comment>
  </data>
  
  <!-- Follow Button States -->
  <data name="FollowButton" xml:space="preserve">
    <value>Follow</value>
    <comment>Follow button text when not following</comment>
  </data>
  <data name="FollowingButton" xml:space="preserve">
    <value>Following</value>
    <comment>Follow button text when already following</comment>
  </data>
  <data name="FollowingInProgress" xml:space="preserve">
    <value>Following...</value>
    <comment>Follow button text during follow action</comment>
  </data>
  <data name="UnfollowingInProgress" xml:space="preserve">
    <value>Unfollowing...</value>
    <comment>Follow button text during unfollow action</comment>
  </data>
  
