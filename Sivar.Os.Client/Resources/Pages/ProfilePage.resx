  <data name="ProfileNotFound" xml:space="preserve">
    <value>Profile not found for '{0}'</value>
    <comment>Error message when profile doesn't exist. {0} = identifier</comment>
  </data>
  <data name="ErrorLoadingProfile" xml:space="preserve">
    <value>An error occurred while loading the profile</value>
    <comment>Generic error message for profile loading</comment>
  </data>
  
  <!-- Fallback/Default Values -->
  <data name="FallbackBio" xml:space="preserve">
    <value>Profile information is currently unavailable.</value>
    <comment>Fallback bio text when profile data can't be loaded</comment>
  </data>
  <data name="DefaultProfileName" xml:space="preserve">
    <value>User Profile</value>
    <comment>Default display name for GUID-based profiles</comment>
  </data>
  <data name="DefaultBio" xml:space="preserve">
    <value>No bio available</value>
    <comment>Default bio text when user hasn't set one</comment>
  </data>
  <data name="UnknownUser" xml:space="preserve">
    <value>Unknown</value>
    <comment>Fallback text for unknown user name</comment>
