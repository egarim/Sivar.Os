@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Enums
@using Sivar.Os.Client.Services
@using MudBlazor
@namespace Sivar.Os.Client.Components.ProfileSwitcher

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="@(() => OnCancel.InvokeAsync())">
        <MudPaper Class="modal-content" Elevation="8" @onclick:stopPropagation="true">
            <MudStack Spacing="3" Style="padding: 24px;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="margin-bottom: 8px;">
                    <MudText Typo="Typo.h5">Create New Profile</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                   OnClick="@(() => OnCancel.InvokeAsync())" 
                                   Size="Size.Small" />
                </MudStack>

                        <!-- Profile Type Selection -->
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.subtitle2">Profile Type</MudText>
                            <MudStack Spacing="2">
                                @foreach (var type in ProfileTypes)
                                {
                                    <MudPaper Outlined="true" 
                                              Class="@GetProfileTypeClass(type.Id)"
                                              @onclick="@(() => SelectProfileType(type))"
                                              Style="cursor: pointer; padding: 12px; transition: all 0.2s ease;">
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.h6">@GetProfileTypeIcon(type.Name)</MudText>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body1" Style="font-weight: 600;">@type.DisplayName</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">@type.Description</MudText>
                                            </MudStack>
                                            @if (SelectedProfileType == type.Id)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Style="margin-left: auto;" />
                                            }
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        </MudStack>

                        <!-- Profile Name Input -->
                        <MudTextField @bind-Value="ProfileName"
                                      Label="Profile Name"
                                      Placeholder="e.g., My Business, Creative Studio"
                                      Required="true"
                                      RequiredError="Profile name is required"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Immediate="true"
                                      OnBlur="ValidateProfileName"
                                      Error="@(!string.IsNullOrEmpty(ProfileNameError))"
                                      ErrorText="@ProfileNameError" />

                        <!-- Profile Description -->
                        <MudTextField @bind-Value="ProfileDescription"
                                      Label="Description (Optional)"
                                      Placeholder="Tell us about this profile..."
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Lines="3"
                                      Counter="500"
                                      MaxLength="500"
                                      HelperText="@($"{ProfileDescription.Length} / 500 characters")" />

                <!-- Error Message -->
                @if (IsSubmitting)
                {
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Justify="Justify.Center">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        <MudText>Creating profile...</MudText>
                    </MudStack>
                }

                <!-- Footer Actions -->
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Style="margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--mud-palette-divider);">
                    <MudButton OnClick="@(() => OnCancel.InvokeAsync())" 
                               Disabled="IsSubmitting"
                               Variant="Variant.Outlined">
                        Cancel
                    </MudButton>
                    <MudButton Color="Color.Primary" 
                               Variant="Variant.Filled"
                               OnClick="SubmitForm"
                               Disabled="@(!IsFormValid())">
                        @if (IsSubmitting)
                        {
                            <span>Creating...</span>
                        }
                        else
                        {
                            <span>Create Profile</span>
                        }
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        animation: fadeIn 0.2s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .modal-content {
        background: var(--mud-palette-surface, white);
        border-radius: 8px;
        max-width: 500px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            transform: translateY(20px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .profile-type-selected {
        border-color: var(--mud-palette-primary) !important;
        background-color: rgba(var(--mud-palette-primary-rgb), 0.08) !important;
    }
</style>

@code {
    [Inject]
    private IProfileSwitcherService ProfileSwitcherService { get; set; } = null!;

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<CreateAnyProfileDto> OnCreate { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    public List<ProfileTypeDto> ProfileTypes { get; set; } = new();

    private Guid SelectedProfileType { get; set; }
    private string ProfileName { get; set; } = string.Empty;
    private string ProfileDescription { get; set; } = string.Empty;
    private bool IsSubmitting { get; set; } = false;
    private string ProfileNameError { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await InitializeProfileTypes();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reset form when modal opens
        if (IsOpen && ProfileTypes.Any())
        {
            SelectedProfileType = ProfileTypes.First().Id;
            ResetForm();
        }
    }

    private async Task InitializeProfileTypes()
    {
        // Fetch real profile types from the server instead of creating fake ones
        ProfileTypes = await ProfileSwitcherService.GetProfileTypesAsync();
        
        Console.WriteLine($"[ProfileCreatorModal] InitializeProfileTypes: Loaded {ProfileTypes.Count} profile types");
        foreach (var type in ProfileTypes)
        {
            Console.WriteLine($"  - {type.DisplayName} (ID: {type.Id})");
        }
        
        if (ProfileTypes.Any())
        {
            SelectedProfileType = ProfileTypes.First().Id;
            Console.WriteLine($"[ProfileCreatorModal] OnInitializedAsync: Set SelectedProfileType to {ProfileTypes.First().DisplayName} (ID: {SelectedProfileType})");
        }
    }

    private void ResetForm()
    {
        ProfileName = string.Empty;
        ProfileDescription = string.Empty;
        ProfileNameError = string.Empty;
        IsSubmitting = false;
    }

    private string GetProfileTypeIcon(string typeName)
    {
        return typeName?.ToLower() switch
        {
            "personal" => "👤",
            "business" => "💼",
            "brand" => "🏢",
            "creator" => "🎬",
            _ => "📋"
        };
    }

    private string GetProfileTypeClass(Guid typeId)
    {
        return SelectedProfileType == typeId ? "profile-type-selected" : "";
    }

    private void SelectProfileType(ProfileTypeDto type)
    {
        Console.WriteLine($"[ProfileCreatorModal] SelectProfileType: Selected {type.DisplayName} (ID: {type.Id})");
        SelectedProfileType = type.Id;
    }

    private void ValidateProfileName()
    {
        ProfileNameError = string.Empty;

        if (string.IsNullOrWhiteSpace(ProfileName))
        {
            ProfileNameError = "Profile name is required";
            return;
        }

        if (ProfileName.Length < 3)
        {
            ProfileNameError = "Profile name must be at least 3 characters";
            return;
        }

        if (ProfileName.Length > 100)
        {
            ProfileNameError = "Profile name must be less than 100 characters";
            return;
        }
    }

    private bool IsFormValid()
    {
        return !string.IsNullOrWhiteSpace(ProfileName) && 
               ProfileName.Length >= 3 && 
               ProfileName.Length <= 100 &&
               SelectedProfileType != Guid.Empty &&
               !IsSubmitting;
    }

    private async Task SubmitForm()
    {
        Console.WriteLine("═══════════════════════════════════════════════════════════════");
        Console.WriteLine("[ProfileCreatorModal.SubmitForm] START - Submitting create profile form");
        
        ValidateProfileName();

        if (!IsFormValid())
        {
            Console.WriteLine("[ProfileCreatorModal.SubmitForm] ❌ Form validation failed");
            Console.WriteLine($"  ProfileName: '{ProfileName}' (Length: {ProfileName?.Length ?? 0})");
            Console.WriteLine($"  SelectedProfileType: {SelectedProfileType}");
            Console.WriteLine($"  IsSubmitting: {IsSubmitting}");
            Console.WriteLine($"  ProfileNameError: {ProfileNameError}");
            Console.WriteLine("═══════════════════════════════════════════════════════════════");
            return;
        }

        IsSubmitting = true;
        Console.WriteLine("[ProfileCreatorModal.SubmitForm] ✅ Form validation passed, starting submission");

        try
        {
            var selectedTypeName = ProfileTypes.FirstOrDefault(t => t.Id == SelectedProfileType)?.DisplayName ?? "Unknown";
            Console.WriteLine("[ProfileCreatorModal.SubmitForm] Creating request object");
            Console.WriteLine($"  Name: {ProfileName.Trim()}");
            Console.WriteLine($"  Type: {selectedTypeName} (ID: {SelectedProfileType})");
            Console.WriteLine($"  Bio: {ProfileDescription.Trim()}");
            Console.WriteLine($"  Visibility: Public (default)");
            Console.WriteLine($"  SetAsActive: True (default - new profile will be auto-selected)");

            var request = new CreateAnyProfileDto
            {
                ProfileTypeId = SelectedProfileType,
                DisplayName = ProfileName.Trim(),
                Bio = ProfileDescription.Trim(),
                VisibilityLevel = VisibilityLevel.Public,  // ✅ Always public by default
                SetAsActive = true  // ✅ Always set as active profile (auto-select in profile switcher)
            };

            Console.WriteLine("[ProfileCreatorModal.SubmitForm] Invoking OnCreate callback");
            await OnCreate.InvokeAsync(request);
            Console.WriteLine("[ProfileCreatorModal.SubmitForm] ✅ OnCreate callback completed");
            Console.WriteLine("═══════════════════════════════════════════════════════════════");
        }
        catch (Exception ex)
        {
            Console.WriteLine("[ProfileCreatorModal.SubmitForm] ❌ EXCEPTION!");
            Console.WriteLine($"  Type: {ex.GetType().Name}");
            Console.WriteLine($"  Message: {ex.Message}");
            Console.WriteLine($"  Stack: {ex.StackTrace}");
            Console.WriteLine("═══════════════════════════════════════════════════════════════");
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
