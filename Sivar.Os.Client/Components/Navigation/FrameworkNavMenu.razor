@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization
@using Sivar.Os.Shared.Framework
@using Sivar.Os.Shared.Framework.Navigation
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Client.Components.ProfileSwitcher
@using Sivar.Os.Client.Layout
@using MudBlazor
@inject INavigationRegistry NavigationRegistry
@inject NavigationManager NavigationManager
@inject IStringLocalizer<FrameworkNavMenu> Localizer
@inject ILogger<FrameworkNavMenu> Logger

@* 
    FrameworkNavMenu - Uses the navigation registry for menu items.
    This is the new pattern that replaces hardcoded navigation.
    Toggle via FeatureFlags:UseFrameworkNavigation in appsettings.json
*@

<div class="framework-nav-container">
    @* Profile Switcher Section *@
    <div class="nav-profile-section">
        <AuthorizeView>
            <Authorized>
                <ProfileSwitcher ActiveProfile="@_activeProfileForSwitcher"
                                 UserProfiles="@UserProfiles"
                                 OnProfileChanged="@OnProfileChanged"
                                 OnCreateProfile="@OnCreateProfile" />
            </Authorized>
            <NotAuthorized>
                <div class="guest-branding">
                    <div class="brand-logo">
                        <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Large" Color="Color.Primary" />
                    </div>
                    <div class="brand-text">
                        <MudText Typo="Typo.h6" Class="brand-name">Sivar.Os</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localizer["ExploreElSalvador"]</MudText>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    @* Navigation Items *@
    <MudNavMenu Class="framework-nav-menu">
        @if (!_visibleItems.Any())
        {
            <MudText Typo="Typo.caption" Class="pa-4 mud-text-secondary">
                @if (!IsAuthenticated)
                {
                    @Localizer["PleaseLogin"]
                }
                else
                {
                    @Localizer["NoMenuItems"]
                }
            </MudText>
        }
        @foreach (var item in _visibleItems)
        {
            @if (item.IsAction)
            {
                <MudNavLink @onclick="@(() => HandleAction(item))"
                            Icon="@GetMudIcon(item.Icon)"
                            Disabled="@(!IsEnabled(item))">
                    @GetLocalizedTitle(item)
                </MudNavLink>
            }
            else
            {
                <MudNavLink Href="@item.Route" 
                            Match="NavLinkMatch.Prefix"
                            Icon="@GetMudIcon(item.Icon)"
                            Disabled="@(!IsEnabled(item))">
                    @GetLocalizedTitle(item)
                </MudNavLink>
            }
        }
    </MudNavMenu>

    @* Theme Toggle *@
    <div class="nav-theme-toggle">
        <MudIcon Icon="@Icons.Material.Filled.LightMode" Size="Size.Small" 
                 Class="@($"theme-icon {(!IsDarkMode ? "active light" : "")}")" />
        <MudSwitch T="bool" 
                   Value="@IsDarkMode" 
                   ValueChanged="@HandleThemeToggle"
                   Color="Color.Primary"
                   Class="theme-switch"
                   ThumbIcon="@(IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                   ThumbIconColor="@(IsDarkMode ? Color.Primary : Color.Warning)" />
        <MudIcon Icon="@Icons.Material.Filled.DarkMode" Size="Size.Small" 
                 Class="@($"theme-icon {(IsDarkMode ? "active dark" : "")}")" />
    </div>

    @* Spacer to push logout to bottom *@
    <div class="nav-spacer"></div>

    @* Logout / Login Section *@
    <AuthorizeView>
        <Authorized>
            <div class="nav-logout-section">
                <MudDivider Class="mb-2" />
                <MudButton Variant="Variant.Text" 
                           StartIcon="@Icons.Material.Filled.Logout" 
                           FullWidth="true" 
                           OnClick="@HandleLogout"
                           Class="justify-start"
                           Color="Color.Error">
                    @Localizer["Logout"]
                </MudButton>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-guest-actions">
                <MudDivider Class="mb-2" />
                <MudButton Variant="Variant.Filled" 
                           StartIcon="@Icons.Material.Filled.PersonAdd" 
                           FullWidth="true" 
                           Href="/welcome?action=signup"
                           Class="mb-2"
                           Color="Color.Primary">
                    @Localizer["SignUp"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           StartIcon="@Icons.Material.Filled.Login" 
                           FullWidth="true" 
                           Href="/welcome"
                           Color="Color.Primary">
                    @Localizer["Login"]
                </MudButton>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<style>
    .framework-nav-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }
    
    .nav-profile-section {
        padding: 16px 16px 8px 16px;
    }
    
    .guest-branding {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px;
        border-radius: 8px;
        background: var(--mud-palette-background-grey);
    }
    
    .brand-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    
    .brand-logo .mud-icon-root {
        color: white !important;
    }
    
    .brand-text {
        display: flex;
        flex-direction: column;
    }
    
    .brand-name {
        font-weight: 700;
        line-height: 1.2;
    }
    
    .framework-nav-menu {
        padding: 8px 8px 0 8px;
    }
    
    .nav-theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 16px;
        margin-top: 8px;
    }
    
    .theme-icon {
        color: var(--mud-palette-text-secondary);
        opacity: 0.5;
        transition: opacity 0.2s, color 0.2s;
    }
    
    .theme-icon.active.light {
        color: var(--mud-palette-warning);
        opacity: 1;
    }
    
    .theme-icon.active.dark {
        color: var(--mud-palette-primary);
        opacity: 1;
    }
    
    .theme-switch {
        margin: 0;
    }
    
    .nav-spacer {
        flex: 1;
    }
    
    .nav-logout-section {
        padding: 8px 16px 16px 16px;
    }
    
    .nav-guest-actions {
        padding: 8px 16px 16px 16px;
    }
</style>

@code {
    /// <summary>
    /// The currently active profile (for visibility filtering and ProfileSwitcher).
    /// </summary>
    [Parameter]
    public ActiveProfileDto? ActiveProfile { get; set; }
    
    /// <summary>
    /// All user profiles for the ProfileSwitcher.
    /// </summary>
    [Parameter]
    public List<ProfileDto> UserProfiles { get; set; } = new();
    
    /// <summary>
    /// Whether the user is authenticated.
    /// </summary>
    [Parameter]
    public bool IsAuthenticated { get; set; }
    
    /// <summary>
    /// User's roles for role-based navigation.
    /// </summary>
    [Parameter]
    public string[] Roles { get; set; } = Array.Empty<string>();
    
    /// <summary>
    /// The platform type (Web, Mobile, Desktop).
    /// </summary>
    [Parameter]
    public PlatformType Platform { get; set; } = PlatformType.Web;
    
    /// <summary>
    /// Whether dark mode is enabled.
    /// </summary>
    [Parameter]
    public bool IsDarkMode { get; set; } = true;
    
    /// <summary>
    /// Event callback when an action item is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnAction { get; set; }
    
    /// <summary>
    /// Event callback when theme is toggled.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnThemeChanged { get; set; }
    
    /// <summary>
    /// Event callback when profile is changed.
    /// </summary>
    [Parameter]
    public EventCallback<ProfileDto> OnProfileChanged { get; set; }
    
    /// <summary>
    /// Event callback when create profile is requested.
    /// </summary>
    [Parameter]
    public EventCallback OnCreateProfile { get; set; }
    
    private IEnumerable<INavigationItem> _visibleItems = Enumerable.Empty<INavigationItem>();
    private NavContext _context = new();
    
    /// <summary>
    /// Gets the active profile as ProfileDto for ProfileSwitcher compatibility.
    /// Finds the matching profile from UserProfiles by ID.
    /// </summary>
    private ProfileDto? _activeProfileForSwitcher => 
        ActiveProfile != null 
            ? UserProfiles.FirstOrDefault(p => p.Id == ActiveProfile.Id) 
              ?? new ProfileDto 
              { 
                  Id = ActiveProfile.Id, 
                  DisplayName = ActiveProfile.DisplayName, 
                  ProfileType = ActiveProfile.ProfileType,
                  Avatar = ActiveProfile.Avatar ?? string.Empty,
                  IsActive = true
              }
            : null;
    
    protected override void OnParametersSet()
    {
        UpdateVisibleItems();
    }
    
    private void UpdateVisibleItems()
    {
        _context = new NavContext
        {
            IsAuthenticated = IsAuthenticated,
            ActiveProfile = ActiveProfile,
            CurrentRoute = NavigationManager.Uri,
            Platform = Platform,
            Roles = Roles
        };
        
        _visibleItems = NavigationRegistry.GetVisibleItems(_context);
        
        Logger.LogDebug("[FrameworkNavMenu] IsAuthenticated={IsAuth}, Profile={Profile}, VisibleItems={Count}",
            IsAuthenticated, ActiveProfile?.DisplayName ?? "none", _visibleItems.Count());
    }
    
    private bool IsEnabled(INavigationItem item)
    {
        if (item.IsEnabled == null)
            return true;
            
        try
        {
            return item.IsEnabled(_context);
        }
        catch
        {
            return true;
        }
    }
    
    private string GetLocalizedTitle(INavigationItem item)
    {
        // Try to get localized string, fall back to Title
        var localized = Localizer[item.TitleKey];
        return localized.ResourceNotFound ? item.Title : localized.Value;
    }
    
    private async Task HandleAction(INavigationItem item)
    {
        if (!string.IsNullOrEmpty(item.ActionId))
        {
            await OnAction.InvokeAsync(item.ActionId);
        }
    }
    
    private async Task HandleThemeToggle(bool isDark)
    {
        await OnThemeChanged.InvokeAsync(isDark);
    }
    
    private void HandleLogout()
    {
        NavigationManager.NavigateTo("/authentication/logout", forceLoad: true);
    }
    
    /// <summary>
    /// Maps icon names to MudBlazor Icons.
    /// </summary>
    private string GetMudIcon(string iconName)
    {
        return iconName switch
        {
            "Home" => Icons.Material.Filled.Home,
            "Search" => Icons.Material.Filled.Search,
            "EventNote" => Icons.Material.Filled.EventNote,
            "EventAvailable" => Icons.Material.Filled.EventAvailable,
            "SmartToy" => Icons.Material.Filled.SmartToy,
            "Explore" => Icons.Material.Filled.Explore,
            "Person" => Icons.Material.Filled.Person,
            "Settings" => Icons.Material.Filled.Settings,
            "Notifications" => Icons.Material.Filled.Notifications,
            "Chat" => Icons.Material.Filled.Chat,
            "Bookmark" => Icons.Material.Filled.Bookmark,
            "Star" => Icons.Material.Filled.Star,
            "Add" => Icons.Material.Filled.Add,
            "Edit" => Icons.Material.Filled.Edit,
            "Delete" => Icons.Material.Filled.Delete,
            "MoreVert" => Icons.Material.Filled.MoreVert,
            _ => Icons.Material.Filled.Circle
        };
    }
}
