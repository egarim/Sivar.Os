@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization
@using Sivar.Os.Shared
@using Sivar.Os.Shared.Framework
@using Sivar.Os.Shared.Framework.Navigation
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Client.Components.ProfileSwitcher
@using Sivar.Os.Client.Layout
@using MudBlazor
@inject INavigationRegistry NavigationRegistry
@inject NavigationManager NavigationManager
@inject IStringLocalizer<FrameworkNavMenu> Localizer
@inject ILogger<FrameworkNavMenu> Logger
@inject ISivarClient SivarClient
@implements IDisposable

@* 
    FrameworkNavMenu - Uses the navigation registry for menu items.
    This is the new pattern that replaces hardcoded navigation.
    Toggle via FeatureFlags:UseFrameworkNavigation in appsettings.json
*@

<div class="framework-nav-container">
    @* Profile Switcher Section - Always visible *@
    <div class="nav-profile-section">
        <AuthorizeView>
            <Authorized>
                <ProfileSwitcher ActiveProfile="@_activeProfileForSwitcher"
                                 UserProfiles="@UserProfiles"
                                 OnProfileChanged="@OnProfileChanged"
                                 OnCreateProfile="@OnCreateProfile" />
            </Authorized>
            <NotAuthorized>
                <div class="guest-branding">
                    <div class="brand-logo">
                        <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Large" Color="Color.Primary" />
                    </div>
                    <div class="brand-text">
                        <MudText Typo="Typo.h6" Class="brand-name">Sivar.Os</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localizer["ExploreElSalvador"]</MudText>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    @* Main Navigation - Always visible *@
    <MudNavMenu Class="framework-nav-menu" Dense="true">
        <MudNavLink Href="/app/home" 
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Home">
            @Localizer["Home"]
        </MudNavLink>
        <MudNavLink Href="/app/chat" 
                    Match="NavLinkMatch.Prefix"
                    Icon="@Icons.Material.Filled.SmartToy">
            @Localizer["SivarAI"]
        </MudNavLink>
    </MudNavMenu>

    @if (_isOnChatPage)
    {
        @* Chat Mode - Show conversations header and list *@
        <div class="chat-mode-header">
            <MudText Typo="Typo.subtitle2" Class="ml-2">@Localizer["Conversations"]</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Add" 
                           Color="Color.Primary" 
                           OnClick="@HandleNewConversation"
                           Size="Size.Small" />
        </div>
        
        @if (_isLoadingConversations)
        {
            <div class="pa-4 d-flex justify-center">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            </div>
        }
        else if (_conversations?.Any() == true)
        {
            <div class="conversation-list">
                @foreach (var conversation in _conversations)
                {
                    var isActive = _currentConversationId == conversation.Id;
                    var convId = conversation.Id;
                    <div class="conversation-item @(isActive ? "active" : "")">
                        <a href="@($"/app/chat/{conversation.Id}")" class="conversation-link">
                            <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Small" />
                            <span class="conversation-title">@TruncateTitle(conversation.Title ?? "Conversation", 20)</span>
                        </a>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" 
                                 Size="Size.Small" 
                                 Dense="true"
                                 AnchorOrigin="Origin.BottomRight"
                                 TransformOrigin="Origin.TopRight"
                                 Class="conversation-menu">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" 
                                        OnClick="@(() => OpenRenameDialog(convId, conversation.Title))">
                                @Localizer["Rename"]
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" 
                                        OnClick="@(() => OpenDeleteDialog(convId, conversation.Title))"
                                        IconColor="Color.Error">
                                @Localizer["Delete"]
                            </MudMenuItem>
                        </MudMenu>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="pa-4 text-center">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localizer["NoConversations"]</MudText>
                <MudButton Variant="Variant.Text" 
                           StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           OnClick="@HandleNewConversation"
                           Class="mt-2">
                    @Localizer["StartConversation"]
                </MudButton>
            </div>
        }
    }
    else
    {
        @* Normal Mode - Full Navigation Items (excluding Home which is already shown) *@
        <MudNavMenu Class="framework-nav-menu">
            @foreach (var item in _visibleItems.Where(i => i.Route != "/app/home"))
            {
                @if (item.IsAction)
                {
                    <MudNavLink @onclick="@(() => HandleAction(item))"
                                Icon="@GetMudIcon(item.Icon)"
                                Disabled="@(!IsEnabled(item))">
                        @GetLocalizedTitle(item)
                    </MudNavLink>
                }
                else
                {
                    <MudNavLink Href="@item.Route" 
                                Match="NavLinkMatch.Prefix"
                                Icon="@GetMudIcon(item.Icon)"
                                Disabled="@(!IsEnabled(item))">
                        @GetLocalizedTitle(item)
                    </MudNavLink>
                }
            }
        </MudNavMenu>
    }

    @* Theme Toggle - Always visible *@
    <div class="nav-theme-toggle">
        <MudIcon Icon="@Icons.Material.Filled.LightMode" Size="Size.Small" 
                 Class="@($"theme-icon {(!IsDarkMode ? "active light" : "")}")" />
        <MudSwitch T="bool" 
                   Value="@IsDarkMode" 
                   ValueChanged="@HandleThemeToggle"
                   Color="Color.Primary"
                   Class="theme-switch"
                   ThumbIcon="@(IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                   ThumbIconColor="@(IsDarkMode ? Color.Primary : Color.Warning)" />
        <MudIcon Icon="@Icons.Material.Filled.DarkMode" Size="Size.Small" 
                 Class="@($"theme-icon {(IsDarkMode ? "active dark" : "")}")" />
    </div>

    @* Spacer to push logout to bottom *@
    <div class="nav-spacer"></div>

    @* Logout / Login Section *@
    <AuthorizeView>
        <Authorized>
            <div class="nav-logout-section">
                <MudDivider Class="mb-2" />
                <MudButton Variant="Variant.Text" 
                           StartIcon="@Icons.Material.Filled.Logout" 
                           FullWidth="true" 
                           OnClick="@HandleLogout"
                           Class="justify-start"
                           Color="Color.Error">
                    @Localizer["Logout"]
                </MudButton>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-guest-actions">
                <MudDivider Class="mb-2" />
                <MudButton Variant="Variant.Filled" 
                           StartIcon="@Icons.Material.Filled.PersonAdd" 
                           FullWidth="true" 
                           Href="/welcome?action=signup"
                           Class="mb-2"
                           Color="Color.Primary">
                    @Localizer["SignUp"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           StartIcon="@Icons.Material.Filled.Login" 
                           FullWidth="true" 
                           Href="/welcome"
                           Color="Color.Primary">
                    @Localizer["Login"]
                </MudButton>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@* Rename Dialog *@
<MudDialog @bind-Visible="_renameDialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@Localizer["RenameConversation"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_renameNewTitle" 
                      Label="@Localizer["ConversationName"]" 
                      Variant="Variant.Outlined"
                      Immediate="true"
                      AutoFocus="true"
                      OnKeyDown="@OnRenameKeyDown" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseRenameDialog">@Localizer["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="@ConfirmRename"
                   Disabled="@(string.IsNullOrWhiteSpace(_renameNewTitle))">
            @Localizer["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@* Delete Confirmation Dialog *@
<MudDialog @bind-Visible="_deleteDialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@Localizer["DeleteConversation"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>@Localizer["DeleteConversationConfirm", _deleteConversationTitle ?? "this conversation"]</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseDeleteDialog">@Localizer["Cancel"]</MudButton>
        <MudButton Color="Color.Error" 
                   Variant="Variant.Filled" 
                   OnClick="@ConfirmDelete">
            @Localizer["Delete"]
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
