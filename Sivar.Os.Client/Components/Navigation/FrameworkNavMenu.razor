@code {
    /// <summary>
    /// The currently active profile (for visibility filtering and ProfileSwitcher).
    /// </summary>
    [Parameter]
    public ActiveProfileDto? ActiveProfile { get; set; }
    
    /// <summary>
    /// All user profiles for the ProfileSwitcher.
    /// </summary>
    [Parameter]
    public List<ProfileDto> UserProfiles { get; set; } = new();
    
    /// <summary>
    /// Whether the user is authenticated.
    /// </summary>
    [Parameter]
    public bool IsAuthenticated { get; set; }
    
    /// <summary>
    /// User's roles for role-based navigation.
    /// </summary>
    [Parameter]
    public string[] Roles { get; set; } = Array.Empty<string>();
    
    /// <summary>
    /// The platform type (Web, Mobile, Desktop).
    /// </summary>
    [Parameter]
    public PlatformType Platform { get; set; } = PlatformType.Web;
    
    /// <summary>
    /// Whether dark mode is enabled.
    /// </summary>
    [Parameter]
    public bool IsDarkMode { get; set; } = true;
    
    /// <summary>
    /// Event callback when an action item is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnAction { get; set; }
    
    /// <summary>
    /// Event callback when theme is toggled.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnThemeChanged { get; set; }
    
    /// <summary>
    /// Event callback when profile is changed.
    /// </summary>
    [Parameter]
    public EventCallback<ProfileDto> OnProfileChanged { get; set; }
    
    /// <summary>
    /// Event callback when create profile is requested.
    /// </summary>
    [Parameter]
    public EventCallback OnCreateProfile { get; set; }
    
    private IEnumerable<INavigationItem> _visibleItems = Enumerable.Empty<INavigationItem>();
    private NavContext _context = new();
    
    // Chat mode state
    private bool _isOnChatPage;
    private bool _isLoadingConversations;
    private List<ConversationDto>? _conversations;
    private Guid _currentConversationId;
    private string _lastKnownUri = string.Empty;
    private Guid _loadedForProfileId = Guid.Empty; // Track which profile conversations were loaded for
    
    // Dialog state
    private bool _renameDialogVisible;
    private bool _deleteDialogVisible;
    private Guid _dialogConversationId;
    private string? _renameNewTitle;
    private string? _deleteConversationTitle;
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    /// <summary>
    /// Gets the active profile as ProfileDto for ProfileSwitcher compatibility.
    /// Finds the matching profile from UserProfiles by ID.
    /// </summary>
    private ProfileDto? _activeProfileForSwitcher => 
        ActiveProfile != null 
            ? UserProfiles.FirstOrDefault(p => p.Id == ActiveProfile.Id) 
              ?? new ProfileDto 
              { 
                  Id = ActiveProfile.Id, 
                  DisplayName = ActiveProfile.DisplayName, 
                  ProfileType = ActiveProfile.ProfileType,
                  Avatar = ActiveProfile.Avatar ?? string.Empty,
                  IsActive = true
              }
            : null;
    
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        UpdateChatPageState();
        Logger.LogInformation("[FrameworkNavMenu] OnInitialized - isOnChatPage={IsOnChat}", _isOnChatPage);
    }
    
    protected override void OnParametersSet()
    {
        UpdateVisibleItems();
        UpdateChatPageState();
        
        // Load conversations if we're on chat page and have a profile
        // Also reload if the profile changed since we last loaded
        var profileChanged = ActiveProfile != null && _loadedForProfileId != ActiveProfile.Id;
        Logger.LogInformation("[FrameworkNavMenu.OnParametersSet] isOnChat={IsOnChat}, IsAuth={IsAuth}, Profile={Profile}, PrevLoadedProfile={PrevProfile}, NeedLoad={NeedLoad}",
            _isOnChatPage, IsAuthenticated, ActiveProfile?.Id, _loadedForProfileId, 
            _isOnChatPage && IsAuthenticated && ActiveProfile != null && (_conversations == null || profileChanged));
        
        if (_isOnChatPage && IsAuthenticated && ActiveProfile != null && (_conversations == null || profileChanged))
        {
            _ = LoadConversationsAsync();
        }
    }
    
    private void UpdateVisibleItems()
    {
        _context = new NavContext
        {
            IsAuthenticated = IsAuthenticated,
            ActiveProfile = ActiveProfile,
            CurrentRoute = NavigationManager.Uri,
            Platform = Platform,
            Roles = Roles
        };
        
        _visibleItems = NavigationRegistry.GetVisibleItems(_context);
        
        Logger.LogDebug("[FrameworkNavMenu] IsAuthenticated={IsAuth}, Profile={Profile}, VisibleItems={Count}",
            IsAuthenticated, ActiveProfile?.DisplayName ?? "none", _visibleItems.Count());
    }
    
    private bool IsEnabled(INavigationItem item)
    {
        if (item.IsEnabled == null)
            return true;
            
        try
        {
            return item.IsEnabled(_context);
        }
        catch
        {
            return true;
        }
    }
    
    private string GetLocalizedTitle(INavigationItem item)
    {
        // Try to get localized string, fall back to Title
        var localized = Localizer[item.TitleKey];
        return localized.ResourceNotFound ? item.Title : localized.Value;
    }
    
    private async Task HandleAction(INavigationItem item)
    {
        if (!string.IsNullOrEmpty(item.ActionId))
        {
            await OnAction.InvokeAsync(item.ActionId);
        }
    }
    
    private async Task HandleThemeToggle(bool isDark)
    {
        await OnThemeChanged.InvokeAsync(isDark);
    }
    
    private void HandleLogout()
    {
        NavigationManager.NavigateTo("/authentication/logout", forceLoad: true);
    }
    
    /// <summary>
    /// Maps icon names to MudBlazor Icons.
    /// </summary>
    private string GetMudIcon(string iconName)
    {
        return iconName switch
        {
            "Home" => Icons.Material.Filled.Home,
            "Search" => Icons.Material.Filled.Search,
            "EventNote" => Icons.Material.Filled.EventNote,
            "EventAvailable" => Icons.Material.Filled.EventAvailable,
            "SmartToy" => Icons.Material.Filled.SmartToy,
            "Explore" => Icons.Material.Filled.Explore,
            "Person" => Icons.Material.Filled.Person,
            "Settings" => Icons.Material.Filled.Settings,
            "Notifications" => Icons.Material.Filled.Notifications,
            "Chat" => Icons.Material.Filled.Chat,
            "Bookmark" => Icons.Material.Filled.Bookmark,
            "Star" => Icons.Material.Filled.Star,
            "Add" => Icons.Material.Filled.Add,
            "Edit" => Icons.Material.Filled.Edit,
            "Delete" => Icons.Material.Filled.Delete,
            "MoreVert" => Icons.Material.Filled.MoreVert,
            _ => Icons.Material.Filled.Circle
        };
    }
    
    // Chat mode methods
    
    private void UpdateChatPageState()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var wasOnChatPage = _isOnChatPage;
        _isOnChatPage = uri.AbsolutePath.StartsWith("/app/chat", StringComparison.OrdinalIgnoreCase);
        
        // Extract conversation ID from URL if present, or reset to Empty if not
        if (_isOnChatPage && uri.AbsolutePath.Length > "/app/chat/".Length)
        {
            var idPart = uri.AbsolutePath.Substring("/app/chat/".Length);
            if (Guid.TryParse(idPart, out var convId))
            {
                _currentConversationId = convId;
            }
            else
            {
                // Reset to Empty if the ID is invalid
                _currentConversationId = Guid.Empty;
            }
        }
        else if (_isOnChatPage)
        {
            // We're on /app/chat without an ID - reset conversation ID
            _currentConversationId = Guid.Empty;
        }
        else
        {
            // Not on chat page - don't reset so we remember last conversation
        }
        
        Logger.LogInformation("[FrameworkNavMenu] UpdateChatPageState: Uri={Uri}, isOnChatPage={IsOnChatPage}, ConversationId={ConversationId}", 
            uri.AbsolutePath, _isOnChatPage, _currentConversationId);
    }
    
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var previousUri = _lastKnownUri;
        var currentUri = e.Location;
        _lastKnownUri = currentUri;
        
        var wasOnChatPage = _isOnChatPage;
        var previousConversationId = _currentConversationId;
        
        // Parse the new URL to get the conversation ID before updating state
        var newConversationId = ExtractConversationIdFromUri(currentUri);
        
        // Update state (this will also extract conversation ID)
        UpdateChatPageState();
        
        // Check if we navigated to a different conversation
        var conversationChanged = _isOnChatPage && 
                                  newConversationId != Guid.Empty && 
                                  previousConversationId != Guid.Empty &&
                                  newConversationId != previousConversationId;
        
        // Check if current conversation ID is not in our current list (new conversation created by Chat.razor)
        var isNewConversation = _isOnChatPage && 
                                newConversationId != Guid.Empty &&
                                _conversations != null &&
                                !_conversations.Any(c => c.Id == newConversationId);
        
        // Check if we're transitioning FROM no conversation (Empty) TO a conversation
        var isFirstConversationNavigation = _isOnChatPage && 
                                            newConversationId != Guid.Empty && 
                                            previousConversationId == Guid.Empty;
        
        Logger.LogInformation("[FrameworkNavMenu.OnLocationChanged] wasOnChat={WasOnChat}, isOnChat={IsOnChat}, prevConv={PrevConv}, newConv={NewConv}, convChanged={ConvChanged}, isNew={IsNew}, isFirst={IsFirst}", 
            wasOnChatPage, _isOnChatPage, previousConversationId, newConversationId, conversationChanged, isNewConversation, isFirstConversationNavigation);
        
        // Load conversations if:
        // 1. We just navigated to chat page from non-chat page, OR
        // 2. Conversation list is empty, OR
        // 3. We navigated to a different conversation, OR
        // 4. Current conversation ID is not in our list (created by Chat.razor), OR
        // 5. We're going from no conversation to a conversation (first nav)
        if (_isOnChatPage && IsAuthenticated && ActiveProfile != null && 
            (_conversations == null || !wasOnChatPage || conversationChanged || isNewConversation || isFirstConversationNavigation))
        {
            Logger.LogInformation("[FrameworkNavMenu.OnLocationChanged] Triggering LoadConversationsAsync");
            await LoadConversationsAsync();
        }
        
        await InvokeAsync(StateHasChanged);
    }
    
    private Guid ExtractConversationIdFromUri(string uri)
    {
        try
        {
            var absoluteUri = NavigationManager.ToAbsoluteUri(uri);
            var path = absoluteUri.AbsolutePath;
            
            if (path.StartsWith("/app/chat/", StringComparison.OrdinalIgnoreCase) && path.Length > "/app/chat/".Length)
            {
                var idPart = path.Substring("/app/chat/".Length);
                if (Guid.TryParse(idPart, out var convId))
                {
                    return convId;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[FrameworkNavMenu] Error extracting conversation ID from URI: {Uri}", uri);
        }
        
        return Guid.Empty;
    }
    
    private async Task LoadConversationsAsync()
    {
        if (ActiveProfile == null) return;
        
        _isLoadingConversations = true;
        StateHasChanged();
        
        try
        {
            Logger.LogInformation("[FrameworkNavMenu.LoadConversationsAsync] Loading for profile {ProfileId}", ActiveProfile.Id);
            var conversations = await SivarClient.Chat.GetConversationsAsync(ActiveProfile.Id);
            _conversations = conversations?.ToList() ?? new List<ConversationDto>();
            _loadedForProfileId = ActiveProfile.Id; // Track which profile we loaded for
            Logger.LogInformation("[FrameworkNavMenu.LoadConversationsAsync] Loaded {Count} conversations", _conversations.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[FrameworkNavMenu] Error loading conversations");
            _conversations = new List<ConversationDto>();
            // Don't set _loadedForProfileId so we can retry on next opportunity
        }
        finally
        {
            _isLoadingConversations = false;
            StateHasChanged();
        }
    }
    
    private void ExitChatMode()
    {
        NavigationManager.NavigateTo("/app/home");
    }
    
    private async Task HandleNewConversation()
    {
        if (ActiveProfile == null) return;
        
        try
        {
            var dto = new CreateConversationDto
            {
                ProfileId = ActiveProfile.Id,
                Title = "New Conversation"
            };
            
            var conversation = await SivarClient.Chat.CreateConversationAsync(dto);
            if (conversation != null)
            {
                // Insert the new conversation at the top of the list
                _conversations ??= new List<ConversationDto>();
                _conversations.Insert(0, conversation);
                
                // Don't set _currentConversationId here - let UpdateChatPageState() handle it
                // when OnLocationChanged fires after navigation
                
                // Navigate to the new conversation
                NavigationManager.NavigateTo($"/app/chat/{conversation.Id}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[FrameworkNavMenu] Error creating conversation");
        }
    }
    
    private string TruncateTitle(string title, int maxLength)
    {
        if (string.IsNullOrEmpty(title)) return "Conversation";
        return title.Length <= maxLength ? title : title.Substring(0, maxLength - 3) + "...";
    }
    
    // Rename dialog methods
    private void OpenRenameDialog(Guid conversationId, string? currentTitle)
    {
        _dialogConversationId = conversationId;
        _renameNewTitle = currentTitle ?? "Conversation";
        _renameDialogVisible = true;
    }
    
    private void CloseRenameDialog()
    {
        _renameDialogVisible = false;
        _renameNewTitle = null;
    }
    
    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_renameNewTitle))
        {
            await ConfirmRename();
        }
        else if (e.Key == "Escape")
        {
            CloseRenameDialog();
        }
    }
    
    private async Task ConfirmRename()
    {
        if (string.IsNullOrWhiteSpace(_renameNewTitle)) return;
        
        try
        {
            Logger.LogInformation("[FrameworkNavMenu] Renaming conversation {Id} to '{Title}'", _dialogConversationId, _renameNewTitle);
            
            var updateDto = new UpdateConversationDto { Title = _renameNewTitle.Trim() };
            await SivarClient.Chat.UpdateConversationAsync(_dialogConversationId, updateDto);
            
            // Update local list
            var conversation = _conversations?.FirstOrDefault(c => c.Id == _dialogConversationId);
            if (conversation != null)
            {
                var index = _conversations!.IndexOf(conversation);
                _conversations[index] = conversation with { Title = _renameNewTitle.Trim() };
            }
            
            CloseRenameDialog();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[FrameworkNavMenu] Error renaming conversation {Id}", _dialogConversationId);
        }
    }
    
    // Delete dialog methods
    private void OpenDeleteDialog(Guid conversationId, string? title)
    {
        _dialogConversationId = conversationId;
        _deleteConversationTitle = title ?? "this conversation";
        _deleteDialogVisible = true;
    }
    
    private void CloseDeleteDialog()
    {
        _deleteDialogVisible = false;
        _deleteConversationTitle = null;
    }
    
    private async Task ConfirmDelete()
    {
        try
        {
            Logger.LogInformation("[FrameworkNavMenu] Deleting conversation {Id}", _dialogConversationId);
            
            await SivarClient.Chat.DeleteConversationAsync(_dialogConversationId);
            
            // Remove from local list
            _conversations?.RemoveAll(c => c.Id == _dialogConversationId);
            
            // If we deleted the current conversation, navigate to a different one or to chat home
            if (_currentConversationId == _dialogConversationId)
            {
                var nextConversation = _conversations?.FirstOrDefault();
                if (nextConversation != null)
                {
                    NavigationManager.NavigateTo($"/app/chat/{nextConversation.Id}");
                }
                else
                {
                    NavigationManager.NavigateTo("/app/chat");
                }
            }
            
            CloseDeleteDialog();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[FrameworkNavMenu] Error deleting conversation {Id}", _dialogConversationId);
        }
    }
    
    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
