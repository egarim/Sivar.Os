    .nav-theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 16px;
        margin-top: 8px;
    }
    
    .theme-icon {
        color: var(--mud-palette-text-secondary);
        opacity: 0.5;
        transition: opacity 0.2s, color 0.2s;
