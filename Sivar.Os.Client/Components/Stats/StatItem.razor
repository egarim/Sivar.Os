@* StatItem component *@

<div class="stat-item">
    <div class="stat-label">@Label</div>
    <div class="stat-value">@Value</div>
</div>

@code {
    /// <summary>
    /// Stat label
    /// </summary>
    [Parameter]
    public string Label { get; set; } = string.Empty;

    /// <summary>
    /// Stat value
    /// </summary>
    [Parameter]
    public string Value { get; set; } = string.Empty;
}
