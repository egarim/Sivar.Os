@using Sivar.Os.Client.Pages

@* ChatResultCard component *@

<div class="chat-result-card" @onclick="OnClick">
    <div class="chat-result-header">
        <div class="chat-result-avatar">@ResultCard.Avatar</div>
        <div class="chat-result-info">
            <div class="chat-result-name">@ResultCard.Name</div>
            <div class="chat-result-type">@ResultCard.Type</div>
        </div>
    </div>
    <div class="chat-result-description">@ResultCard.Description</div>
    <div class="chat-result-actions">
        <button class="chat-result-btn primary" @onclick="() => OnView.InvokeAsync()" @onclick:stopPropagation="true">
            👁️ View Profile
        </button>
        <button class="chat-result-btn secondary" @onclick="() => OnSave.InvokeAsync()" @onclick:stopPropagation="true">
            📌 Save
        </button>
        <button class="chat-result-btn secondary" @onclick="() => OnFollow.InvokeAsync()" @onclick:stopPropagation="true">
            ➕ Follow
        </button>
    </div>
</div>

@code {
    /// <summary>
    /// The result card data
    /// </summary>
    [Parameter, EditorRequired]
    public Sivar.Os.Client.Pages.ChatResultCard ResultCard { get; set; } = null!;

    /// <summary>
    /// Callback when card is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnClick { get; set; }

    /// <summary>
    /// Callback when view button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnView { get; set; }

    /// <summary>
    /// Callback when save button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnSave { get; set; }

    /// <summary>
    /// Callback when follow button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnFollow { get; set; }
}
