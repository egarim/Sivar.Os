@*
    SearchResultsMap.razor - Displays search results on an interactive Leaflet map
    Phase 6: Map View Integration
*@

@using Microsoft.JSInterop
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Services
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IProfileBookmarkService BookmarkService
@implements IAsyncDisposable

<div class="search-results-map-container">
    @if (_isLoading)
    {
        <div class="map-loading-overlay">
            <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
            <span>Cargando mapa...</span>
        </div>
    }
    @if (_noLocationsFound)
    {
        <div class="map-no-locations-overlay">
            <MudIcon Icon="@Icons.Material.Filled.LocationOff" Size="Size.Large" Color="Color.Warning" />
            <span class="no-locations-title">Sin ubicaciones disponibles</span>
            <span class="no-locations-text">Los resultados no tienen coordenadas GPS registradas</span>
        </div>
    }
    <div id="@_mapId" class="search-results-map" style="height: @(Height)px;"></div>
    
    @if (_selectedBusiness != null)
    {
        <div class="map-selected-card" @onclick="() => NavigateToResult(_selectedBusiness)">
            <button class="close-card-btn" @onclick="CloseSelectedCard" @onclick:stopPropagation="true">×</button>
            @if (!string.IsNullOrEmpty(_selectedBusiness.ImageUrl))
            {
                <img src="@_selectedBusiness.ImageUrl" alt="@_selectedBusiness.Title" class="selected-card-image" />
            }
            <div class="selected-card-content">
                <div class="selected-card-header">
                    <h4>@_selectedBusiness.Title</h4>
                    @* Phase 7: Quick Actions *@
                    <div class="selected-card-actions">
                        <button class="map-quick-btn @(IsBusinessSaved(_selectedBusiness.Id) ? "saved" : "")" 
                                @onclick="() => ToggleSave(_selectedBusiness)" 
                                @onclick:stopPropagation="true"
                                title="@(IsBusinessSaved(_selectedBusiness.Id) ? "Quitar" : "Guardar")">
                            <MudIcon Icon="@(IsBusinessSaved(_selectedBusiness.Id) ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)" Size="Size.Small" />
                        </button>
                        <button class="map-quick-btn" 
                                @onclick="() => ShareBusiness(_selectedBusiness)" 
                                @onclick:stopPropagation="true"
                                title="Compartir">
                            <MudIcon Icon="@Icons.Material.Filled.Share" Size="Size.Small" />
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_selectedBusiness.Category))
                {
                    <span class="selected-card-category">@_selectedBusiness.Category</span>
                }
                @if (_selectedBusiness.IsOpenNow.HasValue)
                {
                    <span class="selected-card-status @(_selectedBusiness.IsOpenNow.Value ? "open" : "closed")">
                        @(_selectedBusiness.IsOpenNow.Value ? "🟢 Abierto" : "🔴 Cerrado")
                    </span>
                }
                @if (!string.IsNullOrEmpty(_selectedBusiness.City))
                {
                    <p class="selected-card-location">📍 @_selectedBusiness.City</p>
                }
                <button class="view-profile-btn" @onclick="() => NavigateToResult(_selectedBusiness)" @onclick:stopPropagation="true">
                    Ver Perfil →
                </button>
            </div>
        </div>
    }
</div>

@code {
    /// <summary>
    /// Search results to display on the map
    /// </summary>
    [Parameter] public SearchResultsCollectionDto? Results { get; set; }

    /// <summary>
    /// Height of the map in pixels
    /// </summary>
    [Parameter] public int Height { get; set; } = 350;

    /// <summary>
    /// Default center latitude (El Salvador)
    /// </summary>
    [Parameter] public double DefaultLatitude { get; set; } = 13.6929;

    /// <summary>
    /// Default center longitude (El Salvador)
    /// </summary>
    [Parameter] public double DefaultLongitude { get; set; } = -89.2182;

    /// <summary>
    /// Default zoom level
    /// </summary>
    [Parameter] public int DefaultZoom { get; set; } = 12;

    /// <summary>
    /// User's current latitude (for showing user location marker)
    /// </summary>
    [Parameter] public double? UserLatitude { get; set; }

    /// <summary>
    /// User's current longitude (for showing user location marker)
    /// </summary>
    [Parameter] public double? UserLongitude { get; set; }

    /// <summary>
    /// Whether to show distance lines from user to results
    /// </summary>
    [Parameter] public bool ShowDistanceLines { get; set; } = true;

    private readonly string _mapId = $"search-map-{Guid.NewGuid():N}";
    private bool _isLoading = true;
    private bool _isInitialized = false;
    private bool _noLocationsFound = false;
    private DotNetObjectReference<SearchResultsMap>? _dotNetRef;
    private BusinessSearchResultDto? _selectedBusiness;
    private List<BusinessSearchResultDto> _businessesWithLocation = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadBookmarksAsync();
            await InitializeMapAsync();
        }
    }
    
    /// <summary>
    /// Load user's bookmarks from the database
    /// </summary>
    private async Task LoadBookmarksAsync()
    {
        try
        {
            var bookmarkedIds = await BookmarkService.GetMyBookmarkedPostIdsAsync();
            _savedBusinessIds = new HashSet<Guid>(bookmarkedIds);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SearchResultsMap] Error loading bookmarks: {ex.Message}");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isInitialized && Results != null)
        {
            await UpdateMarkersAsync();
        }
    }

    private async Task InitializeMapAsync()
    {
        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);

            // Calculate initial center from results or use default
            var (centerLat, centerLng) = CalculateCenter();

            var options = new
            {
                scrollWheelZoom = true,
                dragging = true,
                zoomControl = true,
                tileProvider = "cartodb" // Faster CDN tiles
            };

            var success = await JS.InvokeAsync<bool>(
                "initializeMap",
                _mapId,
                centerLat,
                centerLng,
                DefaultZoom,
                options,
                _dotNetRef
            );

            if (success)
            {
                _isInitialized = true;
                _isLoading = false;
                StateHasChanged();
                
                await UpdateMarkersAsync();
                
                // Invalidate size after short delay
                await Task.Delay(100);
                await JS.InvokeVoidAsync("leafletInterop.invalidateSize", _mapId);
            }
            else
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SearchResultsMap] Error initializing map: {ex.Message}");
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task UpdateMarkersAsync()
    {
        if (!_isInitialized || Results == null) return;

        try
        {
            // Log all result counts for debugging
            Console.WriteLine($"[SearchResultsMap] Results: Businesses={Results.Businesses?.Count ?? 0}, Events={Results.Events?.Count ?? 0}, Tourism={Results.Tourism?.Count ?? 0}, Procedures={Results.Procedures?.Count ?? 0}");
            
            // Get all businesses with valid coordinates
            _businessesWithLocation = (Results.Businesses ?? [])
                .Where(b => b.Latitude.HasValue && b.Longitude.HasValue)
                .ToList();

            Console.WriteLine($"[SearchResultsMap] Businesses with coordinates: {_businessesWithLocation.Count}");
            
            // Log businesses that don't have coordinates for debugging
            var businessesWithoutLocation = (Results.Businesses ?? [])
                .Where(b => !b.Latitude.HasValue || !b.Longitude.HasValue)
                .ToList();
            if (businessesWithoutLocation.Any())
            {
                Console.WriteLine($"[SearchResultsMap] Businesses WITHOUT coordinates: {businessesWithoutLocation.Count}");
                foreach (var b in businessesWithoutLocation.Take(3))
                {
                    Console.WriteLine($"  - {b.Title}: Lat={b.Latitude}, Lng={b.Longitude}");
                }
            }

            // Also get events with location
            var eventsWithLocation = (Results.Events ?? [])
                .Where(e => e.Latitude.HasValue && e.Longitude.HasValue)
                .ToList();
            Console.WriteLine($"[SearchResultsMap] Events with coordinates: {eventsWithLocation.Count}");

            // Also get tourism spots with location
            var tourismWithLocation = (Results.Tourism ?? [])
                .Where(t => t.Latitude.HasValue && t.Longitude.HasValue)
                .ToList();
            Console.WriteLine($"[SearchResultsMap] Tourism with coordinates: {tourismWithLocation.Count}");

            // Create combined marker list
            var allMarkers = new List<object>();
            
            // Add business markers
            allMarkers.AddRange(_businessesWithLocation.Select((b, index) => new
            {
                id = b.Id.ToString(),
                lat = b.Latitude!.Value,
                lng = b.Longitude!.Value,
                title = b.Title,
                popup = BuildPopupHtml(b),
                iconType = GetIconType(b),
                onClick = true,
                resultType = "business"
            }));

            // Add event markers
            allMarkers.AddRange(eventsWithLocation.Select((e, index) => new
            {
                id = e.Id.ToString(),
                lat = e.Latitude!.Value,
                lng = e.Longitude!.Value,
                title = e.Title,
                popup = $"<strong>{e.Title}</strong><br/>{e.EventDateFormatted}<br/>{e.Venue ?? ""}",
                iconType = "event",
                onClick = true,
                resultType = "event"
            }));

            // Add tourism markers
            allMarkers.AddRange(tourismWithLocation.Select((t, index) => new
            {
                id = t.Id.ToString(),
                lat = t.Latitude!.Value,
                lng = t.Longitude!.Value,
                title = t.Title,
                popup = $"<strong>{t.Title}</strong><br/>{t.Address ?? ""}<br/>⭐ {t.Rating?.ToString("F1") ?? "N/A"}",
                iconType = "tourism",
                onClick = true,
                resultType = "tourism"
            }));

            if (allMarkers.Count == 0)
            {
                Console.WriteLine("[SearchResultsMap] No results with location data found!");
                _noLocationsFound = true;
                StateHasChanged();
                return;
            }
            
            _noLocationsFound = false;

            Console.WriteLine($"[SearchResultsMap] Adding {allMarkers.Count} total markers to map");
            await JS.InvokeVoidAsync("leafletInterop.addMultipleMarkers", _mapId, allMarkers, true);

            // Add user location marker if available
            if (UserLatitude.HasValue && UserLongitude.HasValue)
            {
                await JS.InvokeVoidAsync("leafletInterop.addUserLocationMarker", _mapId, UserLatitude.Value, UserLongitude.Value);
                Console.WriteLine($"[SearchResultsMap] Added user location marker at ({UserLatitude}, {UserLongitude})");

                // Draw distance lines from user to results
                if (ShowDistanceLines)
                {
                    await JS.InvokeVoidAsync("leafletInterop.drawDistanceLines", _mapId, UserLatitude.Value, UserLongitude.Value, true);
                    Console.WriteLine("[SearchResultsMap] Drew distance lines to results");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SearchResultsMap] Error updating markers: {ex.Message}");
        }
    }

    private (double lat, double lng) CalculateCenter()
    {
        // Collect all coordinates from all result types
        var allCoords = new List<(double lat, double lng)>();
        
        if (Results?.Businesses != null)
        {
            allCoords.AddRange(Results.Businesses
                .Where(b => b.Latitude.HasValue && b.Longitude.HasValue)
                .Select(b => (b.Latitude!.Value, b.Longitude!.Value)));
        }
        
        if (Results?.Events != null)
        {
            allCoords.AddRange(Results.Events
                .Where(e => e.Latitude.HasValue && e.Longitude.HasValue)
                .Select(e => (e.Latitude!.Value, e.Longitude!.Value)));
        }
        
        if (Results?.Tourism != null)
        {
            allCoords.AddRange(Results.Tourism
                .Where(t => t.Latitude.HasValue && t.Longitude.HasValue)
                .Select(t => (t.Latitude!.Value, t.Longitude!.Value)));
        }

        if (!allCoords.Any())
            return (DefaultLatitude, DefaultLongitude);

        var avgLat = allCoords.Average(c => c.lat);
        var avgLng = allCoords.Average(c => c.lng);

        return (avgLat, avgLng);
    }

    private string BuildPopupHtml(BusinessSearchResultDto business)
    {
        var statusHtml = business.IsOpenNow.HasValue
            ? $"<span class='popup-status {(business.IsOpenNow.Value ? "open" : "closed")}'>{(business.IsOpenNow.Value ? "🟢 Abierto" : "🔴 Cerrado")}</span>"
            : "";

        var categoryHtml = !string.IsNullOrEmpty(business.Category)
            ? $"<span class='popup-category'>{business.Category}</span>"
            : "";

        var distanceHtml = business.DistanceKm.HasValue
            ? $"<span class='popup-distance'>📍 {business.DistanceKm.Value:F1} km</span>"
            : "";

        return $@"
            <div class='search-result-popup-content'>
                <strong class='popup-title'>{EscapeHtml(business.Title)}</strong>
                {categoryHtml}
                {statusHtml}
                {distanceHtml}
            </div>";
    }

    private string GetIconType(BusinessSearchResultDto business)
    {
        // Map category to icon type
        var category = business.Category?.ToLowerInvariant() ?? "";
        
        return category switch
        {
            var c when c.Contains("restaurant") || c.Contains("comida") || c.Contains("food") => "Restaurant",
            var c when c.Contains("hotel") || c.Contains("hospedaje") => "Hotel",
            var c when c.Contains("tienda") || c.Contains("store") || c.Contains("shop") => "Store",
            var c when c.Contains("gobierno") || c.Contains("government") => "Government",
            var c when c.Contains("salud") || c.Contains("hospital") || c.Contains("clinic") => "Health",
            var c when c.Contains("banco") || c.Contains("bank") => "Bank",
            var c when c.Contains("turismo") || c.Contains("tourism") => "Tourism",
            _ => "Default"
        };
    }

    private string EscapeHtml(string text)
    {
        return text
            .Replace("&", "&amp;")
            .Replace("<", "&lt;")
            .Replace(">", "&gt;")
            .Replace("\"", "&quot;")
            .Replace("'", "&#39;");
    }

    [JSInvokable]
    public void OnMarkerClick(int index, string? id)
    {
        if (index >= 0 && index < _businessesWithLocation.Count)
        {
            _selectedBusiness = _businessesWithLocation[index];
            StateHasChanged();
        }
    }

    private void CloseSelectedCard()
    {
        _selectedBusiness = null;
        StateHasChanged();
    }

    private void NavigateToResult(BusinessSearchResultDto business)
    {
        NavigationManager.NavigateTo(business.NavigationUrl);
    }

    #region Phase 7: Save & Share
    
    /// <summary>
    /// Set of saved business IDs (loaded from database)
    /// </summary>
    private HashSet<Guid> _savedBusinessIds = new();
    
    private bool IsBusinessSaved(Guid businessId) => _savedBusinessIds.Contains(businessId);
    
    /// <summary>
    /// Toggle save state for a business (persists to database)
    /// </summary>
    private async Task ToggleSaveAsync(BusinessSearchResultDto business)
    {
        try
        {
            var isNowBookmarked = await BookmarkService.ToggleBookmarkAsync(business.Id);
            
            if (isNowBookmarked)
            {
                _savedBusinessIds.Add(business.Id);
            }
            else
            {
                _savedBusinessIds.Remove(business.Id);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SearchResultsMap] Error toggling bookmark: {ex.Message}");
        }
    }
    
    /// <summary>
    /// Toggle save state (synchronous wrapper for UI binding)
    /// </summary>
    private void ToggleSave(BusinessSearchResultDto business)
    {
        _ = ToggleSaveAsync(business);
    }
    
    private async Task ShareBusiness(BusinessSearchResultDto business)
    {
        var baseUrl = NavigationManager.BaseUri.TrimEnd('/');
        var url = $"{baseUrl}{business.NavigationUrl}";
        var text = $"¡Mira esto! {business.Title}";
        
        try
        {
            // Try native share first
            await JS.InvokeVoidAsync("navigator.share", new { title = business.Title, text, url });
        }
        catch
        {
            // Fallback to clipboard
            try
            {
                await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
            }
            catch
            {
                // Final fallback: open WhatsApp
                var whatsappUrl = $"https://wa.me/?text={Uri.EscapeDataString(text + "\n" + url)}";
                NavigationManager.NavigateTo(whatsappUrl, forceLoad: true);
            }
        }
    }
    
    #endregion

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_isInitialized)
            {
                await JS.InvokeVoidAsync("destroyMap", _mapId);
            }
            _dotNetRef?.Dispose();
        }
        catch
        {
            // Ignore disposal errors
        }
    }
}
