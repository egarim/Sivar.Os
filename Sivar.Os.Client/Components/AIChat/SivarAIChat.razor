    #region Helper Methods
    
    /// <summary>
    /// Render markdown content to HTML
    /// </summary>
    private string RenderMarkdown(string content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return string.Empty;
        
        try
        {
            return Markdown.ToHtml(content, _markdownPipeline);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[SivarAIChat] Markdown rendering failed, returning raw content");
            return System.Net.WebUtility.HtmlEncode(content);
        }
    }
    
    /// <summary>
    /// Get a unique message ID from the context
    /// </summary>
    private string GetMessageId(BlazorChatMessage context)
    {
        // Use content hash as identifier
        var contentHash = context.Content?.GetHashCode() ?? 0;
        return $"msg_hash_{contentHash}";
    }
    
    /// <summary>
    /// Try to get structured results for a message
    /// </summary>
    private bool TryGetStructuredResults(string messageId, out SearchResultsCollectionDto? results)
    {
        // Try exact match first
        if (_messageResults.TryGetValue(messageId, out results))
            return true;
        
        // Try content hash lookup (extract hash from messageId if it contains one)
        if (messageId.StartsWith("msg_hash_") && int.TryParse(messageId.Replace("msg_hash_", ""), out var hash))
        {
            if (_contentHashResults.TryGetValue(hash, out results))
            {
                Logger.LogInformation("[SivarAIChat] Found results by content hash: {Hash}", hash);
                return true;
            }
        }
        
        // Try to find by content hash pattern (fallback)
        var matches = _messageResults.Keys
            .Where(k => k.Contains(messageId) || messageId.Contains(k.Split('_').LastOrDefault() ?? ""))
            .ToList();
        
        if (matches.Any())
        {
            results = _messageResults[matches.First()];
            return true;
        }
        
        results = null;
        return false;
    }
    
    #endregion
