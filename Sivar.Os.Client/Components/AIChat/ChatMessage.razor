    private void ToggleSaveBusiness(BusinessSearchResultDto business)
    {
        if (_savedBusinessIds.Contains(business.Id))
        {
            _savedBusinessIds.Remove(business.Id);
            Console.WriteLine($"[ChatMessage] Removed from saved: {business.Title}");
        }
        else
        {
            _savedBusinessIds.Add(business.Id);
            Console.WriteLine($"[ChatMessage] Saved: {business.Title}");
        }
        StateHasChanged();
    }
    
    /// <summary>
    /// Show share options modal
    /// </summary>
    private void ShowShareOptions(BusinessSearchResultDto business)
    {
        _shareBusinessTarget = business;
        _showShareModal = true;
        _showCopiedMessage = false;
        StateHasChanged();
    }
    
    /// <summary>
    /// Close share modal
    /// </summary>
    private void CloseShareModal()
    {
        _showShareModal = false;
        _shareBusinessTarget = null;
        _showCopiedMessage = false;
    }
    
    /// <summary>
    /// Build shareable URL for a business
    /// </summary>
    private string GetShareableUrl(BusinessSearchResultDto business)
    {
        var baseUrl = NavigationManager.BaseUri.TrimEnd('/');
        return $"{baseUrl}{business.NavigationUrl}";
    }
    
    /// <summary>
    /// Copy link to clipboard
    /// </summary>
    private async Task CopyLinkToClipboard()
    {
        if (_shareBusinessTarget == null) return;
        
        var url = GetShareableUrl(_shareBusinessTarget);
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
            _showCopiedMessage = true;
            StateHasChanged();
            
            // Hide message after 2 seconds
            await Task.Delay(2000);
            _showCopiedMessage = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChatMessage] Failed to copy to clipboard: {ex.Message}");
        }
    }
    
    /// <summary>
    /// Share via WhatsApp
    /// </summary>
    private void ShareViaWhatsApp()
    {
        if (_shareBusinessTarget == null) return;
        
        var url = GetShareableUrl(_shareBusinessTarget);
        var text = $"¡Mira esto! {_shareBusinessTarget.Title}";
        if (!string.IsNullOrEmpty(_shareBusinessTarget.Category))
        {
            text += $" - {_shareBusinessTarget.Category}";
        }
        
        var whatsappUrl = $"https://wa.me/?text={Uri.EscapeDataString(text + "\n" + url)}";
        NavigationManager.NavigateTo(whatsappUrl, forceLoad: true);
        CloseShareModal();
    }
    
    /// <summary>
    /// Use native share API (mobile)
    /// </summary>
    private async Task ShareNative()
    {
        if (_shareBusinessTarget == null) return;
        
        var url = GetShareableUrl(_shareBusinessTarget);
        var title = _shareBusinessTarget.Title;
        var text = !string.IsNullOrEmpty(_shareBusinessTarget.Description) 
            ? _shareBusinessTarget.Description 
            : $"Descubre {title} en Sivar.Os";
        
        try
        {
            await JS.InvokeVoidAsync("navigator.share", new { title, text, url });
            CloseShareModal();
        }
        catch
        {
            // Fallback to copy if native share not available
            await CopyLinkToClipboard();
        }
    }
    
