    // Parsed results cache
    private List<BusinessResult>? _cachedResults;
    private string? _cachedIntro;
    private string? _cachedFooter;
    private bool _parsed = false;

    /// <summary>
    /// Business result extracted from AI response
    /// </summary>
    private class BusinessResult
    {
        public string Name { get; set; } = "";
        public string Url { get; set; } = "";
        public string Description { get; set; } = "";
        public string Category { get; set; } = "";
    }

    /// <summary>
    /// Check if the message contains business/profile results
    /// </summary>
    private bool HasBusinessResults()
    {
        if (string.IsNullOrEmpty(Message.Text)) return false;
        
        // Look for patterns like "[Name](/profile/...)" or numbered lists with links
        var pattern = @"\[([^\]]+)\]\(/[a-z\-]+\)";
        return Regex.IsMatch(Message.Text, pattern);
    }

    /// <summary>
    /// Parse and cache the message content
    /// </summary>
    private void ParseMessage()
    {
        if (_parsed) return;
        _parsed = true;

        var text = Message.Text ?? "";
        _cachedResults = new List<BusinessResult>();

        // Pattern to match: 1. [Name](/handle) or **[Name](/handle)**
        // Description follows on the next line or after the link
        var pattern = @"(?:^|\n)\s*(?:\d+\.\s*)?(?:\*\*)?(?:🔗\s*)?\[([^\]]+)\]\((/[a-z0-9\-]+)\)(?:\*\*)?[\s\-:]*([^\n\[]*)?";
        var matches = Regex.Matches(text, pattern, RegexOptions.IgnoreCase | RegexOptions.Multiline);

        var resultEndIndex = 0;
        var firstMatchIndex = text.Length;

        foreach (Match match in matches)
        {
            if (match.Index < firstMatchIndex) firstMatchIndex = match.Index;
            resultEndIndex = Math.Max(resultEndIndex, match.Index + match.Length);

            var name = match.Groups[1].Value.Trim();
            var url = match.Groups[2].Value.Trim();
            var description = match.Groups[3].Value.Trim();

            // Try to extract more description from following text
            var afterMatch = text.Substring(match.Index + match.Length);
            var nextLineMatch = Regex.Match(afterMatch, @"^\s*([^0-9\[\n][^\n\[]{10,})");
            if (nextLineMatch.Success && string.IsNullOrEmpty(description))
            {
                description = nextLineMatch.Groups[1].Value.Trim();
            }

            _cachedResults.Add(new BusinessResult
            {
                Name = name,
                Url = url,
                Description = CleanDescription(description),
                Category = InferCategory(name, description)
            });
        }

        // Extract intro text (everything before first result)
        if (firstMatchIndex > 0)
        {
            _cachedIntro = text.Substring(0, firstMatchIndex).Trim();
            // Remove trailing colons or empty lines
            _cachedIntro = Regex.Replace(_cachedIntro, @":\s*$", "").Trim();
        }

        // Extract footer text (everything after last result, if significant)
        if (resultEndIndex < text.Length - 10)
        {
            var footer = text.Substring(resultEndIndex).Trim();
            // Only include if it's substantial and not just a continuation of the last result
            if (footer.Length > 20 && !footer.StartsWith(",") && !footer.StartsWith("."))
            {
                _cachedFooter = footer;
            }
        }
    }

    private string CleanDescription(string desc)
    {
        if (string.IsNullOrEmpty(desc)) return "";
        // Remove leading dashes, asterisks, numbers
        desc = Regex.Replace(desc, @"^[\s\-\*\.]+", "");
        // Remove trailing punctuation
        desc = desc.TrimEnd('.', ',', '-');
        return desc.Trim();
    }

    private string InferCategory(string name, string description)
    {
        var combined = (name + " " + description).ToLower();
        
        if (combined.Contains("pupus") || combined.Contains("típic") || combined.Contains("salvadoreñ"))
            return "🇸🇻 Comida Salvadoreña";
        if (combined.Contains("restaurante") || combined.Contains("restaurant") || combined.Contains("comida"))
            return "🍽️ Restaurante";
        if (combined.Contains("café") || combined.Contains("coffee") || combined.Contains("cafe"))
            return "☕ Café";
        if (combined.Contains("hotel") || combined.Contains("hostal"))
            return "🏨 Hospedaje";
        if (combined.Contains("banco") || combined.Contains("bank"))
            return "🏦 Banco";
        if (combined.Contains("farmacia") || combined.Contains("pharmacy"))
            return "💊 Farmacia";
        if (combined.Contains("gobierno") || combined.Contains("government") || combined.Contains("alcaldía") || combined.Contains("ministerio"))
            return "🏛️ Gobierno";
        if (combined.Contains("playa") || combined.Contains("beach"))
            return "🏖️ Playa";
        if (combined.Contains("museo") || combined.Contains("museum"))
            return "🏛️ Museo";
        if (combined.Contains("parque") || combined.Contains("park"))
            return "🌳 Parque";
        if (combined.Contains("vegetarian") || combined.Contains("vegano") || combined.Contains("vegan"))
            return "🥗 Vegetariano";
        
        return "📍 Lugar";
    }

    private string GetCategoryIcon(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "📍";
        var lower = name.ToLower();
        if (lower.Contains("pupus")) return "🫓";
        if (lower.Contains("café") || lower.Contains("coffee")) return "☕";
        if (lower.Contains("restaurante") || lower.Contains("restaurant")) return "🍽️";
        if (lower.Contains("banco")) return "🏦";
        if (lower.Contains("farmacia")) return "💊";
        if (lower.Contains("playa")) return "🏖️";
        if (lower.Contains("museo")) return "🏛️";
        if (lower.Contains("hotel")) return "🏨";
        if (lower.Contains("alcaldía") || lower.Contains("ministerio")) return "🏢";
        return "📍";
    }

    private List<BusinessResult> ExtractBusinessResults()
    {
        ParseMessage();
        return _cachedResults ?? new List<BusinessResult>();
    }

    private string GetIntroText()
    {
        ParseMessage();
        return _cachedIntro ?? "";
    }

    private string GetFooterText()
    {
        ParseMessage();
        return _cachedFooter ?? "";
    }

    private string TruncateText(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength) return text;
        return text.Substring(0, maxLength - 3) + "...";
    }

