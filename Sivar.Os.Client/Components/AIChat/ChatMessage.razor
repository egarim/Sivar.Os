@using Sivar.Os.Client.Pages
@using Sivar.Os.Shared.DTOs
@using System.Text.RegularExpressions
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@* ChatMessage component *@

<div class="chat-message @(IsUser ? "user" : "ai")">
    <div class="chat-message-avatar">@(IsUser ? "👤" : "🤖")</div>
    <div class="chat-message-content">
        @if (Message.MessageType == "result-card" && Message.ResultCard != null)
        {
            <ChatResultCard 
                ResultCard="@Message.ResultCard"
                OnView="@OnResultView"
                OnSave="@OnResultSave"
                OnFollow="@OnResultFollow" />
        }
        else if (Message.StructuredResults != null && Message.StructuredResults.HasResults)
        {
            @* Render structured results as graphical cards in a carousel *@
            <div class="chat-bubble chat-intro">
                @((MarkupString)RenderMarkdown(Message.Text))
            </div>
            
            <div class="chat-carousel-container" style="position: relative; width: 100%; max-width: 600px;">
                <button class="carousel-nav carousel-prev" @onclick="() => ScrollCarousel(-1)" @onclick:stopPropagation="true">
                    <span>‹</span>
                </button>
                
                <div class="chat-results-grid" @ref="_carouselRef" style="display: flex; flex-direction: row; flex-wrap: nowrap; gap: 12px; overflow-x: auto; padding: 8px 24px; scroll-snap-type: x mandatory;">
                    @foreach (var business in Message.StructuredResults.Businesses)
                    {
                        <div class="chat-business-card" @onclick="() => NavigateTo(business.NavigationUrl)" style="flex-shrink: 0; min-width: 220px; max-width: 220px;">
                            <div class="card-header">
                                @if (!string.IsNullOrEmpty(business.ImageUrl))
                                {
                                    <img class="card-image" src="@business.ImageUrl" alt="@business.Title" 
                                         style="width: 48px; height: 48px; min-width: 48px; max-width: 48px; object-fit: cover; border-radius: 10px;" />
                                }
                                else
                                {
                                    <div class="card-icon">@GetCategoryIcon(business.Category)</div>
                                }
                                <div class="card-title-section">
                                    <h4 class="card-name">@business.Title</h4>
                                    @if (!string.IsNullOrEmpty(business.Category))
                                    {
                                        <span class="card-category">@business.Category</span>
                                    }
                                </div>
                                @* Phase 7: Quick Save/Share Actions *@
                                <div class="card-quick-actions">
                                    <button class="quick-action-btn @(IsBusinessSaved(business.Id) ? "saved" : "")" 
                                            @onclick="() => ToggleSaveBusiness(business)" 
                                            @onclick:stopPropagation="true"
                                            title="@(IsBusinessSaved(business.Id) ? "Quitar de guardados" : "Guardar")">
                                        <MudIcon Icon="@(IsBusinessSaved(business.Id) ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)" Size="Size.Small" />
                                    </button>
                                    <button class="quick-action-btn" 
                                            @onclick="() => ShowShareOptions(business)" 
                                            @onclick:stopPropagation="true"
                                            title="Compartir">
                                        <MudIcon Icon="@Icons.Material.Filled.Share" Size="Size.Small" />
                                    </button>
                                </div>
                                @if (business.RelevanceScore > 0.7)
                                {
                                    <span class="relevance-badge high">⭐</span>
                                }
                            </div>
                            
                            @* Phase 5: Real-time Open Status Badge *@
                            @if (business.IsOpenNow.HasValue)
                            {
                                <div class="open-status-badge @(business.IsOpenNow.Value ? "open" : "closed")">
                                    <span class="status-dot">@(business.IsOpenNow.Value ? "🟢" : "🔴")</span>
                                    <span class="status-text">@business.OpenStatusText</span>
                                </div>
                            }
                            
                            @if (!string.IsNullOrEmpty(business.Description))
                            {
                                <p class="card-description">@TruncateText(business.Description, 80)</p>
                            }
                            
                            <div class="card-meta">
                                @if (!string.IsNullOrEmpty(business.City))
                                {
                                    <span class="meta-item">
                                        <span class="meta-icon">📍</span>
                                        @business.City
                                        @if (business.DistanceKm.HasValue)
                                        {
                                            <span class="distance">(@business.DistanceKm.Value.ToString("F1") km)</span>
                                        }
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(business.PriceRange))
                                {
                                    <span class="meta-item price-range">@business.PriceRange</span>
                                }
                                @if (business.Rating.HasValue)
                                {
                                    <span class="meta-item rating">⭐ @business.Rating.Value.ToString("F1")</span>
                                }
                            </div>
                            
                            @* Contact Actions (Phase 1: Enhanced Contact System) *@
                            @if (business.Contacts?.Any() == true)
                            {
                                <div class="card-contacts">
                                    <ContactActions Contacts="@business.Contacts.ToList()" 
                                                    MaxTotal="3" 
                                                    IconOnly="true"
                                                    ButtonSize="Size.Small"
                                                    ButtonVariant="Variant.Text" />
                                </div>
                            }
                            
                            <div class="card-actions">
                                @foreach (var action in business.Actions.Take(2))
                                {
                                    <button class="card-btn @(action.IsPrimary ? "primary" : "secondary")" 
                                            @onclick="() => HandleAction(action)" 
                                            @onclick:stopPropagation="true">
                                        @action.Label
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    
                    @foreach (var evt in Message.StructuredResults.Events)
                    {
                        <div class="chat-business-card event-card" @onclick="() => NavigateTo(evt.NavigationUrl)">
                            <div class="card-header">
                                <div class="card-icon event">📅</div>
                                <div class="card-title-section">
                                    <h4 class="card-name">@evt.Title</h4>
                                <span class="card-category">Evento</span>
                            </div>
                            @if (evt.IsUpcoming)
                            {
                                <span class="event-badge upcoming">Próximo</span>
                            }
                        </div>
                        
                        <div class="event-details">
                            <div class="event-date">
                                <span class="date-icon">🗓️</span>
                                @evt.EventDateFormatted
                            </div>
                            @if (!string.IsNullOrEmpty(evt.Venue))
                            {
                                <div class="event-venue">
                                    <span class="venue-icon">🏛️</span>
                                    @evt.Venue
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(evt.TicketPrice))
                            {
                                <div class="event-price">
                                    <span class="price-icon">🎟️</span>
                                    @evt.TicketPrice
                                </div>
                            }
                        </div>
                        
                        <div class="card-actions">
                            @foreach (var action in evt.Actions.Take(2))
                            {
                                <button class="card-btn @(action.IsPrimary ? "primary" : "secondary")" 
                                        @onclick="() => HandleAction(action)" 
                                        @onclick:stopPropagation="true">
                                    <span class="btn-icon material-icons-outlined">@action.Icon</span> 
                                    @action.Label
                                </button>
                            }
                        </div>
                    </div>
                }
                
                @foreach (var proc in Message.StructuredResults.Procedures)
                {
                    <div class="chat-business-card procedure-card @(IsProcedureExpanded(proc.Id) ? "expanded" : "")">
                        <div class="card-header" @onclick="() => NavigateTo(proc.NavigationUrl)">
                            <div class="card-icon procedure">📋</div>
                            <div class="card-title-section">
                                <h4 class="card-name">@proc.Title</h4>
                                <span class="card-category">Trámite</span>
                            </div>
                            @if (proc.IsOnlineAvailable)
                            {
                                <span class="online-badge">🌐 En línea</span>
                            }
                        </div>
                        
                        @* Summary row: Time, Cost at a glance *@
                        <div class="procedure-summary">
                            @if (!string.IsNullOrEmpty(proc.ProcessingTime))
                            {
                                <span class="summary-item">⏱️ @proc.ProcessingTime</span>
                            }
                            @if (!string.IsNullOrEmpty(proc.Cost))
                            {
                                <span class="summary-item cost">💰 @proc.Cost</span>
                            }
                        </div>
                        
                        @* Location & Hours - Always visible *@
                        <div class="procedure-location-info">
                            @if (!string.IsNullOrEmpty(proc.WhereToGo) || !string.IsNullOrEmpty(proc.Address))
                            {
                                <div class="location-row">
                                    <span class="material-icons-outlined">place</span>
                                    <span>@(proc.WhereToGo ?? proc.Address)</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(proc.WorkingHours))
                            {
                                <div class="location-row">
                                    <span class="material-icons-outlined">schedule</span>
                                    <span>@proc.WorkingHours</span>
                                </div>
                            }
                        </div>
                        
                        @* Expandable requirements section *@
                        @{
                            var requirementCount = proc.DocumentCount;
                            var hasRequirements = proc.Documents?.Any() == true || proc.Requirements?.Any() == true;
                            var hasSteps = proc.Steps?.Any() == true;
                        }
                        
                        @if (hasRequirements || hasSteps)
                        {
                            <button class="expand-toggle" 
                                    @onclick="() => ToggleProcedureExpand(proc.Id)" 
                                    @onclick:stopPropagation="true">
                                <span class="material-icons-outlined">@(IsProcedureExpanded(proc.Id) ? "expand_less" : "expand_more")</span>
                                @if (hasRequirements)
                                {
                                    <span>Ver requisitos (@requirementCount documentos)</span>
                                }
                                else if (hasSteps)
                                {
                                    <span>Ver pasos (@proc.StepCount)</span>
                                }
                            </button>
                            
                            @if (IsProcedureExpanded(proc.Id))
                            {
                                <div class="procedure-expanded-content">
                                    @* Requirements checklist *@
                                    @if (hasRequirements)
                                    {
                                        <div class="requirements-section">
                                            <h5 class="section-title">📄 Requisitos</h5>
                                            <ul class="requirements-checklist">
                                                @if (proc.Documents?.Any() == true)
                                                {
                                                    @foreach (var doc in proc.Documents)
                                                    {
                                                        <li class="requirement-item @(IsRequirementChecked(proc.Id, doc.Name) ? "checked" : "")"
                                                            @onclick="() => ToggleRequirement(proc.Id, doc.Name)"
                                                            @onclick:stopPropagation="true">
                                                            <span class="checkbox">@(IsRequirementChecked(proc.Id, doc.Name) ? "☑" : "☐")</span>
                                                            <div class="requirement-content">
                                                                <span class="requirement-name">@doc.Name</span>
                                                                @if (!string.IsNullOrEmpty(doc.ValidityPeriod))
                                                                {
                                                                    <span class="requirement-note">(@doc.ValidityPeriod)</span>
                                                                }
                                                                @if (!doc.IsRequired)
                                                                {
                                                                    <span class="optional-tag">Opcional</span>
                                                                }
                                                            </div>
                                                        </li>
                                                    }
                                                }
                                                else if (proc.Requirements?.Any() == true)
                                                {
                                                    @foreach (var req in proc.Requirements)
                                                    {
                                                        <li class="requirement-item @(IsRequirementChecked(proc.Id, req) ? "checked" : "")"
                                                            @onclick="() => ToggleRequirement(proc.Id, req)"
                                                            @onclick:stopPropagation="true">
                                                            <span class="checkbox">@(IsRequirementChecked(proc.Id, req) ? "☑" : "☐")</span>
                                                            <span class="requirement-name">@req</span>
                                                        </li>
                                                    }
                                                }
                                            </ul>
                                        </div>
                                    }
                                    
                                    @* Steps section *@
                                    @if (hasSteps)
                                    {
                                        <div class="steps-section">
                                            <h5 class="section-title">📝 Pasos a seguir</h5>
                                            <ol class="steps-list">
                                                @foreach (var step in proc.Steps!)
                                                {
                                                    <li class="step-item">
                                                        <div class="step-header">
                                                            <span class="step-number">@step.StepNumber</span>
                                                            <span class="step-title">@step.Title</span>
                                                            @if (step.IsOnline)
                                                            {
                                                                <span class="online-tag">🌐 En línea</span>
                                                            }
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(step.Description))
                                                        {
                                                            <p class="step-description">@step.Description</p>
                                                        }
                                                        @if (!string.IsNullOrEmpty(step.EstimatedTime))
                                                        {
                                                            <span class="step-time">⏱️ @step.EstimatedTime</span>
                                                        }
                                                    </li>
                                                }
                                            </ol>
                                        </div>
                                    }
                                </div>
                            }
                        }
                        
                        @* Action buttons *@
                        <div class="card-actions procedure-actions">
                            @if (!string.IsNullOrEmpty(proc.OnlineUrl))
                            {
                                <button class="card-btn primary"
                                        @onclick="() => NavigateExternal(proc.OnlineUrl!)"
                                        @onclick:stopPropagation="true">
                                    <span class="btn-icon material-icons-outlined">event_available</span>
                                    Cita en línea
                                </button>
                            }
                            @if (!string.IsNullOrEmpty(proc.Phone))
                            {
                                <button class="card-btn secondary"
                                        @onclick="() => NavigateToPhone(proc.Phone!)"
                                        @onclick:stopPropagation="true">
                                    <span class="btn-icon material-icons-outlined">phone</span>
                                    Llamar
                                </button>
                            }
                            @if (proc.Latitude.HasValue && proc.Longitude.HasValue)
                            {
                                <button class="card-btn secondary"
                                        @onclick="() => NavigateToMap(proc.Latitude!.Value, proc.Longitude!.Value)"
                                        @onclick:stopPropagation="true">
                                    <span class="btn-icon material-icons-outlined">map</span>
                                    Mapa
                                </button>
                            }
                        </div>
                    </div>
                }
                
                @foreach (var svc in Message.StructuredResults.Services)
                {
                    <div class="chat-business-card service-card" @onclick="() => NavigateTo(svc.NavigationUrl)">
                        <div class="card-header">
                            <div class="card-icon service">🔧</div>
                            <div class="card-title-section">
                                <h4 class="card-name">@svc.Title</h4>
                                @if (!string.IsNullOrEmpty(svc.Category))
                                {
                                    <span class="card-category">@svc.Category</span>
                                }
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(svc.Description))
                        {
                            <p class="card-description">@TruncateText(svc.Description, 100)</p>
                        }
                        
                        <div class="service-details">
                            <div class="service-price">@svc.PriceFormatted</div>
                            @if (!string.IsNullOrEmpty(svc.ProfileName))
                            {
                                <div class="service-provider">Por: @svc.ProfileName</div>
                            }
                        </div>
                        
                        <div class="card-actions">
                            @foreach (var action in svc.Actions.Take(2))
                            {
                                <button class="card-btn @(action.IsPrimary ? "primary" : "secondary")" 
                                        @onclick="() => HandleAction(action)" 
                                        @onclick:stopPropagation="true">
                                    <span class="btn-icon material-icons-outlined">@action.Icon</span> 
                                    @action.Label
                                </button>
                            }
                        </div>
                    </div>
                }
                </div>
                
                <button class="carousel-nav carousel-next" @onclick="() => ScrollCarousel(1)" @onclick:stopPropagation="true">
                    <span>›</span>
                </button>
            </div>
            
            @if (Message.StructuredResults.TotalCount > 5)
            {
                <div class="chat-bubble chat-footer">
                    Mostrando los primeros resultados. <a href="#" @onclick="OnShowMore" @onclick:preventDefault>Ver más...</a>
                </div>
            }
            
            @* Phase 6: Map View Toggle for results with location data *@
            @if (HasLocationResults())
            {
                <div class="view-toggle">
                    <button class="view-toggle-btn @(!_showMapView ? "active" : "")" 
                            @onclick="() => _showMapView = false" 
                            @onclick:stopPropagation="true"
                            title="Ver como lista">
                        <MudIcon Icon="@Icons.Material.Filled.ViewList" Size="Size.Small" />
                        <span class="toggle-label">Lista</span>
                    </button>
                    <button class="view-toggle-btn @(_showMapView ? "active" : "")" 
                            @onclick="() => _showMapView = true" 
                            @onclick:stopPropagation="true"
                            title="Ver en mapa">
                        <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" />
                        <span class="toggle-label">Mapa</span>
                    </button>
                </div>
                
                @if (_showMapView)
                {
                    <SearchResultsMap Results="Message.StructuredResults" Height="280" />
                }
            }
            
            @* Phase 4: Smart Follow-up Suggestions *@
            @if (Message.StructuredResults.HasSuggestions)
            {
                <div class="suggestion-chips">
                    @foreach (var suggestion in Message.StructuredResults.SuggestedActions)
                    {
                        <button class="suggestion-chip @GetSuggestionChipClass(suggestion.Type)"
                                @onclick="() => OnSuggestionClick.InvokeAsync(suggestion.Query)"
                                @onclick:stopPropagation="true">
                            @suggestion.Label
                        </button>
                    }
                </div>
            }
        }
        else
        {
            @* Fallback to regex-based parsing for legacy responses *@
            @if (!IsUser && HasBusinessResults())
            {
                @* Render intro text *@
                @if (!string.IsNullOrEmpty(GetIntroText()))
                {
                    <div class="chat-bubble chat-intro">@((MarkupString)RenderMarkdown(GetIntroText()))</div>
                }
                
                @* Render results as cards *@
                <div class="chat-results-grid">
                    @foreach (var result in ExtractBusinessResults())
                    {
                        <div class="chat-business-card" @onclick="() => NavigateToProfile(result.Url)">
                            <div class="card-header">
                                <div class="card-icon">@GetCategoryIcon(result.Name)</div>
                                <div class="card-title-section">
                                    <h4 class="card-name">@result.Name</h4>
                                    @if (!string.IsNullOrEmpty(result.Category))
                                    {
                                        <span class="card-category">@result.Category</span>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(result.Description))
                            {
                                <p class="card-description">@TruncateText(result.Description, 120)</p>
                            }
                            <div class="card-actions">
                                <button class="card-btn primary" @onclick="() => NavigateToProfile(result.Url)" @onclick:stopPropagation="true">
                                    <span class="btn-icon">👁️</span> Ver Perfil
                                </button>
                                <button class="card-btn secondary" @onclick="() => OnSaveResult(result)" @onclick:stopPropagation="true">
                                    <span class="btn-icon">📍</span> Guardar
                                </button>
                                <button class="card-btn secondary" @onclick="() => OnShareResult(result)" @onclick:stopPropagation="true">
                                    <span class="btn-icon">📤</span> Compartir
                                </button>
                            </div>
                        </div>
                    }
                </div>
                
                @* Render any footer text *@
                @if (!string.IsNullOrEmpty(GetFooterText()))
                {
                    <div class="chat-bubble chat-footer">@((MarkupString)RenderMarkdown(GetFooterText()))</div>
                }
            }
            else
            {
                <div class="chat-bubble" style="white-space: pre-line;">@((MarkupString)RenderMarkdown(Message.Text))</div>
            }
            
            @* Phase 0.6: Render QuickActionItems with DefaultQuery support *@
            @if (Message.QuickActionItems != null && Message.QuickActionItems.Any())
            {
                <div class="chat-quick-actions">
                    @foreach (var qa in Message.QuickActionItems)
                    {
                        <button class="quick-action-btn" @onclick="() => OnQuickAction.InvokeAsync(qa.DefaultQuery ?? qa.Label)">@qa.Label</button>
                    }
                </div>
            }
            @* Legacy: Simple string-based quick actions *@
            else if (Message.QuickActions != null && Message.QuickActions.Any())
            {
                <div class="chat-quick-actions">
                    @foreach (var action in Message.QuickActions)
                    {
                        <button class="quick-action-btn" @onclick="() => OnQuickAction.InvokeAsync(action)">@action</button>
                    }
                </div>
            }
        }
        <div class="chat-message-time">@Message.Time.ToString("t")</div>
    </div>
</div>

@* Phase 7: Share Modal *@
@if (_showShareModal && _shareBusinessTarget != null)
{
    <div class="share-modal-backdrop" @onclick="CloseShareModal">
        <div class="share-modal" @onclick:stopPropagation="true">
            <div class="share-modal-header">
                <h4>Compartir</h4>
                <button class="share-modal-close" @onclick="CloseShareModal">×</button>
            </div>
            <div class="share-modal-content">
                <div class="share-business-preview">
                    <strong>@_shareBusinessTarget.Title</strong>
                    @if (!string.IsNullOrEmpty(_shareBusinessTarget.Category))
                    {
                        <span class="share-category">@_shareBusinessTarget.Category</span>
                    }
                </div>
                <div class="share-options">
                    <button class="share-option-btn" @onclick="() => CopyLinkToClipboard()">
                        <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" Class="share-btn-icon" />
                        <span>Copiar enlace</span>
                    </button>
                    <button class="share-option-btn whatsapp" @onclick="() => ShareViaWhatsApp()">
                        <span class="share-icon">💬</span>
                        <span>WhatsApp</span>
                    </button>
                    <button class="share-option-btn" @onclick="() => ShareNative()">
                        <MudIcon Icon="@Icons.Material.Filled.Share" Size="Size.Small" Class="share-btn-icon" />
                        <span>Más opciones</span>
                    </button>
                </div>
                @if (_showCopiedMessage)
                {
                    <div class="copied-message">✓ Enlace copiado</div>
                }
            </div>
        </div>
    </div>
}

@code {
    /// <summary>
    /// The chat message to display
    /// </summary>
    [Parameter, EditorRequired]
    public Sivar.Os.Client.Pages.ChatMessage Message { get; set; } = null!;

    /// <summary>
    /// Whether this is a user message
    /// </summary>
    private bool IsUser => Message.Sender == "user";

    /// <summary>
    /// Reference to the carousel element for scrolling
    /// </summary>
    private ElementReference _carouselRef;
    
    /// <summary>
    /// Phase 6: Toggle between list view and map view for results with location data
    /// </summary>
    private bool _showMapView = false;
    
    /// <summary>
    /// Phase 6: Check if any search results have location data
    /// </summary>
    private bool HasLocationResults() => 
        Message.StructuredResults?.Businesses?.Any(b => b.Latitude.HasValue && b.Longitude.HasValue) == true;
    
    /// <summary>
    /// Phase 7: Set of saved business IDs (local to this session)
    /// </summary>
    private static HashSet<Guid> _savedBusinessIds = new();
    
    /// <summary>
    /// Phase 7: Show share modal
    /// </summary>
    private bool _showShareModal = false;
    
    /// <summary>
    /// Phase 7: Target business for sharing
    /// </summary>
    private BusinessSearchResultDto? _shareBusinessTarget = null;
    
    /// <summary>
    /// Phase 7: Show copied message
    /// </summary>
    private bool _showCopiedMessage = false;
    
    /// <summary>
    /// Tracks which procedure cards are expanded (by Id)
    /// </summary>
    private HashSet<Guid> _expandedProcedures = new();
    
    /// <summary>
    /// Tracks checked requirements for procedures (by procedureId:documentName)
    /// </summary>
    private HashSet<string> _checkedRequirements = new();
    
    /// <summary>
    /// Toggle procedure card expansion
    /// </summary>
    private void ToggleProcedureExpand(Guid procedureId)
    {
        if (_expandedProcedures.Contains(procedureId))
            _expandedProcedures.Remove(procedureId);
        else
            _expandedProcedures.Add(procedureId);
    }
    
    /// <summary>
    /// Check if a procedure card is expanded
    /// </summary>
    private bool IsProcedureExpanded(Guid procedureId) => _expandedProcedures.Contains(procedureId);
    
    /// <summary>
    /// Toggle a requirement checkbox
    /// </summary>
    private void ToggleRequirement(Guid procedureId, string requirement)
    {
        var key = $"{procedureId}:{requirement}";
        if (_checkedRequirements.Contains(key))
            _checkedRequirements.Remove(key);
        else
            _checkedRequirements.Add(key);
    }
    
    /// <summary>
    /// Check if a requirement is checked
    /// </summary>
