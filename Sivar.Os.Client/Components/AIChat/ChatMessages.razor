@using Sivar.Os.Client.Pages
@using Sivar.Os.Client.Components.Shared
@inject IJSRuntime JS

@* ChatMessages component *@

<div class="chat-messages" id="chatMessages">
    @if (!Messages.Any())
    {
        <EmptyState Icon="💬" Text="No messages yet" SubText="Start a conversation with the AI" Size="normal" />
    }
    else
    {
        @foreach (var message in Messages)
        {
            <ChatMessage 
                Message="@message"
                OnQuickAction="@OnQuickAction"
                OnResultView="@OnResultView"
                OnResultSave="@OnResultSave"
                OnResultFollow="@OnResultFollow"
                OnSuggestionClick="@OnSuggestionClick" />
        }
    }

    @if (IsTyping)
    {
        <div class="chat-message ai">
            <div class="chat-message-avatar">
                <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                </MudAvatar>
            </div>
            <div class="chat-message-content">
                <MudPaper Class="chat-bubble typing-bubble" Elevation="0">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    <MudText Typo="Typo.caption" Class="ml-2" Style="color: var(--mud-palette-text-secondary);">Thinking...</MudText>
                </MudPaper>
            </div>
        </div>
    }
</div>

@code {
    /// <summary>
    /// List of chat messages
    /// </summary>
    [Parameter]
    public List<Sivar.Os.Client.Pages.ChatMessage> Messages { get; set; } = new();

    /// <summary>
    /// Whether the AI is typing
    /// </summary>
    [Parameter]
    public bool IsTyping { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await JS.InvokeVoidAsync("console.log", $"[ChatMessages] IsTyping={IsTyping}, Messages={Messages?.Count ?? 0}");
    }

    /// <summary>
    /// Callback when quick action is clicked
    /// </summary>
    [Parameter]
    public EventCallback<string> OnQuickAction { get; set; }

    /// <summary>
    /// Callback when result view is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnResultView { get; set; }

    /// <summary>
    /// Callback when result save is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnResultSave { get; set; }

    /// <summary>
    /// Callback when result follow is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnResultFollow { get; set; }
    
    /// <summary>
    /// Callback when a suggestion chip is clicked (sends pre-filled query)
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSuggestionClick { get; set; }
}
