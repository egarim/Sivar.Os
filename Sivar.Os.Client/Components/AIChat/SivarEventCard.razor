@* SivarEventCard - Card component for displaying event results *@
@using Sivar.Os.Shared.DTOs

<div class="sivar-event-card @(Event.IsUpcoming ? "upcoming" : "")" @onclick="HandleClick">
    <div class="card-header">
        <div class="card-icon event">📅</div>
        <div class="card-title-section">
            <h4 class="card-name">@Event.Title</h4>
            <span class="card-category">Evento</span>
        </div>
        @if (Event.IsUpcoming)
        {
            <span class="event-badge upcoming">Próximo</span>
        }
    </div>
    
    @* Event Details *@
    <div class="event-details">
        <div class="event-date">
            <span class="date-icon">🗓️</span>
            <span>@Event.EventDateFormatted</span>
        </div>
        @if (!string.IsNullOrEmpty(Event.Venue))
        {
            <div class="event-venue">
                <span class="venue-icon">🏛️</span>
                <span>@Event.Venue</span>
            </div>
        }
        @if (!string.IsNullOrEmpty(Event.TicketPrice))
        {
            <div class="event-price">
                <span class="price-icon">🎟️</span>
                <span>@Event.TicketPrice</span>
            </div>
        }
        @if (Event.DistanceKm.HasValue)
        {
            <div class="event-distance">
                <span class="distance-icon">📍</span>
                <span>@Event.DistanceKm.Value.ToString("F1") km</span>
            </div>
        }
    </div>
    
    @* Description if available *@
    @if (!string.IsNullOrEmpty(Event.Description))
    {
        <p class="card-description">@TruncateText(Event.Description, 80)</p>
    }
    
    @* Action Buttons *@
    @if (Event.Actions?.Any() == true)
    {
        <div class="card-actions">
            @foreach (var action in Event.Actions.Take(2))
            {
                <button class="card-btn @(action.IsPrimary ? "primary" : "secondary")" 
                        @onclick="() => HandleAction(action)" 
                        @onclick:stopPropagation="true">
                    @action.Label
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public EventSearchResultDto Event { get; set; } = null!;
    
    [Parameter]
    public EventCallback<EventSearchResultDto> OnNavigate { get; set; }
    
    [Parameter]
    public EventCallback<CallToActionDto> OnAction { get; set; }
    
    private async Task HandleClick()
    {
        await OnNavigate.InvokeAsync(Event);
    }
    
    private async Task HandleAction(CallToActionDto action)
    {
        await OnAction.InvokeAsync(action);
    }
    
    private string TruncateText(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        
        return text.Substring(0, maxLength).TrimEnd() + "...";
    }
}
