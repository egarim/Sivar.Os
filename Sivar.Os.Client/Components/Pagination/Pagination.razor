@using Microsoft.Extensions.Logging
@inject ILogger<Pagination> Logger

@* Pagination component *@

<div class="pagination">
    <button class="pagination-btn" @onclick="HandlePrevious" disabled="@(CurrentPage <= 1)">Previous</button>
    <div class="pagination-info">
        <div class="page-indicator">Page <span id="current-page">@CurrentPage</span> of @PageCount</div>
        <div class="posts-info">@TotalItems total @ItemName</div>
    </div>
    <button class="pagination-btn" @onclick="HandleNext" disabled="@(CurrentPage >= PageCount || PageCount <= 1)">Next</button>
</div>

@code {
    /// <summary>
    /// Current page number
    /// </summary>
    [Parameter]
    public int CurrentPage { get; set; } = 1;

    /// <summary>
    /// Total number of pages
    /// </summary>
    [Parameter]
    public int PageCount { get; set; } = 1;

    /// <summary>
    /// Total number of items
    /// </summary>
    [Parameter]
    public int TotalItems { get; set; }

    /// <summary>
    /// Name of items being paginated (e.g. "posts", "items")
    /// </summary>
    [Parameter]
    public string ItemName { get; set; } = "items";

    /// <summary>
    /// Callback when next button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnNext { get; set; }

    /// <summary>
    /// Callback when previous button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnPrevious { get; set; }

    protected override void OnParametersSet()
    {
        Logger.LogDebug("[Pagination] Parameters set - CurrentPage: {CurrentPage}, PageCount: {PageCount}, TotalItems: {TotalItems}", 
            CurrentPage, PageCount, TotalItems);
    }

    private async Task HandlePrevious()
    {
        Logger.LogInformation("[Pagination] Previous button clicked - CurrentPage: {CurrentPage}", CurrentPage);
        await OnPrevious.InvokeAsync();
    }

    private async Task HandleNext()
    {
        Logger.LogInformation("[Pagination] Next button clicked - CurrentPage: {CurrentPage}", CurrentPage);
        await OnNext.InvokeAsync();
    }
}

