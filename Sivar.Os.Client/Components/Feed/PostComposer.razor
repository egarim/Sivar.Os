    }

    .file-size {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 600;
    }

    @@keyframes pulse-gif {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

