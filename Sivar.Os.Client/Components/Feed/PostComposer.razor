    {
        Logger.LogInformation("[PostComposer] Component initialized - ProfileTypeTitle: {ProfileTypeTitle}, SelectedType: {SelectedType}", 
            ProfileTypeTitle, SelectedType);
        
        SelectedLanguage = PostLanguage;
        SelectedVisibility = PostVisibility;
        TagsInput = string.Join(", ", PostTags);
        LocationCity = PostLocation?.City ?? string.Empty;
        BusinessMetadata = PostBusinessMetadata;
    }

    protected override void OnParametersSet()
    {
        Logger.LogDebug("[PostComposer] Parameters set - PostText Length: {Length}, SelectedType: {Type}", 
            PostText?.Length ?? 0, SelectedType);
        
        // Keep local state in sync when parent updates
        SelectedLanguage = PostLanguage;
        SelectedVisibility = PostVisibility;
        LocationCity = PostLocation?.City ?? string.Empty;
        BusinessMetadata = PostBusinessMetadata;
    }

