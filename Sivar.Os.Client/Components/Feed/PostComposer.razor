    #region BusinessLocation Parameters

    /// <summary>
    /// Business location name/title
    /// </summary>
    private string BusinessLocationName { get; set; } = string.Empty;
    
    /// <summary>
    /// Business location description
    /// </summary>
    private string BusinessLocationDescription { get; set; } = string.Empty;
    
    /// <summary>
    /// Selected business location type
    /// </summary>
    private BusinessLocationType SelectedBusinessLocationType { get; set; } = BusinessLocationType.CustomerBranch;
    
    /// <summary>
    /// Location data for business location post
    /// </summary>
    private LocationDto BusinessPostLocation { get; set; } = new();
    
    /// <summary>
    /// Contact phone for the business location
    /// </summary>
    private string BusinessContactPhone { get; set; } = string.Empty;
    
    /// <summary>
    /// Contact email for the business location
    /// </summary>
    private string BusinessContactEmail { get; set; } = string.Empty;
    
    /// <summary>
    /// Whether the location accepts walk-ins
    /// </summary>
    private bool BusinessAcceptsWalkIns { get; set; } = true;
    
    /// <summary>
    /// Whether the location requires appointments
    /// </summary>
    private bool BusinessRequiresAppointment { get; set; } = false;
    
    /// <summary>
    /// Working hours for the business location
    /// </summary>
    private BusinessHours BusinessWorkingHours { get; set; } = new();
    
    /// <summary>
    /// Special instructions for the business location
    /// </summary>
    private string BusinessSpecialInstructions { get; set; } = string.Empty;

    /// <summary>
    /// Build BusinessLocationMetadata from form fields
    /// </summary>
    private BusinessLocationMetadata BuildBusinessLocationMetadata()
    {
        return new BusinessLocationMetadata
        {
            LocationType = SelectedBusinessLocationType,
            Description = !string.IsNullOrWhiteSpace(BusinessLocationDescription) ? BusinessLocationDescription : null,
            ContactPhone = !string.IsNullOrWhiteSpace(BusinessContactPhone) ? BusinessContactPhone : null,
            ContactEmail = !string.IsNullOrWhiteSpace(BusinessContactEmail) ? BusinessContactEmail : null,
            AcceptsWalkIns = BusinessAcceptsWalkIns,
            RequiresAppointment = BusinessRequiresAppointment,
            WorkingHours = BusinessWorkingHours,
            SpecialInstructions = !string.IsNullOrWhiteSpace(BusinessSpecialInstructions) ? BusinessSpecialInstructions : null
        };
    }
    
    /// <summary>
    /// Sync BusinessLocation form data to parent bindings
    /// This is called when any BusinessLocation field changes
    /// </summary>
    private async Task SyncBusinessLocationToParent()
    {
        if (SelectedType != "businesslocation")
            return;
            
        // Set the location name as the post content
        PostText = BusinessLocationName;
        await PostTextChanged.InvokeAsync(PostText);
        
        // Set the location data
        PostLocation = BusinessPostLocation;
        await PostLocationChanged.InvokeAsync(PostLocation);
        
        // Serialize metadata to JSON
        var metadata = BuildBusinessLocationMetadata();
        var metadataJson = JsonSerializer.Serialize(metadata, new JsonSerializerOptions 
        { 
            PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
            WriteIndented = false 
        });
        
        PostBusinessMetadata = metadataJson;
        BusinessMetadata = metadataJson;
        await PostBusinessMetadataChanged.InvokeAsync(metadataJson);
        
        Logger.LogDebug("[PostComposer] Synced BusinessLocation data to parent");
    }
    
    /// <summary>
    /// Clear business location form fields
    /// </summary>
    private void ClearBusinessLocationFields()
    {
        BusinessLocationName = string.Empty;
        BusinessLocationDescription = string.Empty;
        SelectedBusinessLocationType = BusinessLocationType.CustomerBranch;
        BusinessPostLocation = new LocationDto();
        BusinessContactPhone = string.Empty;
        BusinessContactEmail = string.Empty;
        BusinessAcceptsWalkIns = true;
        BusinessRequiresAppointment = false;
        BusinessWorkingHours = new BusinessHours();
        BusinessSpecialInstructions = string.Empty;
    }
    
    // BusinessLocation field change handlers
    
    private async Task OnBusinessLocationNameChanged(string value)
    {
        BusinessLocationName = value;
        await SyncBusinessLocationToParent();
        StateHasChanged(); // Force UI update to re-evaluate IsPublishDisabled
    }
    
