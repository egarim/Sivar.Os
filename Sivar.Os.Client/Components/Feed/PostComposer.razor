@using MudBlazor
@using System.IO
@using System.Text.Json
@using Sivar.Os.Shared
@using Sivar.Os.Shared.Entities
@using Sivar.Os.Shared.Enums
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Services
@using Sivar.Os.Client
@using Sivar.Os.Client.Shared
@using Sivar.Os.Client.Components.Feed
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components.Forms
@inject ILogger<PostComposer> Logger
@inject IStringLocalizer<PostComposer> Localizer
@inject IJSRuntime JS
@inject ISivarClient SivarClient
@inject IImageCompressionService ImageCompression
@inject IDialogService DialogService

@* PostComposer component for creating new posts *@

<div class="post-composer">
    <div class="composer-title">
        <h3>@Localizer["CreatePostTitle"]</h3>
        <span class="composer-profile-indicator">
            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
            @Localizer["PostingAs", ProfileTypeTitle]
        </span>
    </div>
    
    @if (FilteredPostTypeOptions.Count > 1)
    {
        <div class="post-type-selector">
            @foreach (var option in FilteredPostTypeOptions)
            {
                <button type="button" 
                        class="post-type-option @(option.Id == SelectedType ? "active" : null)" 
                        @onclick="() => SelectedTypeChanged.InvokeAsync(option.Id)">
                    <MudIcon Icon="@option.Icon" Size="Size.Small" />
                    @option.Label
                    <span class="tooltip">@option.Tooltip</span>
                </button>
            }
        </div>
    }
    
    @* Show either regular textarea or BlogEditor based on post type *@
    @if (SelectedType == "blog")
    {
        <BlogEditor @bind-Title="BlogTitle"
                    @bind-Subtitle="BlogSubtitle"
                    @bind-Content="BlogContent"
                    @bind-CoverImageUrl="BlogCoverImageUrl"
                    @bind-CoverImageFileId="BlogCoverImageFileId"
                    @bind-IsDraft="BlogIsDraft"
                    OnCoverImageUploaded="OnBlogCoverImageUploaded" />
    }
    else if (SelectedType == "businesslocation")
    {
        @* BusinessLocation Form *@
        <div class="businesslocation-form">
            <div class="form-header">
                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Medium" />
                <span>@Localizer["BusinessLocationFormTitle"]</span>
            </div>
            
            @* Location Name/Title *@
            <div class="form-group">
                <MudTextField Value="@BusinessLocationName"
                              ValueChanged="@((string val) => OnBusinessLocationNameChanged(val))"
                              Label="@Localizer["LocationNameLabel"]"
                              Placeholder="@Localizer["LocationNamePlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              FullWidth="true" />
            </div>
            
            @* Location Description *@
            <div class="form-group">
                <MudTextField Value="@BusinessLocationDescription"
                              ValueChanged="@((string val) => OnBusinessLocationDescriptionChanged(val))"
                              Label="@Localizer["LocationDescriptionLabel"]"
                              Placeholder="@Localizer["LocationDescriptionPlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3"
                              FullWidth="true" />
            </div>
            
            @* Location Type *@
            <div class="form-group">
                <MudSelect T="BusinessLocationType" 
                           Value="@SelectedBusinessLocationType"
                           ValueChanged="@((BusinessLocationType val) => OnBusinessLocationTypeChanged(val))"
                           Label="@Localizer["LocationTypeLabel"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           FullWidth="true">
                    <MudSelectItem T="BusinessLocationType" Value="BusinessLocationType.MainOffice">
                        <div class="select-item">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                            @Localizer["MainOffice"]
                        </div>
                    </MudSelectItem>
                    <MudSelectItem T="BusinessLocationType" Value="BusinessLocationType.CustomerBranch">
                        <div class="select-item">
                            <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Small" />
                            @Localizer["CustomerBranch"]
                        </div>
                    </MudSelectItem>
                    <MudSelectItem T="BusinessLocationType" Value="BusinessLocationType.AdministrativeOffice">
                        <div class="select-item">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" />
                            @Localizer["AdministrativeOffice"]
                        </div>
                    </MudSelectItem>
                    <MudSelectItem T="BusinessLocationType" Value="BusinessLocationType.RetailStore">
                        <div class="select-item">
                            <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Small" />
                            @Localizer["RetailStore"]
                        </div>
                    </MudSelectItem>
                    <MudSelectItem T="BusinessLocationType" Value="BusinessLocationType.Warehouse">
                        <div class="select-item">
                            <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" />
                            @Localizer["Warehouse"]
                        </div>
                    </MudSelectItem>
                    <MudSelectItem T="BusinessLocationType" Value="BusinessLocationType.ServiceCenter">
                        <div class="select-item">
                            <MudIcon Icon="@Icons.Material.Filled.BuildCircle" Size="Size.Small" />
                            @Localizer["ServiceCenter"]
                        </div>
                    </MudSelectItem>
                </MudSelect>
            </div>
            
            @* Location Picker Map *@
            <div class="form-group">
                <LocationPicker Location="@BusinessPostLocation"
                                LocationChanged="@OnBusinessPostLocationChanged"
                                MapHeight="300"
                                DefaultZoom="13" />
            </div>
            
            @* Contact Information *@
            <div class="contact-section">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Size="Size.Small" />
                    <span>@Localizer["ContactInformation"]</span>
                </div>
                
                <div class="form-row">
                    <MudTextField Value="@BusinessContactPhone"
                                  ValueChanged="@((string val) => OnBusinessContactPhoneChanged(val))"
                                  Label="@Localizer["ContactPhoneLabel"]"
                                  Placeholder="@Localizer["ContactPhonePlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  InputType="InputType.Telephone"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Phone" />
                    
                    <MudTextField Value="@BusinessContactEmail"
                                  ValueChanged="@((string val) => OnBusinessContactEmailChanged(val))"
                                  Label="@Localizer["ContactEmailLabel"]"
                                  Placeholder="@Localizer["ContactEmailPlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email" />
                </div>
            </div>
            
            @* Service Options *@
            <div class="service-options">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.MiscellaneousServices" Size="Size.Small" />
                    <span>@Localizer["ServiceOptions"]</span>
                </div>
                
                <div class="options-row">
                    <MudCheckBox T="bool" 
                                 Value="@BusinessAcceptsWalkIns"
                                 ValueChanged="@((bool val) => OnBusinessAcceptsWalkInsChanged(val))"
                                 Label="@Localizer["AcceptsWalkIns"]"
                                 Color="Color.Primary" />
                    
                    <MudCheckBox T="bool" 
                                 Value="@BusinessRequiresAppointment"
                                 ValueChanged="@((bool val) => OnBusinessRequiresAppointmentChanged(val))"
                                 Label="@Localizer["RequiresAppointment"]"
                                 Color="Color.Primary" />
                </div>
            </div>
            
            @* Working Hours (Optional - Modal) *@
            <div class="working-hours-section">
                <div class="working-hours-summary">
                    <div class="hours-info">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                        @if (HasWorkingHours())
                        {
                            <span class="hours-text">@GetWorkingHoursSummary()</span>
                        }
                        else
                        {
                            <span class="hours-text text-secondary">@Localizer["NoWorkingHoursSet"]</span>
                        }
                    </div>
                    <div class="hours-actions">
                        @if (HasWorkingHours())
                        {
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="OpenWorkingHoursDialog">
                                @Localizer["EditHours"]
                            </MudButton>
                            <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                           Size="Size.Small"
                                           Color="Color.Warning"
                                           Title="@Localizer["ClearHours"]"
                                           OnClick="ClearWorkingHours" />
                        }
                        else
                        {
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Schedule"
                                       OnClick="OpenWorkingHoursDialog">
                                @Localizer["SetWorkingHours"]
                            </MudButton>
                        }
                    </div>
                </div>
            </div>
            
            @* Special Instructions *@
            <div class="form-group">
                <MudTextField Value="@BusinessSpecialInstructions"
                              ValueChanged="@((string val) => OnBusinessSpecialInstructionsChanged(val))"
                              Label="@Localizer["SpecialInstructionsLabel"]"
                              Placeholder="@Localizer["SpecialInstructionsPlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="2"
                              FullWidth="true" />
            </div>
        </div>
    }
    else if (SelectedType == "procedure")
    {
        @* Procedure Form *@
        <div class="procedure-form">
            <div class="form-header">
                <MudIcon Icon="@Icons.Material.Filled.Checklist" Size="Size.Medium" />
                <span>@Localizer["ProcedureFormTitle"]</span>
            </div>
            
            @* Procedure Title *@
            <div class="form-group">
                <MudTextField Value="@ProcedureTitle"
                              ValueChanged="@((string val) => OnProcedureTitleChanged(val))"
                              Label="@Localizer["ProcedureTitleLabel"]"
                              Placeholder="@Localizer["ProcedureTitlePlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              FullWidth="true" />
            </div>
            
            @* Procedure Description *@
            <div class="form-group">
                <MudTextField Value="@ProcedureDescription"
                              ValueChanged="@((string val) => OnProcedureDescriptionChanged(val))"
                              Label="@Localizer["ProcedureDescriptionLabel"]"
                              Placeholder="@Localizer["ProcedureDescriptionPlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="2"
                              FullWidth="true" />
            </div>
            
            @* Time and Cost Row *@
            <div class="form-row">
                <div class="form-group flex-1">
                    <MudTextField Value="@ProcedureProcessingTime"
                                  ValueChanged="@((string val) => OnProcedureProcessingTimeChanged(val))"
                                  Label="@Localizer["ProcessingTimeLabel"]"
                                  Placeholder="@Localizer["ProcessingTimePlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Schedule"
                                  FullWidth="true" />
                </div>
                <div class="form-group flex-1">
                    <MudTextField Value="@ProcedureCost"
                                  ValueChanged="@((string val) => OnProcedureCostChanged(val))"
                                  Label="@Localizer["CostLabel"]"
                                  Placeholder="@Localizer["CostPlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                  FullWidth="true" />
                </div>
            </div>
            
            @* Where To Go and Online URL *@
            <div class="form-row">
                <div class="form-group flex-1">
                    <MudTextField Value="@ProcedureWhereToGo"
                                  ValueChanged="@((string val) => OnProcedureWhereToGoChanged(val))"
                                  Label="@Localizer["WhereToGoLabel"]"
                                  Placeholder="@Localizer["WhereToGoPlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.LocationOn"
                                  FullWidth="true" />
                </div>
                <div class="form-group flex-1">
                    <MudTextField Value="@ProcedureOnlineUrl"
                                  ValueChanged="@((string val) => OnProcedureOnlineUrlChanged(val))"
                                  Label="@Localizer["OnlineUrlLabel"]"
                                  Placeholder="@Localizer["OnlineUrlPlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Link"
                                  FullWidth="true" />
                </div>
            </div>
            
            @* Contact Info Row *@
            <div class="form-row">
                <div class="form-group flex-1">
                    <MudTextField Value="@ProcedureContactPhone"
                                  ValueChanged="@((string val) => OnProcedureContactPhoneChanged(val))"
                                  Label="@Localizer["ContactPhoneLabel"]"
                                  Placeholder="@Localizer["ContactPhonePlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Phone"
                                  FullWidth="true" />
                </div>
                <div class="form-group flex-1">
                    <MudTextField Value="@ProcedureContactEmail"
                                  ValueChanged="@((string val) => OnProcedureContactEmailChanged(val))"
                                  Label="@Localizer["ContactEmailLabel"]"
                                  Placeholder="@Localizer["ContactEmailPlaceholder"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  FullWidth="true" />
                </div>
            </div>
            
            @* Appointment Required Checkbox *@
            <div class="form-group checkbox-group">
                <MudCheckBox T="bool" 
                             Value="@ProcedureRequiresAppointment"
                             ValueChanged="@((bool val) => OnProcedureRequiresAppointmentChanged(val))"
                             Label="@Localizer["RequiresAppointmentLabel"]"
                             Color="Color.Primary" />
            </div>
            
            @* Required Documents Section *@
            <div class="procedure-section">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                    <span>@Localizer["RequiredDocumentsLabel"]</span>
                    <MudButton StartIcon="@Icons.Material.Filled.Add" 
                               Size="Size.Small" 
                               Variant="Variant.Text"
                               Color="Color.Primary"
                               OnClick="AddProcedureDocument">
                        @Localizer["AddButton"]
                    </MudButton>
                </div>
                @if (ProcedureDocuments.Any())
                {
                    <div class="documents-list">
                        @foreach (var (doc, index) in ProcedureDocuments.Select((d, i) => (d, i)))
                        {
                            <div class="document-item">
                                <MudTextField Value="@doc.Name"
                                              ValueChanged="@((string val) => OnDocumentNameChanged(index, val))"
                                              Placeholder="@Localizer["DocumentNamePlaceholder"]"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="document-name-field" />
                                <MudCheckBox T="bool" 
                                             Value="@doc.IsRequired"
                                             ValueChanged="@((bool val) => OnDocumentRequiredChanged(index, val))"
                                             Label="@Localizer["RequiredCheckbox"]"
                                             Size="Size.Small"
                                             Class="document-required-checkbox" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Size="Size.Small" 
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveProcedureDocument(index))" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-section">
                        <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" Class="me-2" />
                        <span>@Localizer["NoDocumentsAdded"]</span>
                    </div>
                }
            </div>
            
            @* Steps Section *@
            <div class="procedure-section">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.FormatListNumbered" Size="Size.Small" />
                    <span>@Localizer["StepsLabel"]</span>
                    <MudButton StartIcon="@Icons.Material.Filled.Add" 
                               Size="Size.Small" 
                               Variant="Variant.Text"
                               Color="Color.Primary"
                               OnClick="AddProcedureStep">
                        @Localizer["AddButton"]
                    </MudButton>
                </div>
                @if (ProcedureSteps.Any())
                {
                    <div class="steps-list">
                        @foreach (var (step, index) in ProcedureSteps.Select((s, i) => (s, i)))
                        {
                            <div class="step-item">
                                <div class="step-number">@(index + 1)</div>
                                <MudTextField Value="@step.Title"
                                              ValueChanged="@((string val) => OnStepTitleChanged(index, val))"
                                              Placeholder="@Localizer["StepTitlePlaceholder"]"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="step-title-field" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Size="Size.Small" 
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveProcedureStep(index))" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-section">
                        <MudIcon Icon="@Icons.Material.Outlined.ListAlt" Size="Size.Small" Class="me-2" />
                        <span>@Localizer["NoStepsAdded"]</span>
                    </div>
                }
            </div>
            
            @* Additional Notes *@
            <div class="form-group">
                <MudTextField Value="@ProcedureAdditionalNotes"
                              ValueChanged="@((string val) => OnProcedureAdditionalNotesChanged(val))"
                              Label="@Localizer["AdditionalNotesLabel"]"
                              Placeholder="@Localizer["AdditionalNotesPlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="2"
                              FullWidth="true" />
            </div>
        </div>
    }
    else
    {
        <textarea class="post-input" 
                  placeholder="@Localizer["PostPlaceholder"]" 
                  value="@PostText"
                  @oninput="@((ChangeEventArgs e) => HandlePostTextInputAsync(e))"></textarea>
    }

    @* Advanced Options Section *@
    <div class="composer-advanced-section">
        <details>
            <summary class="advanced-toggle">
                <MudIcon Icon="@Icons.Material.Outlined.Settings" Size="Size.Small" />
                @Localizer["AdvancedOptionsTitle"]
            </summary>
            
            @* Visibility Level *@
            <div class="form-group">
                <label>@Localizer["VisibilityLabel"]</label>
                <select class="form-control" @onchange="HandleVisibilityChange">
                    <option value="">@Localizer["SelectVisibility"]</option>
                    @foreach (VisibilityLevel visibility in Enum.GetValues(typeof(VisibilityLevel)))
                    {
                        <option value="@visibility" selected="@(SelectedVisibility == visibility)">
                            @GetVisibilityLabel(visibility)
                        </option>
                    }
                </select>
                <small class="form-text">@GetVisibilityDescription(SelectedVisibility)</small>
            </div>

            @* Language Selection *@
            <div class="form-group">
                <label>@Localizer["LanguageLabel"]</label>
                <select class="form-control" @bind="SelectedLanguage">
                    <option value="en">English</option>
                    <option value="es">Español (Spanish)</option>
                    <option value="fr">Français (French)</option>
                    <option value="de">Deutsch (German)</option>
                    <option value="pt">Português (Portuguese)</option>
                </select>
            </div>

            @* Tags *@
            <div class="form-group">
                <label>@Localizer["TagsLabel"]</label>
                <input type="text" 
                       class="form-control" 
                       placeholder="@Localizer["TagsPlaceholder"]"
                       @bind="TagsInput"
                       @bind:event="oninput" />
                <small class="form-text">@Localizer["TagsHint"]</small>
            </div>

            @* Location *@
            <div class="form-group">
                <label>@Localizer["LocationLabel"]</label>
                <input type="text" 
                       class="form-control" 
                       placeholder="@Localizer["LocationPlaceholder"]"
                       @bind="LocationCity"
                       @bind:event="oninput" />
                <small class="form-text">@Localizer["LocationHint"]</small>
            </div>

            @* Business Metadata (for business profiles) *@
            @if (IsBusinessProfile)
            {
                <div class="form-group">
                    <label>@Localizer["BusinessMetadataLabel"]</label>
                    <textarea class="form-control" 
                              placeholder="@Localizer["BusinessMetadataPlaceholder"]"
                              @bind="BusinessMetadata"
                              @bind:event="oninput"
                              rows="3"></textarea>
                    <small class="form-text">@Localizer["BusinessMetadataHint"]</small>
                </div>
            }
        </details>
    </div>
    
    <div class="post-actions">
        <div class="post-options">
            <InputFile id="imageUpload" 
                       OnChange="@OnFilesSelected" 
                       accept="image/*" 
                       multiple 
                       style="display: none;" />
            
            <MudIconButton Icon="@Icons.Material.Outlined.Image"
                           Color="Color.Primary"
                           Size="Size.Small"
                           HtmlTag="label"
                           for="imageUpload"
                           title="@Localizer["AddImagesTitle"]">
            </MudIconButton>
            
            @foreach (var option in AttachmentOptions.Where(o => o.Id != "media"))
            {
                <button type="button" 
                        class="post-option @(option.Id == ActiveAttachment ? "active" : null)" 
                        @onclick="() => OnAttachmentToggle.InvokeAsync(option.Id)">
                    <MudIcon Icon="@option.Icon" Size="Size.Small" />
                    @option.Label
                </button>
            }
        </div>
        <button class="post-btn" 
                disabled="@(IsPublishDisabled || IsSubmitting)" 
                @onclick="OnPublish">
            @if (IsSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Class="me-2" Indeterminate="true" />
                <span>@Localizer["PublishingButton"]</span>
            }
            else
            {
                <span>@Localizer["PublishButton"]</span>
            }
        </button>
    </div>

    @* Image Preview Section with Upload Status *@
    @if (SelectedFiles != null && SelectedFiles.Count > 0)
    {
        <div class="image-preview-section">
            <div class="preview-grid">
                @foreach (var (file, index) in SelectedFiles.Select((f, i) => (f, i)))
                {
                    var uploadStatus = UploadStatuses.TryGetValue(index, out var status) ? status : FileUploadStatus.Pending;
                    <div class="preview-item @(file.ContentType == "image/gif" ? "gif-placeholder" : "") @(uploadStatus == FileUploadStatus.Uploading ? "uploading" : "") @(uploadStatus == FileUploadStatus.Completed ? "uploaded" : "") @(uploadStatus == FileUploadStatus.Failed ? "failed" : "")">
                        @if (PreviewUrls.ContainsKey(index))
                        {
                            @if (file.ContentType == "image/gif")
                            {
                                @* Show GIF placeholder with icon *@
                                <div class="gif-preview-placeholder">
                                    <MudIcon Icon="@Icons.Material.Filled.Gif" Size="Size.Large" />
                                    <div class="gif-info">
                                        <div class="gif-badge-large">GIF</div>
                                        <div class="file-size">@FormatFileSize(file.Size)</div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                @* Show actual image preview *@
                                <img src="@PreviewUrls[index]" alt="Preview @file.Name" class="preview-image" />
                            }
                        }
                        
                        @* Upload Status Overlay *@
                        @if (uploadStatus == FileUploadStatus.Uploading)
                        {
                            <div class="upload-status-overlay uploading">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                            </div>
                        }
                        else if (uploadStatus == FileUploadStatus.Completed)
                        {
                            <div class="upload-status-overlay completed">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium" />
                            </div>
                        }
                        else if (uploadStatus == FileUploadStatus.Failed)
                        {
                            <div class="upload-status-overlay failed">
                                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Medium" />
                            </div>
                        }
                        
                        <button type="button" class="remove-preview-btn" @onclick="() => RemoveImage(index)" title="@Localizer["RemoveImageTitle"]">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                        </button>
                        <div class="preview-filename">@file.Name</div>
                    </div>
                }
            </div>
        </div>
    }

    @* Validation Messages *@
    @if (!string.IsNullOrWhiteSpace(ValidationMessage))
    {
        <div class="alert alert-warning" role="alert">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="me-2" />
            @ValidationMessage
        </div>
    }

    @if (ActiveAttachment == "schedule")
    {
        <div class="post-form-fields active">
            <div class="form-row">
                <div class="form-group">
                    <label>@Localizer["EventDateLabel"]</label>
                    <input type="date" @bind="ScheduledDate" />
                </div>
                <div class="form-group">
                    <label>@Localizer["EventTimeLabel"]</label>
                    <input type="time" @bind="ScheduledTime" />
                </div>
            </div>
            <div class="form-group">
                <label>@Localizer["LocationLabel"]</label>
                <input type="text" placeholder="@Localizer["EventLocationPlaceholder"]" @bind="ScheduledLocation" />
            </div>
        </div>
    }
</div>

<style>
    .composer-advanced-section {
        margin: 12px 0;
        border-top: 1px solid var(--wire-border);
    }

    .advanced-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px;
        cursor: pointer;
        font-weight: 500;
        color: var(--wire-text-secondary);
        user-select: none;
    }

    .advanced-toggle:hover {
        background: var(--wire-hover);
        color: var(--wire-text-primary);
    }

    details[open] .advanced-toggle {
        color: var(--wire-primary);
    }

    details > div:not(.advanced-toggle) {
        padding: 0 12px 12px;
    }

    .form-group {
        margin-bottom: 12px;
    }

    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: var(--wire-text-primary);
        margin-bottom: 6px;
    }

    .form-control {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid var(--wire-border);
        border-radius: 6px;
        font-size: 13px;
        font-family: inherit;
    }

