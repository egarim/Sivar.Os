    /// Current profile type name (e.g., "PersonalProfile", "BusinessProfile")
    /// Used to filter available post types
    /// </summary>
    [Parameter]
    public string CurrentProfileTypeName { get; set; } = "PersonalProfile";

    /// <summary>
    /// Available post type options
    /// </summary>
    [Parameter]
    public List<PostTypeOption> PostTypeOptions { get; set; } = new()
    {
        new("general", "General", Icons.Material.Filled.Article, "Share updates with everyone."),
        new("blog", "Blog", Icons.Material.Filled.EditNote, "Write a long-form article or blog post."),
        new("businesslocation", "Location", Icons.Material.Filled.LocationOn, "Add a business location, branch, or office."),
        new("product", "Product", Icons.Material.Filled.Storefront, "Highlight new features or releases."),
        new("service", "Service", Icons.Material.Filled.HeadsetMic, "Promote a service offering."),
        new("event", "Event", Icons.Material.Filled.Event, "Schedule an event or meetup."),
        new("job", "Job", Icons.Material.Filled.Work, "Share an open role with the community."),
        new("procedure", "Procedure", Icons.Material.Filled.Checklist, "Create a step-by-step guide or procedure.")
    };

    /// <summary>
    /// Filtered post type options based on current profile type
    /// Business profiles: all options
    /// Personal profiles: General and Blog
    /// </summary>
    private List<PostTypeOption> FilteredPostTypeOptions => GetFilteredPostTypeOptions();

    private List<PostTypeOption> GetFilteredPostTypeOptions()
    {
        // Business profiles can use all post types
        if (CurrentProfileTypeName?.ToLower().Contains("business") == true)
        {
            return PostTypeOptions;
        }
        
        // Personal, Government, and other profiles can use General, Blog, and Procedure
        // Procedure is available to ALL profile types for guides, tutorials, how-tos
        return PostTypeOptions.Where(o => o.Id == "general" || o.Id == "blog" || o.Id == "procedure").ToList();
    }

