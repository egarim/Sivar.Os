    /// </summary>
    private string ProcedureAdditionalNotes { get; set; } = string.Empty;

    /// <summary>
    /// ProcedureMetadataJson parameter for binding to parent
    /// </summary>
    [Parameter]
    public string ProcedureMetadataJson { get; set; } = string.Empty;
    
    [Parameter]
    public EventCallback<string> ProcedureMetadataJsonChanged { get; set; }

    /// <summary>
    /// Build ProcedureMetadata from form fields
    /// </summary>
    private ProcedureMetadata BuildProcedureMetadata()
    {
        // Update step numbers before building
        for (int i = 0; i < ProcedureSteps.Count; i++)
        {
            ProcedureSteps[i].StepNumber = i + 1;
        }
        
        return new ProcedureMetadata
        {
            ProcessingTime = !string.IsNullOrWhiteSpace(ProcedureProcessingTime) ? ProcedureProcessingTime : null,
            Cost = !string.IsNullOrWhiteSpace(ProcedureCost) ? ProcedureCost : null,
            WhereToGo = !string.IsNullOrWhiteSpace(ProcedureWhereToGo) ? ProcedureWhereToGo : null,
            OnlineUrl = !string.IsNullOrWhiteSpace(ProcedureOnlineUrl) ? ProcedureOnlineUrl : null,
            RequiresAppointment = ProcedureRequiresAppointment,
            ContactPhone = !string.IsNullOrWhiteSpace(ProcedureContactPhone) ? ProcedureContactPhone : null,
            ContactEmail = !string.IsNullOrWhiteSpace(ProcedureContactEmail) ? ProcedureContactEmail : null,
            Documents = ProcedureDocuments.Where(d => !string.IsNullOrWhiteSpace(d.Name)).ToList(),
            Steps = ProcedureSteps.Where(s => !string.IsNullOrWhiteSpace(s.Title)).ToList(),
            AdditionalNotes = !string.IsNullOrWhiteSpace(ProcedureAdditionalNotes) ? ProcedureAdditionalNotes : null
        };
    }
    
    /// <summary>
    /// Sync Procedure form data to parent bindings
    /// </summary>
    private async Task SyncProcedureToParent()
    {
        if (SelectedType != "procedure")
            return;
            
        // Set the procedure title as the post content
        PostText = ProcedureTitle;
        await PostTextChanged.InvokeAsync(PostText);
        
        // Serialize metadata to JSON
        var metadata = BuildProcedureMetadata();
        var metadataJson = JsonSerializer.Serialize(metadata, new JsonSerializerOptions 
        { 
            PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
            WriteIndented = false 
        });
        
        ProcedureMetadataJson = metadataJson;
        await ProcedureMetadataJsonChanged.InvokeAsync(metadataJson);
        
        Logger.LogDebug("[PostComposer] Synced Procedure data to parent");
    }
    
