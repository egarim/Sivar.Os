    }

    .alert {
        padding: 12px;
        border-radius: 6px;
        margin: 12px 0;
        display: flex;
        align-items: center;
    }

    .alert-warning {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    .me-2 {
        margin-right: 8px;
    }

    /* Image Preview Styles */
    .image-preview-section {
        margin: 16px 0;
        padding: 12px;
        background: var(--wire-background);
        border: 1px solid var(--wire-border);
        border-radius: 8px;
    }

    .preview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 12px;
    }

    .preview-item {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        background: var(--wire-background-alt);
        border: 1px solid var(--wire-border);
        transition: border-color 0.3s, box-shadow 0.3s;
    }

    .preview-item.uploading {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 0 8px rgba(var(--mud-palette-primary-rgb), 0.3);
    }

    .preview-item.uploaded {
        border-color: var(--mud-palette-success);
        box-shadow: 0 0 8px rgba(var(--mud-palette-success-rgb), 0.3);
    }

    .preview-item.failed {
        border-color: var(--mud-palette-error);
        box-shadow: 0 0 8px rgba(var(--mud-palette-error-rgb), 0.3);
    }

    /* Upload Status Overlay */
    .upload-status-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 30px; /* Leave room for filename */
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 5;
    }

    .upload-status-overlay.uploading {
        background: rgba(0, 0, 0, 0.5);
    }

    .upload-status-overlay.completed {
        background: rgba(76, 175, 80, 0.2);
        animation: fade-in 0.3s ease-out;
    }

    .upload-status-overlay.failed {
        background: rgba(244, 67, 54, 0.2);
    }

    @@keyframes fade-in {
        from { opacity: 0; transform: scale(0.8); }
        to { opacity: 1; transform: scale(1); }
    }

    .preview-image {
        width: 100%;
        height: 120px;
        object-fit: cover;
        display: block;
    }

    .remove-preview-btn {
        position: absolute;
        top: 4px;
        right: 4px;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        border: none;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 0;
        transition: background 0.2s;
    }

    .remove-preview-btn:hover {
        background: rgba(0, 0, 0, 0.9);
    }

    .preview-filename {
        padding: 6px 8px;
        font-size: 11px;
        color: var(--wire-text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .gif-badge {
        position: absolute;
        top: 8px;
        left: 8px;
        background: rgba(0, 0, 0, 0.8);
        color: #00ff00;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        border: 1px solid #00ff00;
        animation: pulse-gif 2s infinite;
    }

    /* GIF Preview Placeholder Styles */
    .gif-placeholder {
        background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
    }

    .gif-preview-placeholder {
        width: 100%;
        height: 120px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: white;
