    /// <summary>
    /// Determines if the publish button should be disabled based on post type and content
    /// </summary>
    private bool IsPublishDisabled
    {
        get
        {
            if (SelectedType == "blog")
            {
                // For blogs, require at least a title and some content
                return string.IsNullOrWhiteSpace(BlogTitle) || string.IsNullOrWhiteSpace(BlogContent);
            }
            else if (SelectedType == "businesslocation")
            {
                // For business locations, require name and coordinates
                return string.IsNullOrWhiteSpace(BusinessLocationName) || 
                       !BusinessPostLocation.Latitude.HasValue || 
                       !BusinessPostLocation.Longitude.HasValue;
            }
            else if (SelectedType == "procedure")
            {
                // For procedures, require at least a title
                return string.IsNullOrWhiteSpace(ProcedureTitle);
            }
            // For regular posts, require post text
            return string.IsNullOrWhiteSpace(PostText);
        }
    }

