@using Sivar.Os.Client.Pages
@using Sivar.Os.Shared.DTOs
@using MudBlazor

@* PostComments component *@

@if (Comments != null && Comments.Any())
{
    <div class="post-comments-section">
        <button class="comments-toggle" @onclick="OnToggleComments">
            <MudIcon Icon="@(ShowComments ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
            @(ShowComments ? "Hide" : "Show") @Comments.Count comment@(Comments.Count != 1 ? "s" : "")
        </button>
        
        @if (ShowComments)
        {
            <div class="comments-list">
                @foreach (var comment in Comments)
                {
                    <CommentItem 
                        Author="@comment.Profile?.DisplayName"
                        AuthorInitials="@GetInitials(comment.Profile?.DisplayName)"
                        Text="@comment.Content"
                        Time="@comment.CreatedAt"
                        Likes="@(comment.ReactionSummary?.TotalReactions ?? 0)"
                        OnAuthorClick="@(() => OnCommentAuthorClick.InvokeAsync(comment.Profile?.DisplayName ?? string.Empty))" />
                }
            </div>
        }
    </div>
}

@code {
    /// <summary>
    /// List of comments
    /// </summary>
    [Parameter]
    public List<CommentDto>? Comments { get; set; }

    /// <summary>
    /// Whether comments are shown
    /// </summary>
    [Parameter]
    public bool ShowComments { get; set; }

    /// <summary>
    /// Callback when toggle comments button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnToggleComments { get; set; }

    /// <summary>
    /// Callback when comment author is clicked
    /// </summary>
    [Parameter]
    public EventCallback<string> OnCommentAuthorClick { get; set; }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        return string.Join(string.Empty, name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(p => char.ToUpperInvariant(p[0])));
    }
}
