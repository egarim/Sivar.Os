@using MudBlazor

@* Skeleton loading placeholder for feed posts *@
@* Shows animated placeholders while actual posts are loading *@

<div class="feed-skeleton">
    @for (int i = 0; i < Count; i++)
    {
        <article class="post-card skeleton-card">
            @* Header: Avatar + Name + Time *@
            <div class="post-header-skeleton">
                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="48px" Height="48px" Animation="Animation.Wave" />
                <div class="header-text-skeleton">
                    <MudSkeleton Width="140px" Height="16px" Animation="Animation.Wave" />
                    <MudSkeleton Width="80px" Height="12px" Animation="Animation.Wave" Class="mt-1" />
                </div>
            </div>

            @* Content: Text lines *@
            <div class="post-content-skeleton">
                <MudSkeleton Width="100%" Height="14px" Animation="Animation.Wave" />
                <MudSkeleton Width="85%" Height="14px" Animation="Animation.Wave" Class="mt-2" />
                <MudSkeleton Width="60%" Height="14px" Animation="Animation.Wave" Class="mt-2" />
            </div>

            @* Image placeholder (alternating) *@
            @if (i % 2 == 0)
            {
                <div class="post-image-skeleton">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="200px" Animation="Animation.Wave" />
                </div>
            }

            @* Footer: Action buttons *@
            <div class="post-footer-skeleton">
                <MudSkeleton Width="60px" Height="24px" Animation="Animation.Wave" />
                <MudSkeleton Width="60px" Height="24px" Animation="Animation.Wave" />
                <MudSkeleton Width="60px" Height="24px" Animation="Animation.Wave" />
                <MudSkeleton Width="60px" Height="24px" Animation="Animation.Wave" />
            </div>
        </article>
    }
</div>

@code {
    /// <summary>
    /// Number of skeleton cards to display
    /// </summary>
    [Parameter]
    public int Count { get; set; } = 3;
}
