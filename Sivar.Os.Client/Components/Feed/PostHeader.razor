@using Sivar.Os.Client.Components.Shared
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Localization
@inject ILogger<PostHeader> Logger
@inject IStringLocalizer<PostHeader> Localizer

@* PostHeader component *@

<header class="post-header">
    <Avatar Initials="@AuthorInitials" Size="large" IsClickable="true" OnClick="@HandleAuthorClick" CssClass="post-avatar" />
    <div class="post-author-info">
        <div class="post-author-name clickable" @onclick="HandleAuthorClick">@Author</div>
        <div class="post-time">@Time.ToString(Localizer["DateTimeFormat"])</div>
    </div>
    <div class="post-header-tags">
        @if (DistanceKm.HasValue)
        {
            <span class="post-distance-badge" title="@Localizer["DistanceFromYou"]">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                @FormatDistance(DistanceKm.Value)
            </span>
        }
        <span class="post-visibility">@Visibility</span>
        <span class="post-type-badge @Type">@TypeLabel</span>
    </div>
</header>

@code {
    /// <summary>
    /// Author name
    /// </summary>
    [Parameter]
    public string Author { get; set; } = string.Empty;

    /// <summary>
    /// Author initials
    /// </summary>
    [Parameter]
    public string AuthorInitials { get; set; } = string.Empty;

    /// <summary>
    /// Post time
    /// </summary>
    [Parameter]
    public DateTime Time { get; set; }

    /// <summary>
    /// Post visibility (Public, Team, etc.)
    /// </summary>
    [Parameter]
    public string Visibility { get; set; } = "Public";

    /// <summary>
    /// Post type (general, product, service, etc.)
    /// </summary>
    [Parameter]
    public string Type { get; set; } = "general";

    /// <summary>
    /// Display label for the post type
    /// </summary>
    [Parameter]
    public string TypeLabel { get; set; } = "General";

    /// <summary>
    /// Distance in kilometers from user's location (for proximity search results)
    /// </summary>
    [Parameter]
    public double? DistanceKm { get; set; }

    /// <summary>
    /// Callback when author is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnAuthorClick { get; set; }

    /// <summary>
    /// Format distance for display
    /// </summary>
    private string FormatDistance(double km)
    {
        if (km < 1)
            return $"{(int)(km * 1000)} m";
        else if (km < 10)
            return $"{km:F1} km";
        else
            return $"{(int)km} km";
    }

    /// <summary>
    /// Handle author click and invoke callback with debugging
    /// </summary>
    private async Task HandleAuthorClick()
    {
        Logger.LogInformation("=============================================================");
        Logger.LogInformation("[PostHeader.HandleAuthorClick] Clicked on author: {Author}", Author);
        Logger.LogInformation("[PostHeader.HandleAuthorClick] Invoking OnAuthorClick callback");
        
        await OnAuthorClick.InvokeAsync();
        
        Logger.LogInformation("[PostHeader.HandleAuthorClick] Callback invoked successfully");
        Logger.LogInformation("=============================================================");
    }
}
