@using Microsoft.Extensions.Logging
@inject ILogger<FeedHeader> Logger

@* FeedHeader component *@

<div class="feed-header">
    <h2>@Title</h2>
    <p class="feed-subtitle">@Subtitle</p>
</div>

@code {
    /// <summary>
    /// Main title
    /// </summary>
    [Parameter]
    public string Title { get; set; } = "Activity Stream";

    /// <summary>
    /// Subtitle text
    /// </summary>
    [Parameter]
    public string Subtitle { get; set; } = "Latest updates from your network";

    protected override void OnInitialized()
    {
        Logger.LogInformation("[FeedHeader] Component initialized - Title: {Title}, Subtitle: {Subtitle}", Title, Subtitle);
    }
}
