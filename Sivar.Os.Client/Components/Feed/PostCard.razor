@using Sivar.Os.Client.Pages
@using Sivar.Os.Shared.DTOs
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Localization
@using MudBlazor
@inject ILogger<PostCard> Logger
@inject IStringLocalizer<PostCard> Localizer
@inject IDialogService DialogService

@* PostCard component for displaying a complete post *@

<article class="post-card">
    <PostHeader 
        Author="@Post.Profile?.DisplayName"
        AuthorInitials="@GetInitials(Post.Profile?.DisplayName)"
        Time="@Post.CreatedAt"
        Visibility="@Post.Visibility.ToString()"
        Type="@Post.PostType.ToString()"
        TypeLabel="@Post.PostType.ToString()"
        OnAuthorClick="@(async () => await HandleAuthorClick())" />

    <div class="post-content">@Post.Content</div>

    @if (Post.Attachments?.Count > 0)
    {
        Logger.LogInformation("[PostCard] Rendering {Count} attachments for Post {PostId}", Post.Attachments.Count, Post.Id);
        
        @foreach (var att in Post.Attachments)
        {
            Logger.LogInformation("[PostCard] Attachment {AttachmentId}: FileId={FileId}, FilePath={FilePath}, MimeType={MimeType}, OriginalName={OriginalName}",
                att.Id, att.FileId ?? "NULL", att.FilePath ?? "NULL", att.MimeType ?? "NULL", att.OriginalFilename ?? "NULL");
        }
        
        <div class="post-attachments">
            @if (Post.Attachments.Count == 1)
            {
                var singleAttachment = Post.Attachments[0];
                <div class="single-image" @onclick="@(() => OpenImageViewer(0))" style="cursor: pointer;">
                    <img src="@singleAttachment.FilePath" 
                         alt="@(singleAttachment.AltText ?? singleAttachment.OriginalFilename)" 
                         class="attachment-image"
                         @onerror="@(() => LogImageLoadError(singleAttachment.FilePath, singleAttachment.FileId, Post.Id))" />
                    @if (singleAttachment.MimeType == "image/gif")
                    {
                        <div class="gif-badge">@Localizer["GifBadge"]</div>
                    }
                </div>
            }
            else
            {
                <MudCarousel Class="mud-width-full post-carousel" 
                             Style="height:400px;" 
                             ShowArrows="true" 
                             ShowBullets="true" 
                             EnableSwipeGesture="true"
                             AutoCycle="false"
                             TData="object">
                    @for (int i = 0; i < Post.Attachments.Count; i++)
                    {
                        var index = i; // Capture loop variable
                        var attachment = Post.Attachments[index];
                        <MudCarouselItem Transition="Transition.Slide">
                            <div class="carousel-image-container" @onclick="@(() => OpenImageViewer(index))" style="cursor: pointer;">
                                <img src="@attachment.FilePath" 
                                     alt="@(attachment.AltText ?? attachment.OriginalFilename)" 
                                     class="carousel-image"
                                     @onerror="@(() => LogImageLoadError(attachment.FilePath, attachment.FileId, Post.Id))" />
                                @if (attachment.MimeType == "image/gif")
                                {
                                    <div class="gif-badge">@Localizer["GifBadge"]</div>
                                }
                                @if (!string.IsNullOrEmpty(attachment.AltText))
                                {
                                    <div class="image-caption">@attachment.AltText</div>
                                }
                            </div>
                        </MudCarouselItem>
                    }
                </MudCarousel>
            }
        </div>
    }
    else
    {
        Logger.LogWarning("[PostCard] No attachments found for Post {PostId}, Attachments is {IsNull}", 
            Post.Id, Post.Attachments == null ? "NULL" : "EMPTY");
    }

    <PostReactions ReactionSummary="@Post.ReactionSummary" />

    <PostFooter 
        Likes="@(Post.ReactionSummary?.TotalReactions ?? 0)"
        Comments="@Post.CommentCount"
        Shares="0"
        Liked="@(Post.ReactionSummary?.UserReaction.HasValue ?? false)"
        IsPostOwner="@IsCurrentUserOwner"
        PostLink="@GetPostLink()"
        OnLike="@(() => OnLike.InvokeAsync(Post))"
        OnComment="@HandleCommentClick"
        OnShare="@(() => OnShare.InvokeAsync(Post))"
        OnSave="@(() => OnSave.InvokeAsync(Post))"
        OnMore="@(() => OnMore.InvokeAsync(Post))"
        OnEdit="@(() => OnEdit.InvokeAsync(Post))"
        OnDelete="@(() => OnDelete.InvokeAsync(Post))"
        OnViewAnalytics="@(() => OnViewAnalytics.InvokeAsync(Post))"
        OnReport="@(() => OnReport.InvokeAsync(Post))"
        OnCopyLink="@(() => OnCopyLink.InvokeAsync(Post))" />

    <CommentSection PostId="@Post.Id"
                    InitialCommentCount="@Post.CommentCount"
                    IsExpanded="@_showComments"
                    OnCommentAdded="HandleCommentAdded" />
</article>

@code {
    /// <summary>
    /// The post to display
    /// </summary>
    [Parameter, EditorRequired]
    public PostDto Post { get; set; } = null!;

    /// <summary>
    /// Display label for post type
    /// </summary>
    [Parameter]
    public string TypeLabel { get; set; } = "General";

    private string GetLocalizedTypeLabel() => TypeLabel == "General" ? Localizer["DefaultTypeLabel"] : TypeLabel;

    /// <summary>
    /// Current user ID for ownership check
    /// </summary>
    [Parameter]
    public Guid CurrentUserId { get; set; }

    /// <summary>
    /// Whether the current user is the post owner
    /// </summary>
    private bool IsCurrentUserOwner => Post?.Profile?.Id == CurrentUserId;

    /// <summary>
    /// Get the link to the post (for sharing/copying)
    /// </summary>
    private string GetPostLink() => $"/posts/{Post?.Id}";

    /// <summary>
    /// Callback when like button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnLike { get; set; }

    /// <summary>
    /// Callback when comment button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnCommentClick { get; set; }

    /// <summary>
    /// Callback when share button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnShare { get; set; }

    /// <summary>
    /// Callback when save button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnSave { get; set; }

    /// <summary>
    /// Callback when more button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnMore { get; set; }

    /// <summary>
    /// Callback when author name/avatar is clicked
    /// </summary>
    [Parameter]
    public EventCallback<string> OnAuthorClick { get; set; }

    /// <summary>
    /// Callback when edit button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnEdit { get; set; }

    /// <summary>
    /// Callback when delete button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnDelete { get; set; }

    /// <summary>
    /// Callback when view analytics button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnViewAnalytics { get; set; }

    /// <summary>
    /// Callback when report button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnReport { get; set; }

    /// <summary>
    /// Callback when copy link button is clicked
    /// </summary>
    [Parameter]
    public EventCallback<PostDto> OnCopyLink { get; set; }

    /// <summary>
    /// Handle author click with debugging
    /// </summary>
    private async Task HandleAuthorClick()
    {
        var handle = Post.Profile?.Handle ?? string.Empty;
        Logger.LogInformation("=============================================================");
        Logger.LogInformation("[PostCard.HandleAuthorClick] Called");
        Logger.LogInformation("[PostCard.HandleAuthorClick] Post Profile DisplayName: '{DisplayName}'", Post.Profile?.DisplayName);
        Logger.LogInformation("[PostCard.HandleAuthorClick] Post Profile Handle: '{Handle}'", handle);
        Logger.LogInformation("[PostCard.HandleAuthorClick] Handle IsNull: {IsNull}", Post.Profile?.Handle == null);
        Logger.LogInformation("[PostCard.HandleAuthorClick] Handle IsEmpty: {IsEmpty}", string.IsNullOrEmpty(handle));
        Logger.LogInformation("[PostCard.HandleAuthorClick] Invoking OnAuthorClick with: '{Handle}'", handle);
        
        await OnAuthorClick.InvokeAsync(handle);
        
        Logger.LogInformation("[PostCard.HandleAuthorClick] OnAuthorClick.InvokeAsync completed");
        Logger.LogInformation("=============================================================");
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrEmpty(name)) return Localizer["UnknownUserInitials"];
        return string.Join(string.Empty, name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(p => char.ToUpperInvariant(p[0])));
    }

    /// <summary>
    /// Opens the image viewer dialog with the selected image
    /// </summary>
    private async Task OpenImageViewer(int startIndex)
    {
        Logger.LogInformation("[PostCard.OpenImageViewer] Opening image viewer at index {Index}", startIndex);
        
        IDialogReference? dialogRef = null;
        
        var parameters = new DialogParameters
        {
            { "Post", Post },
            { "Attachments", Post.Attachments },
            { "StartIndex", startIndex },
            { "OnClose", new Action(() => dialogRef?.Close()) }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraExtraLarge,
            FullWidth = true,
            CloseButton = false,
            CloseOnEscapeKey = true,
            BackdropClick = true,
            NoHeader = true,
            Position = DialogPosition.Center
        };

        dialogRef = await DialogService.ShowAsync<ImageViewerDialog>("", parameters, options);
    }

    /// <summary>
    /// Log image load error for debugging
    /// </summary>
    private void LogImageLoadError(string? filePath, string? fileId, Guid postId)
    {
        Logger.LogError("[PostCard] IMAGE LOAD FAILED - PostId={PostId}, FileId={FileId}, FilePath={FilePath}",
            postId, fileId ?? "NULL", filePath ?? "NULL");
        Console.WriteLine($"[PostCard] IMAGE LOAD FAILED - PostId={postId}, FileId={fileId ?? "NULL"}, FilePath={filePath ?? "NULL"}");
    }

    // Comment section state
    private bool _showComments = false;

    private async Task HandleCommentClick()
    {
        _showComments = !_showComments;
        await OnCommentClick.InvokeAsync(Post);
        StateHasChanged();
    }

    private void HandleCommentAdded()
    {
        Post = Post with { CommentCount = Post.CommentCount + 1 };
        StateHasChanged();
    }
}
