@using MudBlazor
@using DevExpress.Blazor
@using DevExpress.Blazor.Office
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Logging
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Services
@using System.Net.Http.Headers
@using System.Text.RegularExpressions
@using System.Text.Json

@inject ILogger<BlogEditor> Logger
@inject NavigationManager NavigationManager
@inject HttpClient HttpClient

@* BlogEditor component - DxHtmlEditor for HTML content editing *@

<div class="blog-editor-container">
    @* Cover Image Preview at Top *@
    <div class="blog-cover-section @(string.IsNullOrWhiteSpace(CoverImageUrl) ? "no-preview" : "has-preview")">
        @if (!string.IsNullOrWhiteSpace(CoverImageUrl))
        {
            <div class="cover-image-preview">
                <img src="@CoverImageUrl" alt="Cover image preview" />
                <div class="cover-image-overlay">
                    <label for="coverImageUpload" class="change-cover-btn">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                        <span>Change</span>
                    </label>
                    <button type="button" class="remove-cover-btn" @onclick="RemoveCoverImage">
                        <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                        <span>Remove</span>
                    </button>
                </div>
            </div>
        }
        else
        {
            <label for="coverImageUpload" class="cover-upload-area">
                <MudIcon Icon="@Icons.Material.Outlined.AddPhotoAlternate" Size="Size.Large" />
                <span>Add a cover image</span>
                <small>Recommended: 1200 x 630px</small>
            </label>
        }
        
        <InputFile id="coverImageUpload" 
                   OnChange="OnCoverImageSelected" 
                   accept="image/*" 
                   style="display: none;" />
        
        @if (IsUploadingCover)
        {
            <div class="upload-progress-overlay">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <span>Uploading...</span>
            </div>
        }
    </div>

    @* Title Input *@
    <div class="blog-title-section">
        <input type="text" 
               class="blog-title-input" 
               placeholder="Blog Title (required)" 
               value="@Title" 
               @oninput="OnTitleInput" />
    </div>

    @* Subtitle Input *@
    <div class="blog-subtitle-section">
        <input type="text" 
               class="blog-subtitle-input" 
               placeholder="Add a subtitle (optional)" 
               value="@Subtitle" 
               @oninput="OnSubtitleInput" />
    </div>

    @* HTML Editor (DxHtmlEditor) *@
    <div class="blog-content-section">
        <DxHtmlEditor Markup="@Content"
                      MarkupChanged="@OnContentChanged"
                      Height="500px"
                      Width="100%"
                      NullText="Write your blog content here..."
                      TableResizeEnabled="true"
                      MediaResizeEnabled="true" />
    </div>

    @* Draft Toggle *@
    <div class="blog-options-section">
        <MudSwitch T="bool" 
                   Color="Color.Primary" 
                   @bind-Value="IsDraft"
                   Label="Save as draft" />
        <small class="draft-hint">Drafts are only visible to you until published</small>
    </div>
</div>

<style>
    .blog-editor-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding: 0;
    }

    /* Cover Image Section - At Top */
    .blog-cover-section {
        position: relative;
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
    }

    .blog-cover-section.no-preview {
        min-height: 120px;
        border: 2px dashed var(--wire-border);
        background: var(--wire-card);
    }

    .blog-cover-section.no-preview:hover {
        border-color: var(--wire-primary);
        background: rgba(29, 161, 242, 0.05);
    }

    .blog-cover-section.has-preview {
        min-height: 200px;
    }

    .cover-upload-area {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        height: 120px;
        color: var(--wire-text-secondary);
        cursor: pointer;
    }

    .cover-upload-area:hover {
        color: var(--wire-primary);
    }

    .cover-upload-area span {
        font-size: 14px;
        font-weight: 500;
    }

    .cover-upload-area small {
        font-size: 12px;
        opacity: 0.7;
    }

    .cover-image-preview {
        position: relative;
        width: 100%;
    }

    .cover-image-preview img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
    }

    .cover-image-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 12px;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
        opacity: 0;
        transition: opacity 0.2s;
    }

    .cover-image-preview:hover .cover-image-overlay {
        opacity: 1;
    }

    .change-cover-btn,
    .remove-cover-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        border: none;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .change-cover-btn {
        background: rgba(255, 255, 255, 0.9);
        color: var(--wire-text-primary);
    }

    .change-cover-btn:hover {
        background: white;
    }

    .remove-cover-btn {
        background: rgba(244, 67, 54, 0.9);
        color: white;
    }

    .remove-cover-btn:hover {
        background: #f44336;
    }

    .upload-progress-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        font-size: 14px;
    }

    .blog-title-section,
    .blog-subtitle-section {
        width: 100%;
    }

    .blog-title-input {
        width: 100%;
        font-size: 24px;
        font-weight: 700;
        padding: 12px;
        border: 1px solid var(--wire-border);
        border-radius: 8px;
        background: var(--wire-background);
        color: var(--wire-text-primary);
    }

    .blog-title-input:focus {
        outline: none;
        border-color: var(--wire-primary);
        box-shadow: 0 0 0 2px rgba(29, 161, 242, 0.1);
    }

    .blog-subtitle-input {
        width: 100%;
        font-size: 16px;
        font-weight: 400;
        padding: 10px 12px;
        border: 1px solid var(--wire-border);
        border-radius: 8px;
        background: var(--wire-background);
        color: var(--wire-text-secondary);
    }

    .blog-subtitle-input:focus {
        outline: none;
        border-color: var(--wire-primary);
        box-shadow: 0 0 0 2px rgba(29, 161, 242, 0.1);
    }

    .blog-content-section {
        width: 100%;
        min-height: 400px;
    }

    /* DxHtmlEditor customizations */
    .blog-content-section .dxbl-html-editor {
        border: 1px solid var(--wire-border);
        border-radius: 8px;
    }

    .blog-options-section {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 8px 0;
    }

    .draft-hint {
        font-size: 12px;
        color: var(--wire-text-secondary);
    }
</style>

@code {
    #region Parameters

    /// <summary>
    /// Blog title
    /// </summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> TitleChanged { get; set; }

    /// <summary>
    /// Blog subtitle
    /// </summary>
    [Parameter]
    public string Subtitle { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SubtitleChanged { get; set; }

    /// <summary>
    /// Blog content (HTML)
    /// </summary>
    [Parameter]
    public string Content { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ContentChanged { get; set; }

    /// <summary>
    /// Cover image URL
    /// </summary>
    [Parameter]
    public string CoverImageUrl { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> CoverImageUrlChanged { get; set; }

    /// <summary>
    /// Cover image file ID (for storage reference)
    /// </summary>
    [Parameter]
    public string? CoverImageFileId { get; set; }

    [Parameter]
    public EventCallback<string?> CoverImageFileIdChanged { get; set; }

    /// <summary>
    /// Is this a draft
    /// </summary>
    [Parameter]
    public bool IsDraft { get; set; } = false;

    [Parameter]
    public EventCallback<bool> IsDraftChanged { get; set; }

    /// <summary>
    /// Callback when cover image is uploaded
    /// </summary>
    [Parameter]
    public EventCallback<FileUploadResult> OnCoverImageUploaded { get; set; }

    #endregion

    #region State

    private bool IsUploadingCover { get; set; }
    private bool IsProcessingImages { get; set; }
    private System.Threading.CancellationTokenSource? _debounceTokenSource;

    /// <summary>
    /// Regex pattern to match base64 encoded images in HTML img src attributes
    /// Matches: src="data:image/TYPE;base64,DATA"
    /// </summary>
    private static readonly Regex Base64ImageRegex = new(
        @"src\s*=\s*[""']data:image/(jpeg|jpg|png|gif|webp);base64,([^""']+)[""']",
        RegexOptions.Compiled | RegexOptions.IgnoreCase);

    #endregion

    #region Methods

    private async Task OnTitleInput(ChangeEventArgs e)
    {
        Title = e.Value?.ToString() ?? string.Empty;
        await TitleChanged.InvokeAsync(Title);
    }

    private async Task OnSubtitleInput(ChangeEventArgs e)
    {
        Subtitle = e.Value?.ToString() ?? string.Empty;
        await SubtitleChanged.InvokeAsync(Subtitle);
    }

    private async Task OnContentChanged(string htmlContent)
    {
        // First, notify parent immediately so they see the content
        Content = htmlContent;
        await ContentChanged.InvokeAsync(htmlContent);
        Logger.LogDebug("[BlogEditor] Content updated, HTML length: {Length}", htmlContent?.Length ?? 0);

        // Then, process any base64 images in the background with debouncing
        // This prevents processing on every keystroke
        _debounceTokenSource?.Cancel();
        _debounceTokenSource = new System.Threading.CancellationTokenSource();
        var token = _debounceTokenSource.Token;

        try
        {
            // Wait 1 second before processing (debounce)
            await Task.Delay(1000, token);
            
            if (!token.IsCancellationRequested && !string.IsNullOrWhiteSpace(htmlContent))
            {
                await ProcessBase64ImagesAsync(htmlContent);
            }
        }
        catch (TaskCanceledException)
        {
            // Debounce cancelled, that's expected
        }
    }

    /// <summary>
    /// Process HTML content to find and upload base64 images, replacing them with server URLs
    /// </summary>
    private async Task ProcessBase64ImagesAsync(string htmlContent)
    {
        if (IsProcessingImages)
            return;

        var matches = Base64ImageRegex.Matches(htmlContent);
        if (matches.Count == 0)
            return;

        Logger.LogInformation("[BlogEditor] Found {Count} base64 images to process", matches.Count);
        IsProcessingImages = true;
        StateHasChanged();

        try
        {
            var updatedContent = htmlContent;
            var uploadedCount = 0;

            foreach (Match match in matches)
            {
                var imageType = match.Groups[1].Value.ToLowerInvariant();
                var base64Data = match.Groups[2].Value;
                var fullMatch = match.Value; // e.g., src="data:image/png;base64,..."

                // Determine content type
                var contentType = imageType switch
                {
                    "jpg" or "jpeg" => "image/jpeg",
                    "png" => "image/png",
                    "gif" => "image/gif",
                    "webp" => "image/webp",
                    _ => "image/png"
                };

                try
                {
                    // Upload to server
                    var imageUrl = await UploadBase64ImageAsync(base64Data, contentType);
                    
                    if (!string.IsNullOrWhiteSpace(imageUrl))
                    {
                        // Replace base64 with URL
                        var replacement = $"src=\"{imageUrl}\"";
                        updatedContent = updatedContent.Replace(fullMatch, replacement);
                        uploadedCount++;
                        Logger.LogDebug("[BlogEditor] Replaced base64 image with URL: {Url}", imageUrl);
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "[BlogEditor] Failed to upload base64 image");
                    // Continue processing other images
                }
            }

            // If we made any replacements, update the content
            if (uploadedCount > 0)
            {
                Content = updatedContent;
                await ContentChanged.InvokeAsync(updatedContent);
                Logger.LogInformation("[BlogEditor] Processed {Count} base64 images successfully", uploadedCount);
                StateHasChanged();
            }
        }
        finally
        {
            IsProcessingImages = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Upload a base64 encoded image to the server
    /// </summary>
    private async Task<string?> UploadBase64ImageAsync(string base64Data, string contentType)
    {
        try
        {
            using var httpClient = new HttpClient();
            httpClient.BaseAddress = new Uri(NavigationManager.BaseUri);

            var requestBody = new
            {
                Base64Data = base64Data,
                ContentType = contentType
            };

            var json = System.Text.Json.JsonSerializer.Serialize(requestBody);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");

            var response = await httpClient.PostAsync("api/fileupload/base64-image", content);

            if (response.IsSuccessStatusCode)
            {
                var responseJson = await response.Content.ReadAsStringAsync();
                using var doc = System.Text.Json.JsonDocument.Parse(responseJson);
                
                if (doc.RootElement.TryGetProperty("url", out var urlElement))
                {
                    return urlElement.GetString();
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("[BlogEditor] Base64 image upload failed: {Status} - {Error}", 
                    response.StatusCode, error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[BlogEditor] Error uploading base64 image");
        }

        return null;
    }

    private async Task OnCoverImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null)
            return;

        // Validate
        const long maxSize = 5 * 1024 * 1024; // 5MB for cover images
        if (file.Size > maxSize)
        {
            Logger.LogWarning("[BlogEditor] Cover image too large: {Size} bytes", file.Size);
            return;
        }

        var validTypes = new[] { "image/jpeg", "image/png", "image/webp", "image/gif" };
        if (!validTypes.Contains(file.ContentType))
        {
            Logger.LogWarning("[BlogEditor] Invalid cover image type: {Type}", file.ContentType);
            return;
        }

        IsUploadingCover = true;
        StateHasChanged();

        try
        {
            // Read file and upload via API
            using var stream = file.OpenReadStream(maxSize);
            using var content = new MultipartFormDataContent();
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var fileContent = new StreamContent(memoryStream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            using var httpClient = new HttpClient();
            httpClient.BaseAddress = new Uri(NavigationManager.BaseUri);

            var response = await httpClient.PostAsync($"api/fileupload/upload?container=blog-covers", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<FileUploadResult>();
                if (result != null)
                {
                    CoverImageUrl = result.Url;
                    CoverImageFileId = result.FileId;
                    
                    await CoverImageUrlChanged.InvokeAsync(CoverImageUrl);
                    await CoverImageFileIdChanged.InvokeAsync(CoverImageFileId);
                    await OnCoverImageUploaded.InvokeAsync(result);

                    Logger.LogInformation("[BlogEditor] Cover image uploaded: {Url}", CoverImageUrl);
                }
            }
            else
            {
                Logger.LogError("[BlogEditor] Failed to upload cover image: {Status}", response.StatusCode);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[BlogEditor] Error uploading cover image");
        }
        finally
        {
            IsUploadingCover = false;
            StateHasChanged();
        }
    }

    private async Task RemoveCoverImage()
    {
        CoverImageUrl = string.Empty;
        CoverImageFileId = null;
        
        await CoverImageUrlChanged.InvokeAsync(CoverImageUrl);
        await CoverImageFileIdChanged.InvokeAsync(CoverImageFileId);
    }

    #endregion
}
