@using MudBlazor
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Enums
@using Sivar.Os.Shared.Clients
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ExceptionEditor> Localizer
@inject IResourceBookingsClient BookingsClient
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.EventBusy" />
            <MudText Typo="Typo.h6">@Localizer["ManageExceptions"]</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="exception-editor">
            @* Header with resource info *@
            <MudPaper Class="pa-3 mb-4" Elevation="0" Outlined="true">
                <div class="d-flex align-center gap-2">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">
                        <MudIcon Icon="@GetResourceIcon(Resource.ResourceType)" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.subtitle1">@Resource.Name</MudText>
                </div>
            </MudPaper>

            @* Tabs: Block Time | Special Hours *@
            <MudTabs Elevation="0" Rounded="true" PanelClass="pt-4" @bind-ActivePanelIndex="ActiveTab">
                <MudTabPanel Text="@Localizer["BlockedDates"]" Icon="@Icons.Material.Filled.Block">
                    @* Add Exception Button *@
                    <div class="d-flex justify-end mb-3">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddBlockedDate">
                            @Localizer["BlockDate"]
                        </MudButton>
                    </div>

                    @* Blocked Dates List *@
                    @if (IsLoading)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        </div>
                    }
                    else if (BlockedDates == null || !BlockedDates.Any())
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                            @Localizer["NoBlockedDates"]
                        </MudAlert>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true" Class="exceptions-table">
                            <thead>
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Reason"]</th>
                                    <th>@Localizer["Recurring"]</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var exception in BlockedDates.OrderBy(e => e.Date))
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Small" Color="Color.Error" />
                                                @exception.Date.ToString("ddd, MMM d, yyyy")
                                            </div>
                                        </td>
                                        <td>@(exception.Reason ?? "-")</td>
                                        <td>
                                            @if (exception.IsRecurringAnnually)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                                    @Localizer["Annual"]
                                                </MudChip>
                                            }
                                        </td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="() => DeleteException(exception)"
                                                           aria-label="Delete" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudTabPanel>
                
                <MudTabPanel Text="@Localizer["SpecialHours"]" Icon="@Icons.Material.Filled.AccessTime">
                    @* Add Special Hours Button *@
                    <div class="d-flex justify-end mb-3">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddSpecialHours">
                            @Localizer["AddSpecialHours"]
                        </MudButton>
                    </div>

                    @* Special Hours List *@
                    @if (IsLoading)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        </div>
                    }
                    else if (SpecialHours == null || !SpecialHours.Any())
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                            @Localizer["NoSpecialHours"]
                        </MudAlert>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true" Class="exceptions-table">
                            <thead>
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Hours"]</th>
                                    <th>@Localizer["Reason"]</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var exception in SpecialHours.OrderBy(e => e.Date))
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Warning" />
                                                @exception.Date.ToString("ddd, MMM d, yyyy")
                                            </div>
                                        </td>
                                        <td>@FormatTimeRange(exception.StartTime, exception.EndTime)</td>
                                        <td>@(exception.Reason ?? "-")</td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="() => DeleteException(exception)"
                                                           aria-label="Delete" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudTabPanel>
            </MudTabs>

            @* Add/Edit Form *@
            @if (ShowForm)
            {
                <MudPaper Class="pa-4 mt-4" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Class="mb-3">
                        @(IsAddingBlockedDate ? Localizer["BlockDate"] : Localizer["AddSpecialHours"])
                    </MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="FormDate"
                                           Label="@Localizer["Date"]"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           MinDate="DateTime.Today"
                                           Required="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="FormReason"
                                          Label="@Localizer["Reason"]"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="@Localizer["ReasonPlaceholder"]" />
                        </MudItem>
                        
                        @if (!IsAddingBlockedDate)
                        {
                            <MudItem xs="6">
                                <MudTimePicker @bind-Time="FormStartTime"
                                               Label="@Localizer["From"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Editable="true"
                                               AmPm="false" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTimePicker @bind-Time="FormEndTime"
                                               Label="@Localizer["To"]"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Editable="true"
                                               AmPm="false" />
                            </MudItem>
                        }
                        
                        <MudItem xs="12">
                            <MudCheckBox T="bool" @bind-Value="FormIsRecurring"
                                         Label="@Localizer["RecurAnnually"]"
                                         Color="Color.Primary" />
                        </MudItem>
                    </MudGrid>
                    <div class="d-flex justify-end gap-2 mt-3">
                        <MudButton Size="Size.Small" OnClick="CancelForm">
                            @Localizer["Cancel"]
                        </MudButton>
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="SaveException"
                                   Disabled="@(IsSaving || FormDate == null)">
                            @if (IsSaving)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                            }
                            @Localizer["Save"]
                        </MudButton>
                    </div>
                </MudPaper>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Close">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .exception-editor {
        min-width: 500px;
        max-width: 700px;
    }
    
    .exceptions-table {
        max-height: 250px;
        overflow-y: auto;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter]
    public BookableResourceSummaryDto Resource { get; set; } = null!;
    
    private List<ResourceExceptionDto>? Exceptions { get; set; }
    private IEnumerable<ResourceExceptionDto>? BlockedDates => Exceptions?.Where(e => !e.IsAvailable);
    private IEnumerable<ResourceExceptionDto>? SpecialHours => Exceptions?.Where(e => e.IsAvailable);
    
    private bool IsLoading { get; set; }
    private bool IsSaving { get; set; }
    private bool ShowForm { get; set; }
    private bool IsAddingBlockedDate { get; set; }
    private int ActiveTab { get; set; }
    
    // Form fields
    private DateTime? FormDate { get; set; }
    private string? FormReason { get; set; }
    private TimeSpan? FormStartTime { get; set; }
    private TimeSpan? FormEndTime { get; set; }
    private bool FormIsRecurring { get; set; }
    
    protected override async Task OnInitializedAsync()
    {
        await LoadExceptions();
    }
    
    private async Task LoadExceptions()
    {
        IsLoading = true;
        StateHasChanged();
        
        try
        {
            Exceptions = await BookingsClient.GetExceptionsAsync(Resource.Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["ErrorLoadingExceptions"], Severity.Error);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
    
    private void OpenAddBlockedDate()
    {
        IsAddingBlockedDate = true;
        ResetForm();
        ShowForm = true;
    }
    
    private void OpenAddSpecialHours()
    {
        IsAddingBlockedDate = false;
        ResetForm();
        FormStartTime = new TimeSpan(9, 0, 0);
        FormEndTime = new TimeSpan(17, 0, 0);
        ShowForm = true;
    }
    
    private void ResetForm()
    {
        FormDate = DateTime.Today;
        FormReason = null;
        FormStartTime = null;
        FormEndTime = null;
        FormIsRecurring = false;
    }
    
    private void CancelForm()
    {
        ShowForm = false;
    }
    
    private async Task SaveException()
    {
        if (FormDate == null) return;
        
        IsSaving = true;
        StateHasChanged();
        
        try
        {
            var createDto = new CreateResourceExceptionDto
            {
                Date = DateOnly.FromDateTime(FormDate.Value),
                IsAvailable = !IsAddingBlockedDate,
                StartTime = FormStartTime.HasValue ? TimeOnly.FromTimeSpan(FormStartTime.Value) : null,
                EndTime = FormEndTime.HasValue ? TimeOnly.FromTimeSpan(FormEndTime.Value) : null,
                Reason = FormReason,
                IsRecurringAnnually = FormIsRecurring
            };
            
            var result = await BookingsClient.AddExceptionAsync(Resource.Id, createDto);
            if (result != null)
            {
                Snackbar.Add(Localizer["ExceptionAdded"], Severity.Success);
                await LoadExceptions();
                ShowForm = false;
            }
            else
            {
                Snackbar.Add(Localizer["AddFailed"], Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["SaveError"], Severity.Error);
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }
    
    private async Task DeleteException(ResourceExceptionDto exception)
    {
        try
        {
            var result = await BookingsClient.DeleteExceptionAsync(exception.Id);
            if (result)
            {
                Snackbar.Add(Localizer["ExceptionDeleted"], Severity.Success);
                await LoadExceptions();
            }
            else
            {
                Snackbar.Add(Localizer["DeleteFailed"], Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["DeleteError"], Severity.Error);
        }
    }
    
    private string FormatTimeRange(TimeOnly? start, TimeOnly? end)
    {
        if (start == null || end == null) return "-";
        return $"{start.Value:HH:mm} - {end.Value:HH:mm}";
    }
    
    private string GetResourceIcon(ResourceType type) => type switch
    {
        ResourceType.Person => Icons.Material.Filled.Person,
        ResourceType.Space => Icons.Material.Filled.MeetingRoom,
        ResourceType.Equipment => Icons.Material.Filled.Handyman,
        ResourceType.Object => Icons.Material.Filled.TableRestaurant,
        _ => Icons.Material.Filled.Event
    };
    
    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
