@using Sivar.Os.Shared.DTOs

<MudCard Class="profile-search-card" Style="height: 100%;">
    <MudCardContent>
        <div class="d-flex flex-column align-center text-center" style="gap: 12px;">
            @* Avatar *@
            <MudAvatar Size="Size.Large" Style="width: 96px; height: 96px;">
                @if (!string.IsNullOrWhiteSpace(Profile.Avatar))
                {
                    <MudImage Src="@Profile.Avatar" Alt="@Profile.DisplayName" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                }
            </MudAvatar>

            @* Display Name *@
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 600; margin-bottom: 4px;">
                    @Profile.DisplayName
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @("@" + Profile.Handle)
                </MudText>
            </div>

            @* Bio Preview *@
            @if (!string.IsNullOrWhiteSpace(Profile.BioPreview))
            {
                <MudText Typo="Typo.body2" Class="text-truncate-2-lines" Style="min-height: 40px;">
                    @Profile.BioPreview
                </MudText>
            }
            else
            {
                <div style="min-height: 40px;"></div>
            }

            @* Metadata Icons *@
            <div class="d-flex justify-center flex-wrap" style="gap: 12px; margin-top: 4px;">
                @if (!string.IsNullOrWhiteSpace(Profile.LocationDisplay))
                {
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.LocationOn" Color="Color.Default" Variant="Variant.Text">
                        @Profile.LocationDisplay
                    </MudChip>
                }
                
                @if (Profile.ViewCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Visibility" Color="Color.Default" Variant="Variant.Text">
                        @Profile.ViewCount
                    </MudChip>
                }
            </div>
        </div>
    </MudCardContent>
    
    <MudCardActions Class="d-flex justify-center">
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   FullWidth="true"
                   Href="@($"/{Profile.Handle}")"
                   StartIcon="@Icons.Material.Filled.Person">
            View Profile
        </MudButton>
    </MudCardActions>
</MudCard>

<style>
    .profile-search-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .profile-search-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    }

    .text-truncate-2-lines {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.5;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public ProfileSummaryDto Profile { get; set; } = null!;
}
