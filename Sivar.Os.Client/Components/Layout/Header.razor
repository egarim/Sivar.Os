@using MudBlazor
@using Microsoft.Extensions.Logging
@inject ILogger<Header> Logger

@* Header component for the wireframe landing page *@

<div class="header">
    <div class="logo">Sivar Social</div>
    <div class="user-info">
        <div class="user-details">
            @if (IsLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Height="16px" Class="mb-2" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="14px" />
            }
            else
            {
                <div class="user-name">@UserName</div>
                <div class="user-email">@UserEmail</div>
            }
        </div>
        @if (IsLoading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
        }
        else
        {
            <div class="user-avatar">@UserInitials</div>
        }
        
        <LanguageSelector />
        
        @if (ShowThemeToggle)
        {
            <MudIconButton Icon="@ThemeIcon" 
                           Color="Color.Inherit" 
                           OnClick="@OnThemeToggle"
                           Title="Toggle theme" />
        }
        
        @if (ShowLogout)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Logout" 
                           Color="Color.Inherit" 
                           OnClick="@OnLogout"
                           Title="Logout" />
        }
    </div>
</div>

@code {
    /// <summary>
    /// User's display name
    /// </summary>
    [Parameter]
    public string UserName { get; set; } = "Jordan Doe";

    /// <summary>
    /// Callback when user name changes
    /// </summary>
    [Parameter]
    public EventCallback<string> UserNameChanged { get; set; }

    /// <summary>
    /// User's email address
    /// </summary>
    [Parameter]
    public string UserEmail { get; set; } = "jordan.doe@example.com";

    /// <summary>
    /// Callback when user email changes
    /// </summary>
    [Parameter]
    public EventCallback<string> UserEmailChanged { get; set; }

    /// <summary>
    /// User's initials for avatar
    /// </summary>
    [Parameter]
    public string UserInitials { get; set; } = "JD";

    /// <summary>
    /// Whether the user data is still loading
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; } = true;

    /// <summary>
    /// Show theme toggle button
    /// </summary>
    [Parameter]
    public bool ShowThemeToggle { get; set; } = false;

    /// <summary>
    /// Show logout button
    /// </summary>
    [Parameter]
    public bool ShowLogout { get; set; } = false;

    /// <summary>
    /// Icon for theme toggle button
    /// </summary>
    [Parameter]
    public string ThemeIcon { get; set; } = Icons.Material.Outlined.DarkMode;

    /// <summary>
    /// Callback when theme toggle is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnThemeToggle { get; set; }

    /// <summary>
    /// Callback when logout is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnLogout { get; set; }

    protected override void OnInitialized()
    {
        Logger.LogInformation("[Header] Component initialized - UserName: {UserName}, IsLoading: {IsLoading}", UserName, IsLoading);
    }

    protected override void OnParametersSet()
    {
        Logger.LogDebug("[Header] Parameters set - UserName: {UserName}, UserEmail: {UserEmail}, IsLoading: {IsLoading}", 
            UserName, UserEmail, IsLoading);
    }
}
