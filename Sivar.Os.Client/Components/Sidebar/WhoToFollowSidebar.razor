@using Sivar.Os.Client.Pages
@using Sivar.Os.Shared.DTOs
@using Microsoft.Extensions.Logging
@inject ILogger<WhoToFollowSidebar> Logger

@* WhoToFollowSidebar component for displaying user suggestions *@

<aside class="sidebar">
    <div class="sidebar-header">
        <h3>Who to follow</h3>
        <p class="sidebar-subtitle">Curated for @ProfileTypeTitle</p>
    </div>
    @foreach (var user in SuggestedUsers)
    {
        <UserCard 
            ProfileId="@user.Id"
            Name="@user.DisplayName"
            Bio="@user.Bio"
            Initials="@GetInitials(user.DisplayName)"
            OnFollowToggle="@(() => OnFollowToggle.InvokeAsync(user))"
            OnNameClick="@(() => OnUserNameClick.InvokeAsync(user.Handle ?? string.Empty))" />
    }
    <div class="sidebar-footnote">Suggestions refresh daily based on activity.</div>
</aside>

@code {
    /// <summary>
    /// List of suggested users to display
    /// </summary>
    [Parameter]
    public List<ProfileDto> SuggestedUsers { get; set; } = new();

    /// <summary>
    /// Profile type title for customization message
    /// </summary>
    [Parameter]
    public string ProfileTypeTitle { get; set; } = "Personal Profile";

    /// <summary>
    /// Callback when follow button is toggled
    /// </summary>
    [Parameter]
    public EventCallback<ProfileDto> OnFollowToggle { get; set; }

    /// <summary>
    /// Callback when user name is clicked
    /// </summary>
    [Parameter]
    public EventCallback<string> OnUserNameClick { get; set; }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        return string.Join(string.Empty, name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(p => char.ToUpperInvariant(p[0])));
    }

    protected override void OnParametersSet()
    {
        Logger.LogDebug("[WhoToFollowSidebar] Parameters set - SuggestedUsers count: {Count}, ProfileTypeTitle: {ProfileType}", 
            SuggestedUsers?.Count ?? 0, ProfileTypeTitle);
    }

    protected override void OnInitialized()
    {
        Logger.LogInformation("[WhoToFollowSidebar] Component initialized - ProfileTypeTitle: {ProfileType}", ProfileTypeTitle);
    }
}
