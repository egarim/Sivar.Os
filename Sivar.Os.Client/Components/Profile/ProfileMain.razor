@using Sivar.Os.Client.Pages
@using Microsoft.Extensions.Localization
@using MudBlazor
@inject IStringLocalizer<ProfileMain> Localizer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="profile-main">
    <MudAvatar Size="Size.Large" Class="profile-avatar" Style="width: 72px; height: 72px; font-size: 28px;">
        @Initials
    </MudAvatar>
    <div class="profile-details">
        <MudText Typo="Typo.h6" Class="profile-name">@DisplayName</MudText>
        <MudText Typo="Typo.body2" Class="profile-username">@("@" + Username)</MudText>
        <ProfileStats Stats="@Stats" />
        @if (ShowActions)
        {
            <ProfileActions 
                FollowButtonText="@FollowButtonText"
                OnFollowClick="OnFollowClick"
                OnMessageClick="OnMessageClick" />
        }
        @if (ShowEditButton)
        {
            <div class="profile-edit-actions">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Default" 
                           StartIcon="@Icons.Material.Filled.Settings"
                           Size="Size.Small"
                           OnClick="NavigateToSettings"
                           Class="edit-profile-btn">
                    @Localizer["EditProfile"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Default" 
                           StartIcon="@Icons.Material.Filled.Share"
                           Size="Size.Small"
                           OnClick="ShareProfile"
                           Class="share-profile-btn">
                    @Localizer["Share"]
                </MudButton>
            </div>
        }
    </div>
</div>

<style>
    .profile-edit-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
    }

    .edit-profile-btn, .share-profile-btn {
        font-size: 13px;
        text-transform: none;
        border-radius: 20px;
        padding: 6px 16px;
    }

    .edit-profile-btn:hover, .share-profile-btn:hover {
        background: var(--mud-palette-action-default-hover);
    }
</style>

@code {
    [Parameter]
    public string DisplayName { get; set; } = string.Empty;

    [Parameter]
    public string Username { get; set; } = string.Empty;

    [Parameter]
    public string Initials { get; set; } = string.Empty;

    [Parameter]
    public Sivar.Os.Client.Pages.ProfileStats Stats { get; set; } = new();

    [Parameter]
    public string FollowButtonText { get; set; } = string.Empty;

    [Parameter]
    public bool ShowActions { get; set; } = true;

    [Parameter]
    public bool ShowEditButton { get; set; } = false;

    [Parameter]
    public EventCallback OnFollowClick { get; set; }

    [Parameter]
    public EventCallback OnMessageClick { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(FollowButtonText))
        {
            FollowButtonText = Localizer["DefaultFollowText"];
        }
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo("/app/profile/settings");
    }

    private async Task ShareProfile()
    {
        var profileUrl = NavigationManager.Uri;
        var shareData = new
        {
            title = DisplayName,
            text = $"Check out {DisplayName}'s profile",
            url = profileUrl
        };

        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.share", shareData);
        }
        catch
        {
            // Fallback: copy to clipboard if Web Share API not available
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", profileUrl);
        }
    }
}
