@using Sivar.Os.Client.Pages
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProfileMain> Localizer

<div class="profile-main">
    <MudAvatar Size="Size.Large" Class="profile-avatar" Style="width: 72px; height: 72px; font-size: 28px;">
        @Initials
    </MudAvatar>
    <div class="profile-details">
        <MudText Typo="Typo.h6" Class="profile-name">@DisplayName</MudText>
        <MudText Typo="Typo.body2" Class="profile-username">@("@" + Username)</MudText>
        <ProfileStats Stats="@Stats" />
        @if (ShowActions)
        {
            <ProfileActions 
                FollowButtonText="@FollowButtonText"
                OnFollowClick="OnFollowClick"
                OnMessageClick="OnMessageClick" />
        }
    </div>
</div>

@code {
    [Parameter]
    public string DisplayName { get; set; } = string.Empty;

    [Parameter]
    public string Username { get; set; } = string.Empty;

    [Parameter]
    public string Initials { get; set; } = string.Empty;

    [Parameter]
    public Sivar.Os.Client.Pages.ProfileStats Stats { get; set; } = new();

    [Parameter]
    public string FollowButtonText { get; set; } = string.Empty;

    [Parameter]
    public bool ShowActions { get; set; } = true;

    [Parameter]
    public EventCallback OnFollowClick { get; set; }

    [Parameter]
    public EventCallback OnMessageClick { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(FollowButtonText))
        {
            FollowButtonText = Localizer["DefaultFollowText"];
        }
    }
}
