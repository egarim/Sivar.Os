@using Sivar.Os.Client.Services
@using Sivar.Os.Shared.DTOs.ValueObjects
@using Sivar.Os.Shared.Services
@using MudBlazor
@using Microsoft.Extensions.Localization
@inject BrowserPermissionsService PermissionsService
@inject ILocationService LocationService
@inject IStringLocalizer<ProfileLocationEditor> Localizer
@inject ILogger<ProfileLocationEditor> Logger

<MudCard Class="profile-location-editor">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="mr-2" />
                @Localizer["LocationTitle"]
            </MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            @if (ShowGpsButton)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.MyLocation"
                           OnClick="UseGpsLocationAsync"
                           Disabled="@isLoading"
                           Size="Size.Small">
                    @(isLoading ? Localizer["GettingLocation"] : Localizer["UseGPS"])
                </MudButton>
            }
        </CardHeaderActions>
    </MudCardHeader>
    
    <MudCardContent>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true" CloseIcon="@Icons.Material.Filled.Close" CloseIconClicked="@(() => errorMessage = null)">
                @errorMessage
            </MudAlert>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true" CloseIcon="@Icons.Material.Filled.Close" CloseIconClicked="@(() => successMessage = null)">
                @successMessage
            </MudAlert>
        }

        <MudStack Spacing="3">
            <!-- Manual Entry Section -->
            <MudTextField Value="@_city"
                          ValueChanged="@(async (string value) => { _city = value; if (OnCityChanged.HasDelegate) await OnCityChanged.InvokeAsync(value); })"
                          Label="@Localizer["CityLabel"]"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.LocationCity"
                          Disabled="@isLoading" />

            <MudTextField Value="@_state"
                          ValueChanged="@(async (string value) => { _state = value; if (OnStateChanged.HasDelegate) await OnStateChanged.InvokeAsync(value); })"
                          Label="@Localizer["StateLabel"]"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Map"
                          Disabled="@isLoading" />

            <MudTextField Value="@_country"
                          ValueChanged="@(async (string value) => { _country = value; if (OnCountryChanged.HasDelegate) await OnCountryChanged.InvokeAsync(value); })"
                          Label="@Localizer["CountryLabel"]"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Public"
                          Disabled="@isLoading" />

            <!-- GPS Coordinates Display (Optional) -->
            @if (Latitude.HasValue && Longitude.HasValue)
            {
                <MudPaper Elevation="0" Class="pa-3" Style="background-color: var(--mud-palette-background-grey);">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            <MudIcon Icon="@Icons.Material.Filled.GpsFixed" Size="Size.Small" Class="mr-1" />
                            @Localizer["GPSCoordinates"]
                        </MudText>
                        <MudText Typo="Typo.body2">
                            📍 @Latitude.Value.ToString("F6"), @Longitude.Value.ToString("F6")
                        </MudText>
                    </MudStack>
                </MudPaper>
            }

            <!-- Permission Status Info -->
            @if (ShowPermissionStatus && permissionStatus != PermissionStatus.Unknown)
            {
                <MudChip T="string" 
                         Size="Size.Small" 
                         Color="@GetPermissionColor(permissionStatus)"
                         Icon="@GetPermissionIcon(permissionStatus)">
                    @Localizer["GPSPrefix"] @GetPermissionText(permissionStatus)
                </MudChip>
            }
        </MudStack>
    </MudCardContent>

    @if (ShowActions)
    {
        <MudCardActions>
            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="OnCancel">@Localizer["Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnSave" Disabled="@isLoading">
                @(isLoading ? Localizer["Saving"] : Localizer["SaveLocation"])
            </MudButton>
        </MudCardActions>
    }
</MudCard>

<style>
    .profile-location-editor {
        margin-bottom: 16px;
    }
</style>

@code {
    // Private fields for internal state
    private string _city = string.Empty;
    private string _state = string.Empty;
    private string _country = string.Empty;
    
    // One-way input parameters (from parent)
    [Parameter]
    public string City 
    { 
        get => _city;
        set => _city = value;
    }

    [Parameter]
    public string State 
    { 
        get => _state;
        set => _state = value;
    }

    [Parameter]
    public string Country 
    { 
        get => _country;
        set => _country = value;
    }
    
    // Output event callbacks (to parent)
    [Parameter]
    public EventCallback<string> OnCityChanged { get; set; }
    
    [Parameter]
    public EventCallback<string> OnStateChanged { get; set; }
    
    [Parameter]
    public EventCallback<string> OnCountryChanged { get; set; }

    [Parameter]
    public double? Latitude { get; set; }
    
    [Parameter]
    public EventCallback<double?> OnLatitudeChanged { get; set; }

    [Parameter]
    public double? Longitude { get; set; }
    
    [Parameter]
    public EventCallback<double?> OnLongitudeChanged { get; set; }

    // Configuration parameters
    [Parameter]
    public bool ShowGpsButton { get; set; } = true;

    [Parameter]
    public bool ShowPermissionStatus { get; set; } = false;

    [Parameter]
    public bool ShowActions { get; set; } = false;

    // Callbacks
    [Parameter]
    public EventCallback OnSaveClicked { get; set; }

    [Parameter]
    public EventCallback OnCancelClicked { get; set; }

    [Parameter]
    public EventCallback<GeolocationPosition> OnGpsLocationReceived { get; set; }

    // State
    private bool isLoading = false;
    private string? errorMessage = null;
    private string? successMessage = null;
    private PermissionStatus permissionStatus = PermissionStatus.Unknown;

    protected override async Task OnInitializedAsync()
    {
        // Check GPS permission status on load
        if (ShowPermissionStatus)
        {
            try
            {
                permissionStatus = await PermissionsService.GetLocationPermissionStatusAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to check GPS permission status");
            }
        }
    }

    private async Task UseGpsLocationAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            Logger.LogInformation("[ProfileLocationEditor] Requesting GPS location");

            // Check if geolocation is supported
            var isSupported = await PermissionsService.IsGeolocationSupportedAsync();
            if (!isSupported)
            {
                errorMessage = Localizer["ErrorNotSupported"];
                Logger.LogWarning("[ProfileLocationEditor] Geolocation not supported");
                return;
            }

            // Request location from browser
            var position = await PermissionsService.RequestLocationAsync();

            if (position == null)
            {
                errorMessage = Localizer["ErrorPermissionDenied"];
                Logger.LogWarning("[ProfileLocationEditor] GPS permission denied or error occurred");
                permissionStatus = PermissionStatus.Denied;
                return;
            }

            Logger.LogInformation("[ProfileLocationEditor] GPS location received - Lat: {Lat}, Lng: {Lng}, Accuracy: {Accuracy}m",
                position.Latitude, position.Longitude, position.Accuracy);

            // Store coordinates in local variables
            var newLatitude = position.Latitude;
            var newLongitude = position.Longitude;
            permissionStatus = PermissionStatus.Granted;

            // Notify parent with local variables (don't assign to properties yet)
            if (OnLatitudeChanged.HasDelegate) await OnLatitudeChanged.InvokeAsync(newLatitude);
            if (OnLongitudeChanged.HasDelegate) await OnLongitudeChanged.InvokeAsync(newLongitude);

            // Attempt reverse geocoding to populate city/state/country
            try
            {
                Logger.LogInformation("[ProfileLocationEditor] Starting reverse geocoding for coordinates");
                
                var location = await LocationService.ReverseGeocodeAsync(position.Latitude, position.Longitude);
                
                if (location != null)
                {
                    // Use local variables - do NOT assign to properties to avoid triggering parent updates
                    var newCity = location.City ?? string.Empty;
                    var newState = location.State ?? string.Empty;
                    var newCountry = location.Country ?? string.Empty;

                    // Update success message using local variables
                    successMessage = string.Format(Localizer["SuccessWithAddress"], newCity, newState, newCountry, position.Accuracy);

                    Logger.LogInformation("[ProfileLocationEditor] Reverse geocoding successful - City='{City}', State='{State}', Country='{Country}'",
                        newCity, newState, newCountry);

                    // Notify parent component using local variables (unidirectional data flow)
                    if (OnCityChanged.HasDelegate) await OnCityChanged.InvokeAsync(newCity);
                    if (OnStateChanged.HasDelegate) await OnStateChanged.InvokeAsync(newState);
                    if (OnCountryChanged.HasDelegate) await OnCountryChanged.InvokeAsync(newCountry);
                }
                else
                {
                    Logger.LogWarning("[ProfileLocationEditor] Reverse geocoding returned no results");
                    successMessage = string.Format(Localizer["SuccessManualEntry"], position.Accuracy);
                }
            }
            catch (Exception reverseEx)
            {
                Logger.LogError(reverseEx, "[ProfileLocationEditor] Reverse geocoding failed");
                successMessage = string.Format(Localizer["SuccessGeocodeError"], position.Accuracy);
            }

            // Force another UI update after all changes
            StateHasChanged();

            // Invoke callback if provided
            if (OnGpsLocationReceived.HasDelegate)
            {
                await OnGpsLocationReceived.InvokeAsync(position);
            }

            Logger.LogInformation("[ProfileLocationEditor] GPS location successfully acquired");
        }
        catch (Exception ex)
        {
            errorMessage = string.Format(Localizer["ErrorGettingLocation"], ex.Message);
            Logger.LogError(ex, "[ProfileLocationEditor] Error getting GPS location");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnSave()
    {
        if (OnSaveClicked.HasDelegate)
        {
            await OnSaveClicked.InvokeAsync();
        }
    }

    private async Task OnCancel()
    {
        if (OnCancelClicked.HasDelegate)
        {
            await OnCancelClicked.InvokeAsync();
        }
    }

    private Color GetPermissionColor(PermissionStatus status)
    {
        return status switch
        {
            PermissionStatus.Granted => Color.Success,
            PermissionStatus.Denied => Color.Error,
            PermissionStatus.Prompt => Color.Warning,
            _ => Color.Default
        };
    }

    private string GetPermissionIcon(PermissionStatus status)
    {
        return status switch
        {
            PermissionStatus.Granted => Icons.Material.Filled.CheckCircle,
            PermissionStatus.Denied => Icons.Material.Filled.Block,
            PermissionStatus.Prompt => Icons.Material.Filled.Help,
            _ => Icons.Material.Filled.QuestionMark
        };
    }

    private string GetPermissionText(PermissionStatus status)
    {
        return status switch
        {
            PermissionStatus.Granted => Localizer["StatusEnabled"],
            PermissionStatus.Denied => Localizer["StatusBlocked"],
            PermissionStatus.Prompt => Localizer["StatusNotRequested"],
            _ => Localizer["StatusUnknown"]
        };
    }
}
