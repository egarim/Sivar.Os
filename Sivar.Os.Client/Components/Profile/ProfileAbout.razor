@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProfileAbout> Localizer

<div class="profile-section">
    <MudText Typo="Typo.h6" Class="profile-section-title">@Localizer["SectionTitle"]</MudText>
    <MudText Typo="Typo.body1" Class="profile-bio">
        @Bio
    </MudText>
</div>

@code {
    [Parameter]
    public string Bio { get; set; } = string.Empty;
}
