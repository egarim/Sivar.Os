@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProfileAbout> Localizer

<div class="profile-section">
    <h6 class="profile-section-title">@Localizer["SectionTitle"]</h6>
    <p class="profile-bio">@Bio</p>
</div>

<style>
    .profile-section-title {
        font-size: 13px;
        font-weight: 600;
        margin: 0 0 6px 0;
        color: var(--mud-palette-text-primary);
    }

    .profile-bio {
        font-size: 13px;
        line-height: 1.5;
        color: var(--mud-palette-text-secondary);
        margin: 0;
    }
</style>

@code {
    [Parameter]
    public string Bio { get; set; } = string.Empty;
}
