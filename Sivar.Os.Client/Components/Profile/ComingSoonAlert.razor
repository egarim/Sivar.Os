@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ComingSoonAlert> Localizer

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="coming-soon-card">
    <div class="coming-soon-header">
        <MudIcon Icon="@Icons.Material.Filled.Rocket" Class="coming-soon-icon" />
        <MudText Typo="Typo.subtitle1" Class="coming-soon-text">@Title</MudText>
    </div>
    <MudText Typo="Typo.body2" Class="coming-soon-subtext">
        @Message
    </MudText>
</MudAlert>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Message { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        // Set default localized values if parameters are not provided
        if (string.IsNullOrEmpty(Title))
        {
            Title = Localizer["DefaultTitle"];
        }
        if (string.IsNullOrEmpty(Message))
        {
            Message = Localizer["DefaultMessage"];
        }
    }
}
