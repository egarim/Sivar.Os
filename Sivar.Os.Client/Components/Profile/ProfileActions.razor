<div class="profile-actions">
    <MudButton Variant="Variant.Filled" 
               Color="Color.Primary" 
               StartIcon="@Icons.Material.Filled.PersonAdd"
               Class="action-button primary"
               OnClick="HandleFollowClick">
        @FollowButtonText
    </MudButton>
    <MudButton Variant="Variant.Outlined" 
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.Message"
               Class="action-button secondary"
               OnClick="HandleMessageClick">
        Message
    </MudButton>
</div>

@code {
    [Parameter]
    public string FollowButtonText { get; set; } = "Follow";

    [Parameter]
    public EventCallback OnFollowClick { get; set; }

    [Parameter]
    public EventCallback OnMessageClick { get; set; }

    private async Task HandleFollowClick()
    {
        await OnFollowClick.InvokeAsync();
    }

    private async Task HandleMessageClick()
    {
        await OnMessageClick.InvokeAsync();
    }
}
