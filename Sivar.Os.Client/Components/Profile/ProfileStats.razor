@using Sivar.Os.Client.Pages
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProfileStats> Localizer

<div class="profile-stats">
    <div class="stat">
        <MudText Typo="Typo.h5" Class="stat-value">@Stats.Posts</MudText>
        <MudText Typo="Typo.body2" Class="stat-label">@Localizer["PostsLabel"]</MudText>
    </div>
    <div class="stat">
        <MudText Typo="Typo.h5" Class="stat-value">@Stats.Followers</MudText>
        <MudText Typo="Typo.body2" Class="stat-label">@Localizer["FollowersLabel"]</MudText>
    </div>
    <div class="stat">
        <MudText Typo="Typo.h5" Class="stat-value">@Stats.Following</MudText>
        <MudText Typo="Typo.body2" Class="stat-label">@Localizer["FollowingLabel"]</MudText>
    </div>
</div>

@code {
    [Parameter]
    public Sivar.Os.Client.Pages.ProfileStats Stats { get; set; } = new();
}
