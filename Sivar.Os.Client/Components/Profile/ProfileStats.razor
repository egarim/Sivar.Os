@using Sivar.Os.Client.Pages
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProfileStats> Localizer

<div class="profile-stats">
    <div class="stat">
        <span class="stat-value">@Stats.Posts</span>
        <span class="stat-label">@Localizer["PostsLabel"]</span>
    </div>
    <div class="stat">
        <span class="stat-value">@Stats.Followers</span>
        <span class="stat-label">@Localizer["FollowersLabel"]</span>
    </div>
    <div class="stat">
        <span class="stat-value">@Stats.Following</span>
        <span class="stat-label">@Localizer["FollowingLabel"]</span>
    </div>
</div>

<style>
    .profile-stats {
        display: flex;
        gap: 24px;
        margin-top: 12px;
    }

    .stat {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .stat-value {
        font-size: 16px;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
        line-height: 1.2;
    }

    .stat-label {
        font-size: 12px;
        color: var(--mud-palette-text-secondary);
        margin-top: 2px;
    }
</style>

@code {
    [Parameter]
    public Sivar.Os.Client.Pages.ProfileStats Stats { get; set; } = new();
}
