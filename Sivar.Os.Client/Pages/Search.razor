@page "/search"
@using Microsoft.Extensions.Localization
@using Sivar.Os.Shared.Clients
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Services
@using Sivar.Os.Client.Components.Search
@inject IStringLocalizer<Search> Localizer
@inject IProfilesClient ProfilesClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="search-page-container">
    @* Search Header - Using MudPaper for proper theme support *@
    <MudPaper Elevation="0" Class="search-header pa-3 mb-4 rounded-lg">
        <div class="search-input-wrapper d-flex align-center gap-2">
            <MudTextField @bind-Value="_searchQuery"
                          Label="@Localizer["SearchLabel"]"
                          Placeholder="@Localizer["SearchPlaceholder"]"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnKeyUp="HandleKeyPress"
                          Immediate="true"
                          Margin="Margin.Dense"
                          Class="flex-grow-1" />
            
            @if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                <MudIconButton Icon="@Icons.Material.Filled.Clear" 
                               Color="Color.Secondary"
                               Size="Size.Small"
                               OnClick="ClearSearch"
                               Title="@Localizer["ClearSearch"]" />
            }
            
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="PerformSearch"
                       Disabled="_isSearching">
                @Localizer["SearchButton"]
            </MudButton>
        </div>
    </MudPaper>

    @* Results Section *@
    @if (_isSearching)
    {
        @* Loading State *@
        <div class="search-loading">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
            <span class="search-loading-text">@Localizer["SearchingMessage"]</span>
        </div>
    }
    else if (_hasSearched && _searchResults != null)
    {
        @* Search Results *@
        @if (_searchResults.Any())
        {
            @* Results Count *@
            <div class="search-results-header">
                <span class="results-count">
                    @string.Format(Localizer["ResultsCount"], _searchResults.Count())
                </span>
                
                <div class="view-toggle">
                    <MudToggleIconButton @bind-Toggled="_isGridView"
                                         Icon="@Icons.Material.Filled.ViewModule"
                                         ToggledIcon="@Icons.Material.Filled.ViewList"
                                         Size="Size.Small"
                                         Title="@(_isGridView ? Localizer["ListView"] : Localizer["GridView"])" />
                </div>
            </div>

            @* Results Grid/List *@
            @if (_isGridView)
            {
                <div class="search-results-grid">
                    @foreach (var profile in _searchResults)
                    {
                        <ProfileSearchCard Profile="profile" />
                    }
                </div>
            }
            else
            {
                <div class="search-results-list">
                    @foreach (var profile in _searchResults)
                    {
                        <ProfileSearchCard Profile="profile" />
                    }
                </div>
            }
        }
        else
        {
            @* No Results *@
            <div class="search-empty-state">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="empty-icon" />
                <h3 class="empty-title">@Localizer["NoResults"]</h3>
                <p class="empty-description">@Localizer["NoResultsDescription"]</p>
            </div>
        }
    }
    else
    {
        @* Empty State - Show Quick Links *@
        <div class="search-empty-state">
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="empty-icon primary" />
            <h3 class="empty-title">@Localizer["EmptySearchTitle"]</h3>
            <p class="empty-description">@Localizer["EmptySearchDescription"]</p>
            
            @* Quick Links *@
            <div class="quick-links">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.TrendingUp"
                           OnClick="LoadPopularProfiles">
                    @Localizer["PopularProfiles"]
                </MudButton>
                
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.NewReleases"
                           OnClick="LoadRecentProfiles">
                    @Localizer["RecentProfiles"]
                </MudButton>
            </div>
        </div>
    }
</MudContainer>

<style>
    /* Search Page Container */
    .search-page-container {
        padding: 16px 24px;
        max-width: 680px !important;
    }

    /* Search Header - Using MudPaper for theme support */
    .search-header {
        border: 1px solid var(--mud-palette-lines-default);
    }

    /* Loading State */
    .search-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 200px;
        gap: 12px;
    }

    .search-loading-text {
        font-size: 14px;
        color: var(--mud-palette-text-secondary);
    }

    /* Results Header */
    .search-results-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        padding: 0 4px;
    }

    .results-count {
        font-size: 14px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
    }

    /* Results Grid */
    .search-results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
    }

    /* Results List */
    .search-results-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    /* Empty State */
    .search-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 250px;
        padding: 24px;
    }

    .empty-icon {
        font-size: 48px !important;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 12px;
    }

    .empty-icon.primary {
        color: var(--mud-palette-primary);
    }

    .empty-title {
        font-size: 18px;
        font-weight: 600;
        margin: 0 0 8px 0;
        color: var(--mud-palette-text-primary);
    }

    .empty-description {
        font-size: 13px;
        color: var(--mud-palette-text-secondary);
        margin: 0 0 16px 0;
    }

    .quick-links {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: center;
    }

    /* Responsive */
    @@media (max-width: 600px) {
        .search-page-container {
            padding: 12px 16px;
        }

        .search-results-grid {
            grid-template-columns: 1fr;
        }

        .quick-links {
            flex-direction: column;
        }

        .quick-links .mud-button-root {
            width: 100%;
        }
    }
</style>

@code {
    private string _searchQuery = string.Empty;
    private IEnumerable<ProfileSummaryDto>? _searchResults;
    private bool _isSearching = false;
    private bool _hasSearched = false;
    private bool _isGridView = true;
    private System.Threading.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        // Check if there's a query parameter in the URL
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var searchParam = query["q"];
        
        if (!string.IsNullOrWhiteSpace(searchParam))
        {
            _searchQuery = searchParam;
            await PerformSearch();
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _debounceTimer?.Dispose();
            _ = PerformSearch();
        }
        else
        {
            // Debounce search - wait 300ms after last keystroke
            _debounceTimer?.Dispose();
            _debounceTimer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(async () =>
                {
                    if (!string.IsNullOrWhiteSpace(_searchQuery))
                    {
                        await PerformSearch();
                    }
                });
            }, null, 300, Timeout.Infinite);
        }
    }

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Length < 2)
        {
            return;
        }

        _isSearching = true;
        StateHasChanged();

        try
        {
            // Update URL with search query
            Navigation.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery)}", false);
            
            // Search profiles using the search term
            _searchResults = await ProfilesClient.SearchProfilesAsync(_searchQuery, pageSize: 20, pageNumber: 1);
            _hasSearched = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["ErrorSearchingProfiles"], Severity.Error);
            Console.WriteLine($"[Search] Error: {ex.Message}");
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private async Task LoadPopularProfiles()
    {
        _isSearching = true;
        StateHasChanged();

        try
        {
            _searchResults = await ProfilesClient.GetPopularProfilesAsync(limit: 12);
            _hasSearched = true;
            _searchQuery = Localizer["PopularProfiles"];
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["ErrorLoadingProfiles"], Severity.Error);
            Console.WriteLine($"[Search] Error loading popular profiles: {ex.Message}");
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private async Task LoadRecentProfiles()
    {
        _isSearching = true;
        StateHasChanged();

        try
        {
            _searchResults = await ProfilesClient.GetRecentProfilesAsync(limit: 12);
            _hasSearched = true;
            _searchQuery = Localizer["RecentProfiles"];
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["ErrorLoadingProfiles"], Severity.Error);
            Console.WriteLine($"[Search] Error loading recent profiles: {ex.Message}");
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private void ClearSearch()
    {
        _searchQuery = string.Empty;
        _searchResults = null;
        _hasSearched = false;
        Navigation.NavigateTo("/search", false);
        StateHasChanged();
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
