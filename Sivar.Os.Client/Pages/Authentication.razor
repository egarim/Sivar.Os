@page "/authentication/{action}"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject IStringLocalizer<Authentication> Localizer

<div style="display: flex; align-items: center; justify-content: center; min-height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div style="text-align: center; color: white;">
        <div style="font-size: 48px; margin-bottom: 16px;">🔐</div>
        <div style="font-size: 24px; font-weight: 600; margin-bottom: 8px;">@GetMessage()</div>
        <div style="font-size: 16px; opacity: 0.9;">@Localizer["PleaseWait"]</div>
    </div>
</div>

@code {
    [Parameter]
    public string? Action { get; set; }

    private string GetMessage()
    {
        return Action?.ToLower() switch
        {
            "login" => Localizer["RedirectingToLogin"],
            "register" => Localizer["RedirectingToRegistration"],
            "logout" => Localizer["LoggingOut"],
            "logged-out" => Localizer["LoggedOut"],
            "login-callback" => Localizer["CompletingLogin"],
            "login-failed" => Localizer["LoginFailed"],
            _ => Localizer["Authenticating"]
        };
    }
}
