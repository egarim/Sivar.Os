            width: 100% !important;
        }
        
        .wireframe-landing .chat-history-sidebar {
            width: 240px;
        }
    }
    
    /* Extra small devices (phones in portrait) */
    @@media (max-width: 480px) {
        .wireframe-landing .header {
            padding: 10px;
        }
        
        .wireframe-landing .logo {
            font-size: 16px;
        }
        
        .wireframe-landing .feed {
            padding: 8px;
        }
        
        .wireframe-landing .post-composer {
            padding: 10px;
        }
        
        .wireframe-landing .composer-title h3 {
            font-size: 13px;
        }
        
        .wireframe-landing .post-type-selector {
            gap: 3px;
        }
        
        .wireframe-landing .post-type-option {
            padding: 5px 8px;
            font-size: 10px;
        }
        
        .wireframe-landing .post-input {
            padding: 8px;
            font-size: 13px;
        }
        
        .wireframe-landing .post-card {
            padding: 10px;
        }
        
        .wireframe-landing .post-avatar {
            width: 32px;
            height: 32px;
            font-size: 13px;
        }
        
        .wireframe-landing .post-metadata {
            padding: 6px 8px;
            font-size: 10px;
        }
        
        .wireframe-landing .action-btn {
            padding: 5px 6px;
            font-size: 11px;
        }
        
        .wireframe-landing .chat-history-sidebar {
            width: 180px;
        }
        
        .wireframe-landing .chat-history-sidebar.active {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            z-index: 10;
            box-shadow: 2px 0 8px rgba(0,0,0,0.2);
        }
    }
    
    /* Container adjustments for mobile */
    @@media (max-width: 768px) {
        .wireframe-landing .wire-container {
            padding: 0 !important;
        }
        
        .wireframe-landing .main-layout {
            width: 100%;
            max-width: 100%;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.False" Class="wire-container wireframe-landing">
    <div class="header">
        <div class="logo">Sivar Social</div>
        <div class="header-center">
            <span class="profile-type-label">Profile type</span>
            <select class="profile-type-switcher" @bind="_profileType">
                <option value="personal">Personal profile</option>
                <option value="business">Business page</option>
                <option value="product">Product showcase</option>
            </select>
        </div>
        <div class="user-info">
            <div class="user-details">
                <div class="user-name">Jordan Doe</div>
                <div class="user-email">jordan.doe@example.com</div>
            </div>
            <div class="user-avatar">JD</div>
        </div>
    </div>

    <div class="main-layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h3>Who to follow</h3>
                <p class="sidebar-subtitle">Curated for @_profileTypeTitle</p>
            </div>
            @foreach (var user in _suggestedUsers)
            {
                <div class="user-card @(user.IsFollowing ? "following" : string.Empty)">
                    <div class="small-avatar">@user.Initials</div>
                    <div class="user-card-info">
                        <div class="user-card-name clickable">@user.Name</div>
                        <div class="user-card-bio">@user.Bio</div>
                    </div>
                    <button class="follow-btn @(user.IsFollowing ? "following" : "follow")" @onclick="() => ToggleFollow(user)">
                        @(user.IsFollowing ? "Following" : "Follow")
                    </button>
                </div>
            }
            <div class="sidebar-footnote">Suggestions refresh daily based on activity.</div>
        </aside>

        <section class="feed">
            <div class="feed-header">
                <h2>Activity Stream</h2>
                <p class="feed-subtitle">Latest updates from your network</p>
            </div>

            <div class="post-composer">
                <div class="composer-title">
                    <h3>Create post</h3>
                    <span class="composer-profile-indicator">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        Posting as @_profileTypeTitle
                    </span>
                </div>
                <div class="post-type-selector">
                    @foreach (var option in _postTypeOptions)
                    {
                        <button type="button" class="post-type-option @(option.Id == _newPostType ? "active" : null)" @onclick="() => SelectPostType(option.Id)">
                            <MudIcon Icon="@option.Icon" Size="Size.Small" />
                            @option.Label
                            <span class="tooltip">@option.Tooltip</span>
                        </button>
                    }
                </div>
                <textarea class="post-input" placeholder="What's happening?" @bind="_newPostText"></textarea>
                <div class="post-actions">
                    <div class="post-options">
                        @foreach (var option in _composerAttachmentOptions)
                        {
                            <button type="button" class="post-option @(option.Id == _activeAttachment ? "active" : null)" @onclick="() => ToggleAttachment(option.Id)">
                                <MudIcon Icon="@option.Icon" Size="Size.Small" />
                                @option.Label
                            </button>
                        }
                    </div>
                    <button class="post-btn" disabled="@string.IsNullOrWhiteSpace(_newPostText)" @onclick="CreatePost">Publish</button>
                </div>

                @if (_activeAttachment == "schedule")
                {
                    <div class="post-form-fields active">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Event date</label>
                                <input type="date" @bind="_scheduledDate" />
                            </div>
                            <div class="form-group">
                                <label>Event time</label>
                                <input type="time" @bind="_scheduledTime" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Location</label>
                            <input type="text" placeholder="Virtual, HQ, etc." @bind="_scheduledLocation" />
                        </div>
                    </div>
                }
            </div>

            @if (!_pagedPosts.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📭</div>
                    <div class="empty-state-text">No posts yet</div>
                    <div class="empty-state-subtext">Create the first post to start the conversation.</div>
                </div>
            }
            else
            {
                @foreach (var post in _pagedPosts)
                {
                    <article class="post-card">
                        <header class="post-header">
                            <div class="post-avatar clickable" @onclick="() => NavigateToProfile(post.Author)">@post.AuthorInitials</div>
                            <div class="post-author-info">
                                <div class="post-author-name clickable" @onclick="() => NavigateToProfile(post.Author)">@post.Author</div>
                                <div class="post-time">@post.Time.ToString("MMM dd, yyyy h:mm tt")</div>
                            </div>
                            <div class="post-header-tags">
                                <span class="post-visibility">@post.Visibility</span>
                                <span class="post-type-badge @post.Type">@_postTypeLabels[post.Type]</span>
                            </div>
                        </header>

                        <div class="post-content">@post.Content</div>

                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <div class="post-image">
                                <img src="@post.ImageUrl" alt="Post image" />
                            </div>
                        }

                        @if (post.Metadata.Any())
                        {
                            <div class="post-metadata">
                                @foreach (var meta in post.Metadata)
                                {
                                    <div class="post-metadata-row">
                                        <div class="post-metadata-label">@meta.Label</div>
                                        <div class="post-metadata-value">@meta.Value</div>
                                    </div>
                                }
                            </div>
                        }

                        @* Reactions Section *@
                        @if (post.Reactions != null && post.Reactions.Any())
                        {
                            <div class="post-reactions">
                                @foreach (var reaction in post.Reactions)
                                {
                                    <div class="reaction-pill @(reaction.IsActive ? "active" : "")" @onclick="() => ToggleReaction(post, reaction)">
                                        <span class="reaction-emoji">@reaction.Emoji</span>
                                        <span class="reaction-count">@reaction.Count</span>
                                    </div>
                                }
                            </div>
                        }

                        <footer class="post-footer">
                            <div class="post-actions-buttons">
                                <button class="action-btn @(post.Liked ? "active" : null)" @onclick="() => ToggleLike(post)">
                                    <MudIcon Icon="@(post.Liked ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)" Size="Size.Small" />
                                    <span>@post.Likes</span>
                                </button>
                                <button class="action-btn" @onclick="() => ToggleComments(post)">
                                    <MudIcon Icon="@Icons.Material.Outlined.ChatBubbleOutline" Size="Size.Small" />
                                    <span>@post.Comments</span>
                                </button>
                                <button class="action-btn">
                                    <MudIcon Icon="@Icons.Material.Outlined.Share" Size="Size.Small" />
                                    <span>@post.Shares</span>
                                </button>
                            </div>
                            <div class="post-actions-buttons">
                                <button class="action-btn">
                                    <MudIcon Icon="@Icons.Material.Outlined.BookmarkBorder" Size="Size.Small" />
                                    Save
                                </button>
                                <button class="action-btn">
                                    <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Size="Size.Small" />
                                </button>
                            </div>
                        </footer>

                        @* Comments Section *@
                        @if (post.CommentsList != null && post.CommentsList.Any())
                        {
                            <div class="post-comments-section">
                                <button class="comments-toggle" @onclick="() => ToggleComments(post)">
                                    <MudIcon Icon="@(post.ShowComments ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                                    @(post.ShowComments ? "Hide" : "Show") @post.CommentsList.Count comment@(post.CommentsList.Count != 1 ? "s" : "")
                                </button>
                                
                                @if (post.ShowComments)
                                {
                                    <div class="comments-list">
                                        @foreach (var comment in post.CommentsList)
                                        {
                                            <div class="comment-item">
                                                <div class="comment-avatar clickable" @onclick="() => NavigateToProfile(comment.Author)">@comment.AuthorInitials</div>
                                                <div class="comment-content">
                                                    <div class="comment-header">
                                                        <span class="comment-author clickable" @onclick="() => NavigateToProfile(comment.Author)">@comment.Author</span>
                                                        <span class="comment-time">@comment.Time.ToString("MMM dd, h:mm tt")</span>
                                                    </div>
                                                    <div class="comment-text">@comment.Text</div>
                                                    @if (comment.Likes > 0)
                                                    {
                                                        <div class="comment-actions">
                                                            <div class="comment-like">
                                                                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" />
                                                                <span class="comment-like-count">@comment.Likes</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </article>
                }
            }

            <div class="pagination">
                <button class="pagination-btn" @onclick="PreviousPage" disabled="@(_currentPage == 1)">Previous</button>
                <div class="pagination-info">
                    <div class="page-indicator">Page <span id="current-page">@_currentPage</span> of @_pageCount</div>
                    <div class="posts-info">@_posts.Count total posts</div>
                </div>
                <button class="pagination-btn" @onclick="NextPage" disabled="@(_currentPage == _pageCount)">Next</button>
            </div>
        </section>

        <aside class="stats-panel">
            <h3>Your summary</h3>
            @foreach (var stat in _statsItems)
            {
                <div class="stat-item">
                    <div class="stat-label">@stat.Label</div>
                    <div class="stat-value">@stat.Value</div>
                </div>
            }

            <div class="saved-results-section">
                <div class="saved-results-header">
                    <h5>Saved insights</h5>
                    <button class="clear-saved-btn" @onclick="ClearSavedResults">Clear all</button>
                </div>
                @if (!_savedResults.Any())
                {
                    <div class="empty-state small">
                        <div class="empty-state-icon">⭐</div>
                        <div class="empty-state-text">No saved results yet</div>
                        <div class="empty-state-subtext">Pin AI replies to revisit them later.</div>
                    </div>
                }
                else
                {
                    @foreach (var result in _savedResults)
                    {
                        <div class="saved-result-item">
                            <div class="saved-result-avatar">@result.Initials</div>
                            <div class="saved-result-info">
                                <div class="saved-result-name">@result.Title</div>
                                <div class="saved-result-type">@result.Type</div>
                            </div>
                            <button class="quick-action-btn secondary" @onclick="() => RemoveSavedResult(result.Id)">Remove</button>
                        </div>
                    }
                }
            </div>
        </aside>
    </div>

    <MudDrawer Anchor="Anchor.Right"
               Open="@_chatOpen"
               Elevation="8"
               Width="520px"
               ClipMode="DrawerClipMode.Always"
               Class="ai-chat-drawer">
        <div class="ai-chat-panel @( _historyOpen ? "with-history" : null)">
            <div class="chat-history-sidebar @( _historyOpen ? "active" : null )">
                <div class="chat-history-header">
                    <h4>Conversations</h4>
                    <button class="history-close-btn" @onclick="ToggleHistory">→</button>
                </div>
                <button class="new-chat-btn" @onclick="StartNewConversation">➕ New Conversation</button>
                <div class="chat-history-list">
                    @if (!_conversations.Any())
                    {
                        <div class="empty-history">
                            <div class="empty-history-icon">💬</div>
                            <div class="empty-history-text">No conversations yet.<br/>Start chatting to see history!</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var conversation in _conversations)
                        {
                            <div class="conversation-item @(conversation.Id == _currentConversationId ? "active" : null)" @onclick="() => LoadConversation(conversation.Id)">
                                <div class="conversation-item-header">
                                    <div class="conversation-title">@conversation.Title</div>
                                    <div class="conversation-time">@GetTimeAgo(conversation.LastUpdated)</div>
                                </div>
                                <div class="conversation-preview">@conversation.Preview</div>
                                @if (conversation.MessageCount > 0 || conversation.ResultCount > 0)
                                {
                                    <div class="conversation-meta">
                                        @if (conversation.MessageCount > 0)
                                        {
                                            <span class="conversation-badge">💬 @conversation.MessageCount msgs</span>
                                        }
                                        @if (conversation.ResultCount > 0)
                                        {
                                            <span class="conversation-badge">📄 @conversation.ResultCount results</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
                
                @if (_savedResults.Any())
                {
                    <div class="saved-results-section">
                        <div class="saved-results-header">
                            <h5>📌 Saved Results</h5>
                            <button class="clear-saved-btn" @onclick="ClearSavedResults">Clear</button>
                        </div>
                        @foreach (var result in _savedResults)
                        {
                            <div class="saved-result-item">
                                <div class="saved-result-avatar">@result.Initials</div>
                                <div class="saved-result-info">
                                    <div class="saved-result-name">@result.Title</div>
                                    <div class="saved-result-type">@result.Type</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="chat-main-container">
                <div class="chat-header">
                    <div class="chat-header-left">
                        <button class="history-toggle-btn" @onclick="ToggleHistory" title="Toggle conversation history">
                            <MudIcon Icon="@Icons.Material.Filled.Menu" Size="Size.Medium" />
                        </button>
                        <div class="chat-header-info">
                            <div class="chat-ai-avatar">🤖</div>
                            <div class="chat-header-text">
                                <h4>Sivar AI Assistant</h4>
                                <p>Always here to help you explore</p>
                            </div>
                        </div>
                    </div>
                    <div class="chat-header-actions">
                        <button class="chat-close-btn" @onclick="ToggleChat">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                        </button>
                    </div>
                </div>

                <div class="chat-messages" id="chatMessages">
                    @if (!_chatMessages.Any())
                    {
                        <div class="empty-history">
                            <div class="empty-history-icon">💬</div>
                            <div class="empty-history-text">No messages yet</div>
                            <div class="empty-history-subtext">Start a conversation with the AI</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var message in _chatMessages)
                        {
                            <div class="chat-message @(message.Sender == "user" ? "user" : "ai")">
                                <div class="chat-message-avatar">@((message.Sender == "user") ? "👤" : "🤖")</div>
                                <div class="chat-message-content">
                                    @if (message.MessageType == "result-card" && message.ResultCard != null)
                                    {
                                        <div class="chat-result-card">
                                            <div class="chat-result-header">
                                                <div class="chat-result-avatar">@message.ResultCard.Avatar</div>
                                                <div class="chat-result-info">
                                                    <div class="chat-result-name">@message.ResultCard.Name</div>
                                                    <div class="chat-result-type">@message.ResultCard.Type</div>
                                                </div>
                                            </div>
                                            <div class="chat-result-description">@message.ResultCard.Description</div>
                                            <div class="chat-result-actions">
                                                <button class="chat-result-btn primary" @onclick="() => {}">
                                                    👁️ View Profile
                                                </button>
                                                <button class="chat-result-btn secondary" @onclick="() => {}">
                                                    📌 Save
                                                </button>
                                                <button class="chat-result-btn secondary" @onclick="() => {}">
                                                    ➕ Follow
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="chat-bubble" style="white-space: pre-line;">@message.Text</div>
                                        @if (message.QuickActions != null && message.QuickActions.Any())
                                        {
                                            <div class="chat-quick-actions">
                                                @foreach (var action in message.QuickActions)
                                                {
                                                    <button class="quick-action-btn" @onclick="async () => await SendQuickPrompt(action)">@action</button>
                                                }
                                            </div>
                                        }
                                    }
                                    <div class="chat-message-time">@message.Time.ToString("t")</div>
                                </div>
                            </div>
                        }
                    }

                    @if (_typing)
                    {
                        <div class="chat-message ai typing">
                            <div class="chat-message-avatar">🤖</div>
                            <div class="chat-message-content">
                                <div class="chat-bubble">
                                    <div class="typing-indicator">
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="chat-input-container">
                    <MudTextField @bind-Value="_chatInput" Placeholder="Ask me anything..." Immediate="true" OnKeyDown="OnChatKeyDown" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Send" OnAdornmentClick="SendChat" />
                </div>
            </div>
        </div>
    </MudDrawer>

    <button class="ai-fab" aria-label="Open AI Chat" @onclick="ToggleChat">
        🤖
    </button>
</MudContainer>

@code {
#nullable enable
    private string _profileType = "personal";
    private string _newPostText = string.Empty;
    private string _newPostType = "general";
    private string? _activeAttachment;
    private DateTime? _scheduledDate;
    private TimeOnly? _scheduledTime;
    private string _scheduledLocation = string.Empty;
    private bool _chatOpen;
    private string _chatInput = string.Empty;
    private bool _bodyClassApplied;

    private readonly List<UserSample> _suggestedUsers = new();
    private readonly List<PostTypeOption> _postTypeOptions = new();
    private readonly Dictionary<string, string> _postTypeLabels = new();
    private readonly List<ComposerAttachmentOption> _composerAttachmentOptions = new();
    private readonly List<PostSample> _posts = new();
    private readonly List<StatItem> _statsItems = new();
    private readonly List<SavedResultItem> _savedResults = new();
    private readonly List<string> _quickPrompts = new();
    private readonly StatsSummary _stats = new();
    private readonly Random _random = new();

    private int _currentPage = 1;
    private int _pageSize = 3;

    private IEnumerable<PostSample> _pagedPosts => _posts.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    private int _pageCount => Math.Max(1, (int)Math.Ceiling((double)_posts.Count / _pageSize));
    private string _profileTypeTitle => _profileType switch
    {
        "business" => "Business Page",
        "product" => "Product Profile",
        _ => "Personal Profile"
    };

    private readonly List<Conversation> _conversations = new();
    private readonly Dictionary<string, List<ChatMessage>> _conversationMessages = new();
    private List<ChatMessage> _chatMessages = new();
    private string _currentConversationId = string.Empty;
    private bool _historyOpen;
    private bool _typing;

    protected override void OnInitialized()
    {
        SeedPostTypes();
        SeedComposerOptions();
        SeedUsers();
        SeedPosts();
        SeedStats();
        SeedSavedResults();
        SeedQuickPrompts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (_bodyClassApplied)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("eval", "document.body.classList.add('wireframe-landing-page')");
            _bodyClassApplied = true;
        }
        catch
        {
            // Ignore failures until the circuit is interactive.
        }
    }

    private void SeedPostTypes()
    {
        _postTypeOptions.AddRange(new[]
        {
            new PostTypeOption("general", "General", Icons.Material.Filled.Article, "Share updates with everyone."),
            new PostTypeOption("product", "Product", Icons.Material.Filled.Storefront, "Highlight new features or releases."),
            new PostTypeOption("service", "Service", Icons.Material.Filled.HeadsetMic, "Promote a service offering."),
            new PostTypeOption("event", "Event", Icons.Material.Filled.Event, "Schedule an event or meetup."),
            new PostTypeOption("job", "Job", Icons.Material.Filled.Work, "Share an open role with the community.")
        });

        foreach (var option in _postTypeOptions)
        {
            _postTypeLabels[option.Id] = option.Label;
        }
    }

    private void SeedComposerOptions()
    {
        _composerAttachmentOptions.AddRange(new[]
        {
            new ComposerAttachmentOption("media", "Add media", Icons.Material.Outlined.Image),
            new ComposerAttachmentOption("schedule", "Schedule", Icons.Material.Outlined.EventAvailable),
            new ComposerAttachmentOption("poll", "Poll", Icons.Material.Outlined.Poll),
            new ComposerAttachmentOption("ai-draft", "AI draft", Icons.Material.Outlined.AutoAwesome)
        });
    }

    private void SeedUsers()
    {
        _suggestedUsers.AddRange(new[]
        {
            new UserSample("Alice Doe", "Product Designer", false),
            new UserSample("Bob Smith", "Frontend Engineer", true),
            new UserSample("Carol Lee", "CTO", false),
            new UserSample("Diego Martin", "Growth Marketer", false)
        });
    }

    private void SeedPosts()
    {
        _posts.AddRange(new[]
        {
            new PostSample
            {
                Author = "Alice Doe",
                Content = "We launched a new feature today that helps teams orchestrate releases in half the time.",
                Type = "product",
                Visibility = "Public",
                Time = DateTime.Now.AddHours(-1),
                Likes = 42,
                Comments = 9,
                Shares = 3,
                ImageUrl = "https://picsum.photos/800/600?random=1",
                Metadata =
                {
                    new PostMetadataItem("Campaign", "Spring Launch"),
                    new PostMetadataItem("Status", "Rolling out to 25% of users"),
                    new PostMetadataItem("Owner", "Lifecycle squad")
                },
                Reactions =
                {
                    new PostReaction("👍", 28) { IsActive = true },
                    new PostReaction("🎉", 12),
                    new PostReaction("❤️", 8),
                    new PostReaction("🚀", 5)
                },
                CommentsList =
                {
