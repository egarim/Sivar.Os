        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_currentConversationId))
        {
            StartNewConversation();
        }

        var message = new ChatMessage("user", _chatInput.Trim());
        AddMessage(_currentConversationId, message);

        _chatInput = string.Empty;
        _typing = true;
        StateHasChanged();
        await ScrollChatToBottom();

        var aiText = await GetMockResponseAsync(message.Text);
        
