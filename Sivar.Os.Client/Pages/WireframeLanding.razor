            AddMessage(_currentConversationId, followUp);
        }
        else if (aiText == "TECH_SEARCH")
        {
            var aiMessage = new ChatMessage("ai", "I found several tech companies in your network:");
            AddMessage(_currentConversationId, aiMessage);
            await Task.Delay(300);
            
            var tech1 = new ChatMessage("ai", "", "result-card")
