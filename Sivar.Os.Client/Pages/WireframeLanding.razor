@page "/wireframe-landing"
@using System
@using System.Linq
@using System.Threading.Tasks
@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

<style>
    /* Hide scroll to top button on this page */
    .mud-scroll-to-top {
        display: none !important;
    }
    
    /* Mobile-friendly touch targets */
    @@media (max-width: 768px) {
        .wireframe-landing button,
        .wireframe-landing .action-btn,
        .wireframe-landing .post-option,
        .wireframe-landing .post-type-option {
            min-height: 44px; /* Apple's recommended touch target size */
        }
    }

    /* Use MudBlazor's CSS variables that adapt to theme automatically */
    .wireframe-landing {
        --wire-bg: var(--mud-palette-background-gray, #f5f7fa);
        --wire-surface: var(--mud-palette-surface, #ffffff);
        --wire-border: var(--mud-palette-lines-default, #e1e8ed);
        --wire-text-primary: var(--mud-palette-text-primary, #14171a);
        --wire-text-secondary: var(--mud-palette-text-secondary, #657786);
        --wire-primary: var(--mud-palette-primary, #1da1f2);
        --wire-hover: var(--mud-palette-action-default-hover, #f0f4f8);
    }

    .wire-container.wireframe-landing {
        background: var(--wire-bg);
        min-height: 100vh;
        padding: 0 !important;
        max-width: none !important;
    }

    .wireframe-landing .header {
        background: var(--wire-surface);
        border-bottom: 1px solid var(--wire-border);
        padding: 12px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .wireframe-landing .logo {
        font-size: 20px;
        font-weight: 700;
        color: var(--wire-primary);
    }

    .wireframe-landing .header-center {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .wireframe-landing .profile-type-label {
        font-size: 13px;
        color: var(--wire-text-secondary);
    }

    .wireframe-landing .profile-type-switcher {
        padding: 6px 12px;
        border: 1px solid var(--wire-border);
        border-radius: 6px;
        background: var(--wire-surface);
        font-size: 14px;
        cursor: pointer;
    }

    .wireframe-landing .user-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .wireframe-landing .user-details {
        text-align: right;
    }

    .wireframe-landing .user-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--wire-text-primary);
    }

    .wireframe-landing .user-email {
        font-size: 12px;
        color: var(--wire-text-secondary);
    }

    .wireframe-landing .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--wire-primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    .wireframe-landing .main-layout {
        display: grid;
        grid-template-columns: 260px 1fr 300px;
        gap: 24px;
        padding: 24px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .wireframe-landing .sidebar,
    .wireframe-landing .stats-panel {
        background: var(--wire-surface);
        border: 1px solid var(--wire-border);
        border-radius: 12px;
        padding: 20px;
    }

    .wireframe-landing .sidebar-header h3,
    .wireframe-landing .stats-panel h3 {
        font-size: 18px;
        font-weight: 700;
        margin: 0 0 8px 0;
        color: var(--wire-text-primary);
    }

    .wireframe-landing .sidebar-subtitle {
        font-size: 13px;
        color: var(--wire-text-secondary);
        margin-bottom: 16px;
    }

    .wireframe-landing .user-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        margin-bottom: 8px;
        border-radius: 8px;
        transition: background 0.2s;
    }

    .wireframe-landing .user-card:hover {
        background: var(--wire-hover);
    }

    .wireframe-landing .small-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--wire-primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        flex-shrink: 0;
    }

    .wireframe-landing .user-card-info {
        flex: 1;
        min-width: 0;
    }

    .wireframe-landing .user-card-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--wire-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .wireframe-landing .user-card-name.clickable:hover {
        color: var(--wire-primary);
        cursor: pointer;
        text-decoration: underline;
    }

    .wireframe-landing .user-card-bio {
        font-size: 13px;
        color: var(--wire-text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .wireframe-landing .follow-btn {
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        flex-shrink: 0;
        border: none;
    }

    .wireframe-landing .follow-btn.follow {
        background: var(--wire-primary);
        color: white;
    }

    .wireframe-landing .follow-btn.follow:hover {
        background: #1a8cd8;
    }

    .wireframe-landing .follow-btn.following {
        background: transparent;
        color: var(--wire-text-secondary);
        border: 1px solid var(--wire-border);
    }

    .wireframe-landing .follow-btn.following:hover {
        background: #fff0f0;
        border-color: #ff6b6b;
        color: #ff6b6b;
    }

    .wireframe-landing .sidebar-footnote {
        font-size: 12px;
        color: var(--wire-text-secondary);
        text-align: center;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--wire-border);
    }

    .wireframe-landing .feed {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    .wireframe-landing .feed-header h2 {
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 4px 0;
        color: var(--wire-text-primary);
    }

    .wireframe-landing .feed-subtitle {
        font-size: 14px;
        color: var(--wire-text-secondary);
        margin: 0;
    }

    .wireframe-landing .post-composer {
        background: var(--wire-surface);
        border: 1px solid var(--wire-border);
        border-radius: 12px;
        padding: 20px;
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }

    .wireframe-landing .composer-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .wireframe-landing .composer-title h3 {
        font-size: 16px;
        font-weight: 600;
        margin: 0;
        color: var(--wire-text-primary);
    }

    .wireframe-landing .composer-profile-indicator {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--wire-text-secondary);
    }

    .wireframe-landing .post-type-selector {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .wireframe-landing .post-type-option {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        white-space: nowrap;
        background: transparent;
        border: 1px solid var(--wire-border);
        color: var(--wire-text-secondary);
        transition: all 0.2s;
        position: relative;
    }

    .wireframe-landing .post-type-option:hover {
        background: var(--wire-hover);
    }

    .wireframe-landing .post-type-option.active {
        background: var(--wire-primary);
        color: white;
        border-color: var(--wire-primary);
    }

    .wireframe-landing .post-type-option .tooltip {
        display: none;
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: var(--wire-text-primary);
        color: white;
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 11px;
        white-space: nowrap;
        margin-bottom: 8px;
        z-index: 10;
    }

    .wireframe-landing .post-type-option:hover .tooltip {
        display: block;
    }

    .wireframe-landing .post-input {
        width: 100%;
        min-height: 80px;
        padding: 12px;
        border: 1px solid var(--wire-border);
        border-radius: 8px;
        font-size: 14px;
        font-family: inherit;
        resize: vertical;
        margin-bottom: 12px;
    }

    .wireframe-landing .post-input:focus {
        outline: none;
        border-color: var(--wire-primary);
    }

    .wireframe-landing .post-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .wireframe-landing .post-options {
        display: flex;
        gap: 8px;
    }

    .wireframe-landing .post-option {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        cursor: pointer;
        background: transparent;
        border: 1px solid var(--wire-border);
        color: var(--wire-text-secondary);
        transition: all 0.2s;
    }

    .wireframe-landing .post-option:hover {
        background: var(--wire-hover);
        border-color: var(--wire-primary);
        color: var(--wire-primary);
    }

    .wireframe-landing .post-btn {
        padding: 8px 24px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        background: var(--wire-primary);
        color: white;
        border: none;
        transition: all 0.2s;
    }

    .wireframe-landing .post-btn:hover:not(:disabled) {
        background: #1a8cd8;
    }

    .wireframe-landing .post-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .wireframe-landing .post-card {
        background: var(--wire-surface);
        border: 1px solid var(--wire-border);
        border-radius: 12px;
        padding: 20px;
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
        overflow-wrap: break-word;
        word-wrap: break-word;
    }

    .wireframe-landing .post-header {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 12px;
    }

    .wireframe-landing .post-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--wire-primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        flex-shrink: 0;
        transition: all 0.2s;
    }

    .wireframe-landing .post-avatar.clickable {
        cursor: pointer;
    }

    .wireframe-landing .post-avatar.clickable:hover {
        transform: scale(1.1);
        box-shadow: 0 4px 12px rgba(25, 118, 210, 0.3);
    }

    .wireframe-landing .post-author-info {
        flex: 1;
        min-width: 0;
    }

    .wireframe-landing .post-author-name {
        font-size: 15px;
        font-weight: 600;
        color: var(--wire-text-primary);
    }

    .wireframe-landing .post-author-name.clickable:hover {
        color: var(--wire-primary);
        cursor: pointer;
        text-decoration: underline;
    }

    .wireframe-landing .post-time {
        font-size: 13px;
        color: var(--wire-text-secondary);
    }

    .wireframe-landing .post-header-tags {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .wireframe-landing .post-visibility {
        font-size: 11px;
        padding: 4px 8px;
        border-radius: 4px;
        background: var(--wire-hover);
        color: var(--wire-text-secondary);
        font-weight: 500;
    }

    .wireframe-landing .post-type-badge {
        font-size: 11px;
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .wireframe-landing .post-type-badge.general {
        background: #e3f2fd;
        color: #1976d2;
    }

    .wireframe-landing .post-type-badge.product {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .wireframe-landing .post-type-badge.service {
        background: #e8f5e9;
        color: #388e3c;
    }

    .wireframe-landing .post-type-badge.event {
        background: #fff3e0;
        color: #f57c00;
    }

    .wireframe-landing .post-type-badge.job {
        background: #fce4ec;
        color: #c2185b;
    }

    .wireframe-landing .post-content {
        font-size: 15px;
        line-height: 1.5;
        color: var(--wire-text-primary);
        margin-bottom: 12px;
    }

    .wireframe-landing .post-image {
        width: 100%;
        margin-bottom: 12px;
        border-radius: 8px;
        overflow: hidden;
    }

    .wireframe-landing .post-image img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: cover;
        max-height: 500px;
    }

    .wireframe-landing .post-metadata {
        background: var(--wire-hover);
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 12px;
    }

    .wireframe-landing .post-metadata-row {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
    }

    .wireframe-landing .post-metadata-row:not(:last-child) {
        border-bottom: 1px solid var(--wire-border);
    }

    .wireframe-landing .post-metadata-label {
        font-size: 12px;
        color: var(--wire-text-secondary);
        font-weight: 500;
    }

    .wireframe-landing .post-metadata-value {
        font-size: 12px;
        color: var(--wire-text-primary);
        font-weight: 600;
    }

    .wireframe-landing .post-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 12px;
        border-top: 1px solid var(--wire-border);
    }

    .wireframe-landing .post-actions-buttons {
        display: flex;
        gap: 16px;
    }

    .wireframe-landing .action-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        color: var(--wire-text-secondary);
        background: transparent;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .wireframe-landing .action-btn:hover {
        background: var(--wire-hover);
        color: var(--wire-primary);
    }

    .wireframe-landing .action-btn span {
        font-weight: 600;
    }

    /* Post Reactions */
    .wireframe-landing .post-reactions {
        display: flex;
        gap: 8px;
        padding: 12px 0;
        border-top: 1px solid var(--wire-border);
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .wireframe-landing .reaction-pill {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 20px;
        background: var(--wire-bg);
        border: 1px solid var(--wire-border);
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s;
        user-select: none;
    }

    .wireframe-landing .reaction-pill:hover {
        background: var(--wire-hover);
        border-color: var(--wire-primary);
        transform: translateY(-2px);
    }

    .wireframe-landing .reaction-pill.active {
        background: rgba(25, 118, 210, 0.1);
        border-color: var(--wire-primary);
        color: var(--wire-primary);
    }

    .wireframe-landing .reaction-emoji {
        font-size: 16px;
        line-height: 1;
    }

    .wireframe-landing .reaction-count {
        font-size: 13px;
        font-weight: 600;
        color: var(--wire-text-secondary);
    }

    .wireframe-landing .reaction-pill.active .reaction-count {
        color: var(--wire-primary);
    }

    /* Post Comments Section */
    .wireframe-landing .post-comments-section {
        border-top: 1px solid var(--wire-border);
        margin-top: 12px;
        padding-top: 12px;
    }

    .wireframe-landing .comments-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        background: var(--wire-bg);
        border: 1px solid var(--wire-border);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        color: var(--wire-text-secondary);
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 12px;
    }

    .wireframe-landing .comments-toggle:hover {
        background: var(--wire-hover);
        border-color: var(--wire-primary);
        color: var(--wire-primary);
    }

    .wireframe-landing .comments-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .wireframe-landing .comment-item {
        display: flex;
        gap: 10px;
        padding: 10px;
        background: var(--wire-bg);
        border-radius: 8px;
        border: 1px solid var(--wire-border);
    }

    .wireframe-landing .comment-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--wire-primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 600;
        flex-shrink: 0;
        transition: all 0.2s;
    }

    .wireframe-landing .comment-avatar.clickable {
        cursor: pointer;
    }

    .wireframe-landing .comment-avatar.clickable:hover {
        transform: scale(1.1);
        box-shadow: 0 4px 12px rgba(25, 118, 210, 0.3);
    }

    .wireframe-landing .comment-content {
        flex: 1;
        min-width: 0;
    }

    .wireframe-landing .comment-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
    }

    .wireframe-landing .comment-author {
        font-size: 14px;
        font-weight: 600;
        color: var(--wire-text-primary);
        transition: all 0.2s;
    }

    .wireframe-landing .comment-author.clickable {
        cursor: pointer;
    }

    .wireframe-landing .comment-author.clickable:hover {
        color: var(--wire-primary);
        text-decoration: underline;
    }

    .wireframe-landing .comment-time {
        font-size: 12px;
        color: var(--wire-text-secondary);
        opacity: 0.8;
    }

    .wireframe-landing .comment-text {
        font-size: 14px;
        color: var(--wire-text-primary);
        line-height: 1.5;
        margin-bottom: 6px;
    }

    .wireframe-landing .comment-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .wireframe-landing .comment-like {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 12px;
        color: var(--wire-text-secondary);
        cursor: pointer;
        transition: all 0.2s;
    }

    .wireframe-landing .comment-like:hover {
        color: var(--wire-primary);
    }

    .wireframe-landing .comment-like-count {
        font-weight: 600;
    }

    .wireframe-landing .pagination {
        background: var(--wire-surface);
        border: 1px solid var(--wire-border);
        border-radius: 12px;
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .wireframe-landing .pagination-info {
        text-align: center;
    }

    .wireframe-landing .page-indicator,
    .wireframe-landing .posts-info {
        font-size: 13px;
        color: var(--wire-text-secondary);
    }

    .wireframe-landing .page-indicator {
        font-weight: 600;
        margin-bottom: 4px;
    }

    .wireframe-landing #current-page {
        color: var(--wire-primary);
    }

    .wireframe-landing .pagination-btn {
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        background: var(--wire-primary);
        color: white;
        border: none;
        transition: all 0.2s;
    }

    .wireframe-landing .pagination-btn:hover:not(:disabled) {
        background: #1a8cd8;
    }

    .wireframe-landing .pagination-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .wireframe-landing .stat-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
    }

    .wireframe-landing .stat-item:not(:last-of-type) {
        border-bottom: 1px solid var(--wire-border);
    }

    .wireframe-landing .stat-label {
        font-size: 13px;
        color: var(--wire-text-secondary);
    }

    .wireframe-landing .stat-value {
        font-size: 16px;
        font-weight: 700;
        color: var(--wire-text-primary);
    }

    .wireframe-landing .saved-results-section {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 2px solid var(--wire-border);
    }

    .wireframe-landing .saved-results-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        padding: 0 2px;
    }

    .wireframe-landing .saved-results-header h5 {
        font-size: 16px;
        font-weight: 600;
        margin: 0;
        color: var(--wire-text-primary);
        letter-spacing: -0.2px;
    }

    .wireframe-landing .clear-saved-btn {
        font-size: 12px;
        color: var(--wire-primary);
        background: transparent;
        border: none;
        cursor: pointer;
        font-weight: 600;
    }

    .wireframe-landing .clear-saved-btn:hover {
        text-decoration: underline;
    }

    .wireframe-landing .saved-result-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        margin-bottom: 8px;
        border-radius: 10px;
        background: white;
        border: 2px solid var(--wire-border);
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .wireframe-landing .saved-result-item:hover {
        border-color: var(--wire-primary);
        transform: translateX(3px);
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    }

    .wireframe-landing .saved-result-avatar {
        width: 32px;
        height: 32px;
