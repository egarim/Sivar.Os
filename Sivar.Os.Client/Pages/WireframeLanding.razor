                ResultCard = new ChatResultCard("tech1", "💻", "TechVision Solutions", 
                    "🏢 Business Profile • Software Development", 
                    "Leading software development company specializing in AI and cloud solutions. Currently hiring!")
            };
            AddMessage(_currentConversationId, tech1);
            await Task.Delay(300);
            
            var tech2 = new ChatMessage("ai", "", "result-card")
            {
                ResultCard = new ChatResultCard("tech2", "🚀", "Innovation Labs", 
                    "🏛️ Organization Profile • Tech Incubator", 
                    "Supporting startups and tech entrepreneurs. Check out our upcoming events and mentorship programs.")
            };
            AddMessage(_currentConversationId, tech2);
        }
        else if (aiText == "EVENT_SEARCH")
        {
            var aiMessage = new ChatMessage("ai", "Here are upcoming events you might be interested in:");
            AddMessage(_currentConversationId, aiMessage);
            await Task.Delay(300);
            
            var event1 = new ChatMessage("ai", "", "result-card")
            {
                ResultCard = new ChatResultCard("event1", "🎉", "Tech Innovation Summit 2024", 
                    "🎉 Event • March 15, 2024", 
                    "Annual gathering of tech leaders and innovators. Network, learn, and grow! Free admission.")
            };
            AddMessage(_currentConversationId, event1);
