    private void ToggleReaction(PostSample post, PostReaction reaction)
    {
        if (reaction.IsActive)
        {
            reaction.IsActive = false;
            reaction.Count--;
            if (reaction.Count < 0)
            {
                reaction.Count = 0;
            }
        }
        else
        {
            // Deactivate all other reactions for this post
            if (post.Reactions != null)
            {
                foreach (var r in post.Reactions.Where(r => r.IsActive))
                {
                    r.IsActive = false;
                    r.Count--;
                    if (r.Count < 0)
                    {
                        r.Count = 0;
                    }
                }
            }
            
            reaction.IsActive = true;
            reaction.Count++;
        }
    }

