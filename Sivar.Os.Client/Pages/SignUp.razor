@page "/signup"
@layout LandingLayout
@using MudBlazor
@inject NavigationManager Navigation

<style>
    .signup-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
        overflow: hidden;
        padding: 24px;
    }

    .signup-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        width: 100%;
        max-width: 500px;
        padding: 48px;
        animation: slideUp 0.6s ease-out;
    }

    .signup-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .signup-logo {
        font-size: 36px;
        font-weight: 800;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 12px;
    }

    .signup-title {
        font-size: 24px;
        font-weight: 700;
        color: #1a1a27;
        margin-bottom: 8px;
    }

    .signup-subtitle {
        font-size: 14px;
        color: #666;
    }

    .signup-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-label {
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }

    .form-input {
        padding: 14px 16px;
        font-size: 15px;
        border: 2px solid #e8e8e8;
        border-radius: 8px;
        transition: all 0.3s ease;
        font-family: inherit;
    }

    .form-input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-input.error {
        border-color: #ff3f5f;
    }

    .error-message {
        color: #ff3f5f;
        font-size: 13px;
        margin-top: -12px;
    }

    .form-checkbox {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 14px;
        color: #666;
        line-height: 1.4;
    }

    .form-checkbox input {
        margin-top: 2px;
    }

    .form-checkbox a {
        color: #667eea;
        text-decoration: none;
    }

    .form-checkbox a:hover {
        text-decoration: underline;
    }

    .submit-btn {
        padding: 16px;
        font-size: 16px;
        font-weight: 700;
        color: white;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-top: 8px;
    }

    .submit-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
    }

    .submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .signup-footer {
        text-align: center;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #e8e8e8;
        font-size: 14px;
        color: #666;
    }

    .signup-footer a {
        color: #667eea;
        font-weight: 600;
        text-decoration: none;
    }

    .signup-footer a:hover {
        text-decoration: underline;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: white;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        position: absolute;
        top: 24px;
        left: 24px;
        padding: 12px 20px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .back-link:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateX(-4px);
    }

    .bg-circle {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        animation: float 20s ease-in-out infinite;
    }

    .bg-circle-1 {
        width: 400px;
        height: 400px;
        top: -200px;
        left: -200px;
        animation-delay: 0s;
    }

    .bg-circle-2 {
        width: 300px;
        height: 300px;
        bottom: -150px;
        right: -150px;
        animation-delay: 7s;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -30px) scale(1.1);
        }
        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }
    }

    @@media (max-width: 768px) {
        .signup-card {
            padding: 32px 24px;
        }

        .back-link {
            position: static;
            margin-bottom: 24px;
            display: inline-flex;
        }

        .signup-container {
            display: block;
            padding: 24px;
        }
    }
</style>

<div class="signup-container">
    <div class="bg-circle bg-circle-1"></div>
    <div class="bg-circle bg-circle-2"></div>

    <a href="/" class="back-link">
        <span>←</span>
        <span>Back to Home</span>
    </a>

    <div class="signup-card">
        <div class="signup-header">
            <div class="signup-logo">SivarOS</div>
            <div class="signup-title">Create Account</div>
            <div class="signup-subtitle">Join the future of digital governance</div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="error-message" style="margin-bottom: 16px;">@_errorMessage</div>
        }

        <div class="signup-form">
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" 
                       class="form-input @(_showErrors && string.IsNullOrEmpty(_fullName) ? "error" : "")" 
                       placeholder="Enter your full name" 
                       @bind="_fullName"
                       @bind:event="oninput" />
            </div>

            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" 
                       class="form-input @(_showErrors && !IsValidEmail(_email) ? "error" : "")" 
                       placeholder="Enter your email" 
                       @bind="_email"
                       @bind:event="oninput" />
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" 
                       class="form-input @(_showErrors && string.IsNullOrEmpty(_password) ? "error" : "")" 
                       placeholder="Create a password (min. 8 characters)" 
                       @bind="_password"
                       @bind:event="oninput" />
                @if (_showErrors && !string.IsNullOrEmpty(_password) && _password.Length < 8)
                {
                    <span class="error-message">Password must be at least 8 characters</span>
                }
            </div>

            <div class="form-group">
                <label class="form-label">Confirm Password</label>
                <input type="password" 
                       class="form-input @(_showErrors && _password != _confirmPassword ? "error" : "")" 
                       placeholder="Confirm your password" 
                       @bind="_confirmPassword"
                       @bind:event="oninput" />
                @if (_showErrors && !string.IsNullOrEmpty(_confirmPassword) && _password != _confirmPassword)
                {
                    <span class="error-message">Passwords do not match</span>
                }
            </div>

            <label class="form-checkbox">
                <input type="checkbox" @bind="_agreeToTerms" />
                <span>I agree to the <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a></span>
            </label>
            @if (_showErrors && !_agreeToTerms)
            {
                <span class="error-message" style="margin-top: -12px;">You must agree to the terms</span>
            }

            <button class="submit-btn" @onclick="HandleSignUp" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span>Creating Account...</span>
                }
                else
                {
                    <span>Create Account</span>
                }
            </button>
        </div>

        <div class="signup-footer">
            Already have an account? <a href="/login">Sign in</a>
        </div>
    </div>
</div>

@code {
    private string _fullName = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _agreeToTerms = false;
    private bool _isLoading = false;
    private bool _showErrors = false;
    private string _errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        // Redirect immediately to Keycloak registration
        // In Keycloak, the registration page is typically accessed via the login page
        // You may need to configure Keycloak to show a "Register" link or use a direct registration URL
        Navigation.NavigateTo("/authentication/register", forceLoad: true);
    }

    private async Task HandleSignUp()
    {
        // This method is no longer needed as we redirect to Keycloak
        // But keeping it in case user somehow accesses the page
        Navigation.NavigateTo("/authentication/register", forceLoad: true);
    }

    private bool IsValidEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return false;

        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            return addr.Address == email;
        }
        catch
        {
            return false;
        }
    }
}
