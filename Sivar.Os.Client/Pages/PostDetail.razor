@page "/post/{PostId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using Sivar.Os.Shared.Clients
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Enums
@using Sivar.Os.Client.Components.Feed
@using Microsoft.Extensions.Logging
@inject NavigationManager Navigation
@inject IPostsClient PostsClient
@inject IProfilesClient ProfilesClient
@inject ILogger<PostDetail> Logger

<PageTitle>@(_post?.Profile?.DisplayName ?? "Post") - Sivar.Os</PageTitle>

<div class="post-detail-page wireframe-landing">
    <!-- Header with back button -->
    <div class="post-detail-header">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" 
                      OnClick="GoBack" 
                      Color="Color.Default"
                      Size="Size.Medium" />
        <MudText Typo="Typo.h6">Post</MudText>
    </div>

    <div class="post-detail-content">
        @if (_isLoading)
        {
            <div class="loading-container">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body1" Class="mt-3">Loading post...</MudText>
            </div>
        }
        else if (_error != null)
        {
            <div class="error-container">
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-3">@_error</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="GoBack">
                    Go Back
                </MudButton>
            </div>
        }
        else if (_post != null)
        {
            @if (_post.PostType == PostType.Blog)
            {
                <!-- Blog Post Detail View -->
                <article class="blog-detail">
                    @if (!string.IsNullOrEmpty(_post.CoverImageUrl))
                    {
                        <div class="blog-cover-image">
                            <img src="@_post.CoverImageUrl" alt="@_post.Content" />
                        </div>
                    }
                    
                    <div class="blog-detail-content">
                        <!-- Author Info + Edit Action -->
                        <div class="blog-author-row">
                            <div class="blog-author">
                                <MudAvatar Size="Size.Medium" Color="Color.Primary">
                                    @GetInitials(_post.Profile?.DisplayName)
                                </MudAvatar>
                                <div class="blog-author-info">
                                    <MudText Typo="Typo.subtitle1" Class="blog-author-name">
                                        @_post.Profile?.DisplayName
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @FormatDate(_post.PublishedAt ?? _post.CreatedAt)
                                        @if (_post.ReadTimeMinutes.HasValue && _post.ReadTimeMinutes.Value > 0)
                                        {
                                            <span> · @_post.ReadTimeMinutes min read</span>
                                        }
                                    </MudText>
                                </div>
                            </div>
                            @if (_post.Profile?.Id == _currentProfileId)
                            {
                                <MudTooltip Text="Edit Article">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit" 
                                                   Color="Color.Default" 
                                                   Size="Size.Small"
                                                   OnClick="@(() => HandleEditBlog(_post))" />
                                </MudTooltip>
                            }
                        </div>
                        
                        <!-- Title -->
                        <h1 class="blog-title">@_post.Content</h1>
                        
                        <!-- Subtitle -->
                        @if (!string.IsNullOrEmpty(_post.Subtitle))
                        {
                            <p class="blog-subtitle">@_post.Subtitle</p>
                        }
                        
                        <!-- Blog Content - render as HTML -->
                        @if (!string.IsNullOrEmpty(_post.BlogContent))
                        {
                            <div class="blog-body">
                                @((MarkupString)_post.BlogContent)
                            </div>
                        }
                        
                        <!-- Tags -->
                        @if (_post.Tags?.Count > 0)
                        {
                            <div class="blog-tags">
                                @foreach (var tag in _post.Tags)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                        @tag
                                    </MudChip>
                                }
                            </div>
                        }
                        
                        <MudDivider Class="my-4" />
                        
                        <!-- Reactions -->
                        <PostReactions ReactionSummary="@_post.ReactionSummary" />
                        
                        <!-- Footer Actions -->
                        <PostFooter 
                            Likes="@(_post.ReactionSummary?.TotalReactions ?? 0)"
                            Comments="@_post.CommentCount"
                            Shares="0"
                            Liked="@(_post.ReactionSummary?.UserReaction.HasValue ?? false)"
                            IsPostOwner="@(_post.Profile?.Id == _currentProfileId)"
                            PostLink="@($"/post/{_post.Id}")"
                            OnLike="@(() => HandleLike(_post))"
                            OnComment="@(() => HandleCommentClick(_post))"
                            OnShare="@(() => HandleShare(_post))"
                            OnEdit="@(() => HandleEdit(_post))"
                            OnDelete="@(() => HandleDelete(_post))" />
                        
                        <!-- Comments Section -->
                        <CommentSection PostId="@_post.Id"
                                        InitialCommentCount="@_post.CommentCount"
                                        IsExpanded="true" />
                    </div>
                </article>
            }
            else
            {
                <!-- Regular Post - Use PostCard -->
                <div class="feed">
                    <PostCard Post="_post"
                              CurrentProfileId="_currentProfileId"
                              OnLike="HandleLike"
                              OnCommentClick="HandleCommentClick"
                              OnShare="HandleShare"
                              OnEdit="HandleEdit"
                              OnDelete="HandleDelete" />
                </div>
            }
        }
    </div>
</div>

<style>
    .post-detail-page {
        min-height: 100vh;
        background: var(--mud-palette-background);
    }

    .post-detail-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem 1rem;
        background: var(--mud-palette-surface);
        border-bottom: 1px solid var(--mud-palette-lines-default);
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .post-detail-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
    }

    .post-detail-content .feed {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
    }

    .loading-container,
    .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        padding: 2rem;
    }

    /* Blog Detail Styles */
    .blog-detail {
        background: var(--mud-palette-surface);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--mud-elevation-2);
    }

    .blog-cover-image {
        width: 100%;
        max-height: 600px;
        overflow: hidden;
    }

    .blog-cover-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .blog-detail-content {
        padding: 24px;
    }

    .blog-author-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .blog-author {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .blog-author-info {
        display: flex;
        flex-direction: column;
    }

    .blog-author-name {
        font-weight: 600;
    }

    .blog-title {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.2;
        margin: 0 0 12px 0;
        color: var(--mud-palette-text-primary);
    }

    .blog-subtitle {
        font-size: 1.25rem;
        color: var(--mud-palette-text-secondary);
        margin: 0 0 24px 0;
        line-height: 1.5;
    }

    .blog-body {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--mud-palette-text-primary);
    }

    .blog-body p {
        margin-bottom: 1.5rem;
    }

    .blog-body h1, .blog-body h2, .blog-body h3 {
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .blog-body ul, .blog-body ol {
        margin-bottom: 1.5rem;
        padding-left: 2rem;
    }

    .blog-body li {
        margin-bottom: 0.5rem;
    }

    .blog-body blockquote {
        border-left: 4px solid var(--mud-palette-primary);
        padding-left: 1rem;
        margin: 1.5rem 0;
        font-style: italic;
        color: var(--mud-palette-text-secondary);
    }

    .blog-body pre {
        background: var(--mud-palette-background);
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
    }

    .blog-body code {
        background: var(--mud-palette-background);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
    }

    .blog-body img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1rem 0;
    }

    .blog-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 24px;
    }
</style>

@code {
    [Parameter]
    public Guid PostId { get; set; }

    private PostDto? _post;
    private bool _isLoading = true;
    private string? _error;
    private Guid _currentProfileId;
    private Guid _lastLoadedPostId;

    protected override async Task OnParametersSetAsync()
    {
        // Only load if PostId changed (prevents double-loading)
        if (PostId != _lastLoadedPostId)
        {
            _lastLoadedPostId = PostId;
            await LoadPost();
        }
    }

    private async Task LoadPost()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            // Load current user's profile for ownership check
            var currentProfile = await ProfilesClient.GetMyActiveProfileAsync();
            _currentProfileId = currentProfile?.Id ?? Guid.Empty;
            Logger.LogInformation("[PostDetail] Current user profile ID: {ProfileId}", _currentProfileId);

            Logger.LogInformation("[PostDetail] Loading post {PostId}", PostId);
            _post = await PostsClient.GetPostAsync(PostId);
            
            if (_post == null)
            {
                _error = "Post not found";
                Logger.LogWarning("[PostDetail] Post not found: {PostId}", PostId);
            }
            else
            {
                Logger.LogInformation("[PostDetail] Post loaded successfully: {PostId}, Post owner: {OwnerId}", PostId, _post.Profile?.Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[PostDetail] Error loading post {PostId}", PostId);
            _error = "Failed to load post. Please try again.";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/home");
    }

    private async Task HandleLike(PostDto post)
    {
        // PostCard handles reactions internally, reload to get updated state
        await LoadPost();
    }

    private Task HandleCommentClick(PostDto post)
    {
        // Comments are handled inline by PostCard
        return Task.CompletedTask;
    }

    private Task HandleShare(PostDto post)
    {
        // Share functionality - could copy link to clipboard
        return Task.CompletedTask;
    }

    private Task HandleEdit(PostDto post)
    {
        // Edit functionality - handled by PostCard's edit modal
        return Task.CompletedTask;
    }

    private void HandleEditBlog(PostDto post)
    {
        // Navigate to blog editor with the post ID
        Navigation.NavigateTo($"/blog/edit/{post.Id}");
    }

    private async Task HandleDelete(PostDto post)
    {
        try
        {
            await PostsClient.DeletePostAsync(post.Id);
            Navigation.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[PostDetail] Error deleting post {PostId}", post.Id);
        }
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        return string.Join(string.Empty, name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(p => char.ToUpperInvariant(p[0])));
    }

    private string FormatDate(DateTime date)
    {
        var now = DateTime.UtcNow;
        var diff = now - date;

        if (diff.TotalDays < 1)
            return date.ToString("h:mm tt");
        if (diff.TotalDays < 7)
            return date.ToString("ddd, MMM d");
        if (date.Year == now.Year)
            return date.ToString("MMM d");
        return date.ToString("MMM d, yyyy");
    }
}
