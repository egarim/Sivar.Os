    /// <summary>
    /// Load feed posts from API - shows activities from profiles the user follows
    /// </summary>
    private async Task LoadFeedActivitiesAsync()
    {
        try
        {
            Console.WriteLine("---------------------------------------------------------------");
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] START");
            Console.WriteLine($"  Current Profile ID: {_currentProfileId}");
            Console.WriteLine($"  Current Page: {_currentPage}");
            Console.WriteLine($"  Current Activities Count: {_activities?.Count ?? 0}");
            
            // Check if we have a valid profile ID
            if (_currentProfileId == Guid.Empty)
            {
                Console.WriteLine("[Home.LoadFeedActivitiesAsync] ?? No active profile ID - skipping activity load");
                _activities = new List<ActivityDto>();
                _totalPages = 0;
                StateHasChanged();
                Console.WriteLine("---------------------------------------------------------------");
                return;
            }
            
            // Load activities from profiles the user follows (their personalized feed)
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ?? Calling API: GetFeedActivitiesAsync(pageSize=10, pageNumber={_currentPage})");
            var feedDto = await SivarClient.Activities.GetFeedActivitiesAsync(pageSize: 10, pageNumber: _currentPage);
            
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ?? API Response received");
            
            if (feedDto == null)
            {
                Console.WriteLine("[Home.LoadFeedActivitiesAsync] ? Feed DTO is null!");
                _activities = new List<ActivityDto>();
                _totalPages = 0;
                StateHasChanged();
                Console.WriteLine("---------------------------------------------------------------");
                return;
            }
            
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] Feed DTO Details:");
            Console.WriteLine($"  Activities: {feedDto.Activities?.Count ?? 0} items");
            Console.WriteLine($"  TotalCount: {feedDto.TotalCount}");
            Console.WriteLine($"  TotalPages: {feedDto.TotalPages}");
            Console.WriteLine($"  CurrentPage: {feedDto.Page}");
            
            if (feedDto?.Activities != null && feedDto.Activities.Any())
            {
                Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ?? Processing {feedDto.Activities.Count} activities:");
                for (int i = 0; i < feedDto.Activities.Count; i++)
                {
                    var activity = feedDto.Activities[i];
                    Console.WriteLine($"  Activity {i + 1}:");
                    Console.WriteLine($"    ID: {activity.Id}");
                    Console.WriteLine($"    Verb: {activity.Verb}");
                    Console.WriteLine($"    Summary: {activity.Summary}");
                    Console.WriteLine($"    Actor: {activity.Actor?.DisplayName ?? "null"}");
                    Console.WriteLine($"    Post: {(activity.Post != null ? $"PostId={activity.Post.Id}" : "null")}");
                }
                
                _activities = feedDto.Activities;
                _totalPages = feedDto.TotalPages;
                
                Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ? Successfully assigned {_activities.Count} activities to _activities field");
                Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ? Total pages: {_totalPages}");
            }
            else
            {
                Console.WriteLine("[Home.LoadFeedActivitiesAsync] ?? No activities in response - feed is empty");
                _activities = new List<ActivityDto>();
                _totalPages = feedDto?.TotalPages ?? 0;
            }
            
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ?? Calling StateHasChanged()...");
            StateHasChanged();
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ? StateHasChanged() completed");
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] FINAL: _activities.Count = {_activities?.Count ?? 0}");
            Console.WriteLine("---------------------------------------------------------------");
        }
        catch (Exception ex)
        {
            Console.WriteLine("---------------------------------------------------------------");
            Console.WriteLine($"[Home.LoadFeedActivitiesAsync] ? ERROR!");
            Console.WriteLine($"  Message: {ex.Message}");
            Console.WriteLine($"  Type: {ex.GetType().Name}");
            Console.WriteLine($"  Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"  Inner Exception: {ex.InnerException.Message}");
            }
            Console.WriteLine("---------------------------------------------------------------");
            _activities = new List<ActivityDto>();
            _totalPages = 0;
            StateHasChanged();
        }
    }

