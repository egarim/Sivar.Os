    private async Task<string> GetMockResponseAsync(string userText)
    {
        await Task.Delay(600 + _random.Next(300));

        if (string.IsNullOrWhiteSpace(userText))
        {
            return _cannedReplies[_random.Next(_cannedReplies.Length)];
        }

        var lower = userText.ToLowerInvariant();

        // Pizza search - returns special handling flag
        if (lower.Contains("pizza") || lower.Contains("??"))
        {
            return "PIZZA_SEARCH";
        }

        // Tech companies search
        if (lower.Contains("tech") || lower.Contains("company") || lower.Contains("companies") || lower.Contains("??"))
        {
            return "TECH_SEARCH";
        }

        // Events search
        if (lower.Contains("event") || lower.Contains("??"))
        {
            return "EVENT_SEARCH";
        }

        // Jobs search
        if (lower.Contains("job") || lower.Contains("jobs") || lower.Contains("hiring"))
        {
            return "JOB_SEARCH";
        }

        if (lower.Contains("help") || lower.Contains("how") || lower.Contains("what"))
        {
            return "Sure � what specifically do you need help with?";
        }

        if (lower.Contains("bug") || lower.Contains("error") || lower.Contains("fail"))
        {
            return "Sorry to hear that. Can you share the steps to reproduce?";
        }

        if (lower.Contains("design") || lower.Contains("ui") || lower.Contains("layout"))
        {
            return "For design feedback, consider spacing, contrast, and alignment � need a checklist?";
        }

        if (lower.Contains("yes") || lower.Contains("ok") || lower.Contains("thanks"))
        {
            return _cannedReplies[_random.Next(_cannedReplies.Length)];
        }

        var shortEcho = userText.Length > 70 ? $"{userText[..67]}�" : userText;
        return $"You said: \"{shortEcho}\" � I can expand on that if you'd like.";
    }

