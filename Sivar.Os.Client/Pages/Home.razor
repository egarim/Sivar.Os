    /// <summary>
    /// Fallback approach: ensure user and profile are created after successful Keycloak login
    /// This is called on home page load after authentication
    /// </summary>
    private async Task EnsureUserAndProfileCreatedAsync()
    {
        try
        {
            Console.WriteLine("[Home.EnsureUserAndProfileCreatedAsync] START");
            
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (!user.Identity?.IsAuthenticated ?? true)
            {
                Console.WriteLine("[Home.EnsureUserAndProfileCreatedAsync] ?? User not authenticated");
                return; // User not authenticated, nothing to do
            }

            // Extract Keycloak claims using helper method
            var (keycloakId, email, firstName, lastName) = ExtractKeycloakClaims(user);

            if (string.IsNullOrEmpty(keycloakId))
            {
                Console.WriteLine("[Home.EnsureUserAndProfileCreatedAsync] ? Missing required claim 'sub' (subject identifier)");
                return;
            }

            if (string.IsNullOrEmpty(email))
            {
                Console.WriteLine("[Home.EnsureUserAndProfileCreatedAsync] ? Missing required claim 'email' or 'preferred_username'");
                return;
            }

            Console.WriteLine("[Home.EnsureUserAndProfileCreatedAsync] Calling authentication service");

            // Call authentication service via SivarClient
            var authInfo = new UserAuthenticationInfo
            {
                Email = email,
                FirstName = firstName,
                LastName = lastName,
                Role = "RegisteredUser"
            };

            var result = await SivarClient.Auth.AuthenticateUserAsync(keycloakId, authInfo);
            
            if (result.IsSuccess)
            {
                _currentUserId = result.User?.Id ?? Guid.Empty;
                _currentProfileId = result.ActiveProfile?.Id ?? Guid.Empty;
                
                if (result.IsNewUser)
                {
                    Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync] ? New user and profile created");
                    Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - User ID: {_currentUserId}");
                    Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - Profile ID: {_currentProfileId}");
                }
                else
                {
                    Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync] ? Existing user authenticated");
                    Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - User ID: {_currentUserId}");
                    Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - Profile ID: {_currentProfileId}");
                }
            }
            else
            {
                Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync] ? Authentication failed: {result.ErrorMessage}");
                Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - IsSuccess: {result.IsSuccess}");
                Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - IsNewUser: {result.IsNewUser}");
                Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - User ID: {result.User?.Id}");
                Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync]   - Profile ID: {result.ActiveProfile?.Id}");
            }
            
            Console.WriteLine("[Home.EnsureUserAndProfileCreatedAsync] END");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync] ? Error: {ex.Message}");
            Console.WriteLine($"[Home.EnsureUserAndProfileCreatedAsync] Stack trace: {ex.StackTrace}");
            // Don't throw - this is a best-effort operation
        }
    }

    /// <summary>
    /// Helper method to extract and log Keycloak claims for debugging
    /// </summary>
    private (string? keycloakId, string? email, string firstName, string lastName) ExtractKeycloakClaims(ClaimsPrincipal user)
    {
        Console.WriteLine("[Home] Extracting Keycloak claims - Available claims:");
        foreach (var claim in user.Claims)
        {
            Console.WriteLine($"  {claim.Type}: {claim.Value}");
        }

        string? keycloakId = user.FindFirst("sub")?.Value
                          ?? user.FindFirst("user_id")?.Value
                          ?? user.FindFirst("id")?.Value;

        string? email = user.FindFirst("email")?.Value
                     ?? user.FindFirst("preferred_username")?.Value
                     ?? user.FindFirst("upn")?.Value;

        string firstName = user.FindFirst("given_name")?.Value
                        ?? user.FindFirst("firstName")?.Value
                        ?? user.FindFirst("name")?.Value
                        ?? "";

        string lastName = user.FindFirst("family_name")?.Value
                       ?? user.FindFirst("lastName")?.Value
                       ?? user.FindFirst("surname")?.Value
                       ?? "";

        Console.WriteLine($"[Home] Extracted - Keycloak ID: {keycloakId}, Email: {email}, First Name: {firstName}, Last Name: {lastName}");
        return (keycloakId, email, firstName, lastName);
    }

    
    
