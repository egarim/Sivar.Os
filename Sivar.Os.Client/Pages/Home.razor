    /// </summary>
    private async Task HandleCreateProfile(CreateAnyProfileDto request)
    {
        try
        {
            Console.WriteLine("---------------------------------------------------------------");
            Console.WriteLine("[Home.HandleCreateProfile] START - Creating new profile");
            Console.WriteLine($"  DisplayName: {request.DisplayName}");
            Console.WriteLine($"  ProfileTypeId: {request.ProfileTypeId}");
            Console.WriteLine($"  SetAsActive: {request.SetAsActive}");
            Console.WriteLine($"  Visibility: {request.VisibilityLevel}");
            Console.WriteLine($"  Bio: {request.Bio}");
            Console.WriteLine($"  Avatar: {request.Avatar}");
            Console.WriteLine($"  Tags: {request.Tags}");
            Console.WriteLine("---------------------------------------------------------------");

            // Step 1: Call the SivarClient to create the profile
            Console.WriteLine("[Home.HandleCreateProfile] STEP 1: Calling SivarClient.Profiles.CreateProfileAsync()");
            var newProfile = await SivarClient.Profiles.CreateProfileAsync(request);
            
            if (newProfile != null)
            {
                Console.WriteLine($"[Home.HandleCreateProfile] STEP 2: ? Profile created successfully!");
                Console.WriteLine($"  Profile ID: {newProfile.Id}");
                Console.WriteLine($"  Profile Name: {newProfile.DisplayName}");
                Console.WriteLine($"  Profile Type: {newProfile.ProfileType?.DisplayName}");
                
                // ? ALWAYS auto-select the new profile (if SetAsActive is true)
                Console.WriteLine($"[Home.HandleCreateProfile] STEP 3: SetAsActive={request.SetAsActive}, attempting to auto-select");
                
                if (request.SetAsActive)
                {
                    try
                    {
                        var activeProfileResult = await SivarClient.Profiles.SetMyActiveProfileAsync(newProfile.Id);
                        Console.WriteLine($"[Home.HandleCreateProfile] STEP 3: ? SetMyActiveProfileAsync succeeded!");
                        Console.WriteLine($"  Returned Profile ID: {activeProfileResult?.Id}");
                    }
                    catch (Exception setActiveEx)
                    {
                        Console.WriteLine($"[Home.HandleCreateProfile] STEP 3: ?? SetMyActiveProfileAsync failed!");
                        Console.WriteLine($"  Exception: {setActiveEx.GetType().Name}");
                        Console.WriteLine($"  Message: {setActiveEx.Message}");
                        Console.WriteLine("  Continuing anyway - profile was created successfully");
                    }
                }
                else
                {
                    Console.WriteLine($"[Home.HandleCreateProfile] STEP 3: Skipping auto-select (SetAsActive=false)");
                }
                
                // ? Reset pagination
                _currentPage = 1;
                Console.WriteLine("[Home.HandleCreateProfile] STEP 4: Reset pagination to page 1");
                
                // Reload profiles after creation to get the updated list with the new profile
                Console.WriteLine("[Home.HandleCreateProfile] STEP 5: Reloading user profiles");
                await LoadUserProfilesAsync();
                Console.WriteLine("[Home.HandleCreateProfile] STEP 5: User profiles reloaded");
                Console.WriteLine($"[Home.HandleCreateProfile] STEP 5: Active profile is now: {_activeProfile?.DisplayName} (ID: {_activeProfile?.Id})");
                
                // Update current profile ID to match the active profile (which should be the newly created one if SetAsActive=true)
                _currentProfileId = _activeProfile?.Id ?? newProfile.Id;
                Console.WriteLine($"[Home.HandleCreateProfile] STEP 6: Updated _currentProfileId to {_currentProfileId}");
                
                // ? Reload activities for the new profile
                Console.WriteLine("[Home.HandleCreateProfile] STEP 7: Loading feed for new profile");
                await LoadFeedActivitiesAsync();
                Console.WriteLine("[Home.HandleCreateProfile] STEP 7: Feed loaded successfully");
                
                StateHasChanged();
