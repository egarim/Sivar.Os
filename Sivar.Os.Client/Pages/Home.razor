<MudContainer MaxWidth="MaxWidth.False" Class="wire-container wireframe-landing">
    <Header @bind-ProfileType="@_profileType"
            @bind-UserName="@_userName"
            @bind-UserEmail="@_userEmail"
            UserInitials="@GetUserInitials()"
            IsLoading="@_isUserLoading"
            ShowThemeToggle="true"
            ShowLogout="true"
            ThemeIcon="@(_layout?.DarkLightModeButtonIcon ?? Icons.Material.Outlined.DarkMode)"
            OnThemeToggle="@HandleThemeToggle"
            OnLogout="@HandleLogout" />

    <div class="main-layout">
        <!-- Left spacer (empty on mobile) -->
        <div></div>

        <!-- Center: Main Feed -->
        <div class="feed">
            <FeedHeader Title="@($"{_profileType.ToUpper()} FEED")"
                        Subtitle="See what's happening in your network" />

            <PostComposer ProfileTypeTitle="@GetProfileTypeTitle()"
                          @bind-SelectedType="@_selectedPostType"
                          PostText="@_postText"
                          PostTextChanged="@HandlePostTextInputChanged"
                          @bind-ActiveAttachment="@_activeAttachment"
                          @bind-ScheduledDate="@_scheduledDate"
                          @bind-ScheduledTime="@_scheduledTime"
                          @bind-ScheduledLocation="@_scheduledLocation"
                          @bind-PostVisibility="@_postVisibility"
                          @bind-PostLanguage="@_postLanguage"
                          @bind-PostTags="@_postTags"
                          @bind-PostLocation="@_postLocation"
                          @bind-PostBusinessMetadata="@_postBusinessMetadata"
                          IsBusinessProfile="@(_profileType == "business")"
                          OnPublish="@(() => HandlePostSubmitAsync())" />

            @foreach (var post in _posts)
            {
                <PostCard Post="@post"
                          CurrentUserId="@_currentUserId"
                          OnLike="@(() => ToggleLike(post))"
                          OnCommentClick="@(() => ToggleComments(post))"
                          OnShare="@(() => SharePost(post))"
                          OnSave="@(() => SavePost(post))"
                          OnEdit="@(() => HandleEditPost(post))"
                          OnDelete="@(() => HandleDeletePost(post))"
                          OnViewAnalytics="@(() => HandleViewAnalytics(post))"
                          OnReport="@(() => HandleReportPost(post))"
                          OnCopyLink="@(() => HandleCopyPostLink(post))"
                          OnAuthorClick="@((author) => ViewProfile(author))" />
            }

            <Pagination CurrentPage="@_currentPage"
                        PageCount="@_totalPages"
                        TotalItems="@(_posts.Count)"
                        ItemName="posts"
                        OnPrevious="@(() => PreviousPage())"
                        OnNext="@(() => NextPage())" />
        </div>

        <!-- Right: Stats + Who to Follow -->
        <div>
            <StatsPanel Stats="@GetStatsList()"
                        SavedItems="@_savedResults"
                        OnRemoveSaved="@((id) => RemoveSavedResultById(id))" />

            <WhoToFollowSidebar SuggestedUsers="@_suggestedUsers"
                                OnFollowToggle="@((user) => ToggleFollow(user))"
                                OnUserNameClick="@((name) => ViewProfile(name))" />
        </div>
    </div>

    <!-- AI Chat Floating Button & Panel -->
    <AIFloatingButton OnClick="@(() => _chatOpen = !_chatOpen)" />

    <AIChatPanel IsOpen="@_chatOpen"
                 ShowHistory="@_historyOpen"
                 CurrentConversationId="@_currentConversationId"
                 Conversations="@_conversations"
                 Messages="@_chatMessages"
                 InputText="@_chatInput"
                 IsTyping="@_isTyping"
                 OnClose="@(() => _chatOpen = !_chatOpen)"
                 OnToggleHistory="@(() => ToggleHistory())"
                 OnNewConversation="@(() => NewConversation())"
                 OnConversationSelect="@((conversationId) => SelectConversationById(conversationId))"
                 OnSendMessage="@(() => SendChat())"
                 InputTextChanged="@((text) => _chatInput = text)"
                 OnQuickAction="@((action) => HandleQuickAction(action))"
                 OnResultView="@(() => {})"
                 OnResultSave="@(() => {})"
                 OnResultFollow="@(() => {})" />
</MudContainer>

