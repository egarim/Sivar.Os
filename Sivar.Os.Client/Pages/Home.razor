    private async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(_chatInput)) return;

        var userMessage = new ChatMessage("user", _chatInput);
        AddMessage(_currentConversationId, userMessage);

        var userQuery = _chatInput;
        _chatInput = string.Empty;
        _isTyping = true;
        StateHasChanged();
        await ScrollChatToBottom();

        var aiResponse = await GetMockResponseAsync(userQuery);

        _isTyping = false;

        // Special handling for search results
        if (aiResponse == "PIZZA_SEARCH")
        {
            var resultMessage = new ChatMessage("ai", "I found 3 pizza places near you:", "result-card");
            AddMessage(_currentConversationId, resultMessage);

            // Add result cards
            var pizzaResults = new[]
            {
                new ChatResultCard("p1", "🍕", "Joe's Pizza Palace", "Restaurant", "Classic NY-style pizza • 4.8★ • $$ • Open now"),
                new ChatResultCard("p2", "🍕", "Maria's Pizzeria", "Restaurant", "Authentic Italian wood-fired • 4.9★ • $$$ • Closes 10pm"),
                new ChatResultCard("p3", "🍕", "Pizza Express", "Fast Food", "Quick delivery & takeout • 4.2★ • $ • Open 24hrs")
            };

            foreach (var card in pizzaResults)
            {
                var cardMessage = new ChatMessage("ai", "", "result-card") { ResultCard = card };
                AddMessage(_currentConversationId, cardMessage);
            }
        }
        else if (aiResponse == "TECH_SEARCH")
        {
            var resultMessage = new ChatMessage("ai", "Here are tech companies in your area:", "result-card");
            AddMessage(_currentConversationId, resultMessage);

            var techResults = new[]
            {
                new ChatResultCard("t1", "💼", "TechCorp Solutions", "Technology", "Cloud services & AI development • 200+ employees"),
                new ChatResultCard("t2", "💼", "Innovation Labs", "Startup", "Mobile app development • Series A funded"),
                new ChatResultCard("t3", "💼", "DataWorks Inc", "Enterprise", "Big data analytics platform • Fortune 500")
            };

            foreach (var card in techResults)
            {
                var cardMessage = new ChatMessage("ai", "", "result-card") { ResultCard = card };
                AddMessage(_currentConversationId, cardMessage);
            }
        }
        else if (aiResponse == "EVENT_SEARCH")
        {
            var resultMessage = new ChatMessage("ai", "Upcoming events you might like:", "result-card");
            AddMessage(_currentConversationId, resultMessage);

            var eventResults = new[]
            {
                new ChatResultCard("e1", "🎉", "Tech Conference 2024", "Conference", "3-day tech summit • Mar 15-17 • Downtown Center"),
                new ChatResultCard("e2", "🎉", "Startup Pitch Night", "Networking", "Monthly startup showcase • Mar 10 • 6pm"),
                new ChatResultCard("e3", "🎉", "Code & Coffee", "Meetup", "Weekly developer hangout • Every Saturday")
            };

            foreach (var card in eventResults)
            {
                var cardMessage = new ChatMessage("ai", "", "result-card") { ResultCard = card };
                AddMessage(_currentConversationId, cardMessage);
            }
        }
        else if (aiResponse == "JOB_SEARCH")
        {
            var resultMessage = new ChatMessage("ai", "Here are job openings matching your profile:", "result-card");
            AddMessage(_currentConversationId, resultMessage);

            var jobResults = new[]
            {
                new ChatResultCard("j1", "💼", "Senior Developer", "TechCorp", "Full-stack position • $120k-150k • Remote available"),
                new ChatResultCard("j2", "💼", "UX Designer", "Design Studio", "Lead designer role • $90k-110k • Hybrid"),
                new ChatResultCard("j3", "💼", "Product Manager", "StartupXYZ", "PM for AI products • $130k-160k • On-site")
            };

            foreach (var card in jobResults)
            {
                var cardMessage = new ChatMessage("ai", "", "result-card") { ResultCard = card };
                AddMessage(_currentConversationId, cardMessage);
            }
        }
        else
        {
            // Regular text response
            var aiMessage = new ChatMessage("ai", aiResponse);
            AddMessage(_currentConversationId, aiMessage);
        }

        UpdateConversationPreview(_currentConversationId);
        StateHasChanged();
        await ScrollChatToBottom();
