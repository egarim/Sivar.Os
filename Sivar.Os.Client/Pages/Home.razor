    /// <summary>
    /// Load feed posts from API
    /// </summary>
    private async Task LoadFeedPostsAsync()
    {
        try
        {
            Console.WriteLine($"[Home.LoadFeedPostsAsync] START - Current profile: {_currentProfileId}, Page: {_currentPage}");
            
            if (_currentProfileId == Guid.Empty)
            {
                Console.WriteLine("[Home.LoadFeedPostsAsync] ⚠️ Profile ID is empty, cannot load feed");
                _posts = new List<PostDto>();
                StateHasChanged();
                return;
            }
            
            Console.WriteLine($"[Home.LoadFeedPostsAsync] Calling GetFeedPostsAsync with pageSize=10, pageNumber={_currentPage}");
            var feedDto = await SivarClient.Posts.GetFeedPostsAsync(pageSize: 10, pageNumber: _currentPage);
            
            if (feedDto == null)
            {
                Console.WriteLine("[Home.LoadFeedPostsAsync] ❌ Feed DTO is null");
                _posts = new List<PostDto>();
                _totalPages = 0;
                StateHasChanged();
                return;
            }
            
            Console.WriteLine($"[Home.LoadFeedPostsAsync] Feed DTO received - Posts count: {feedDto.Posts?.Count ?? 0}, Total: {feedDto.TotalCount}, Pages: {feedDto.TotalPages}");
            
            if (feedDto?.Posts != null && feedDto.Posts.Any())
            {
                _posts = feedDto.Posts;
                _totalPages = feedDto.TotalPages;
                
                Console.WriteLine($"[Home.LoadFeedPostsAsync] ✓ Successfully loaded {_posts.Count} posts (Page {feedDto.Page + 1} of {feedDto.TotalPages})");
            }
            else
            {
                Console.WriteLine("[Home.LoadFeedPostsAsync] ⚠️ No posts found in feed");
                _posts = new List<PostDto>();
                _totalPages = feedDto?.TotalPages ?? 0;
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Home.LoadFeedPostsAsync] ❌ Error loading feed posts: {ex.Message}");
            Console.WriteLine($"[Home.LoadFeedPostsAsync] Stack trace: {ex.StackTrace}");
            _posts = new List<PostDto>();
            _totalPages = 0;
            StateHasChanged();
        }
    }

