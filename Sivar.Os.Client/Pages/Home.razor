    /// <summary>
    /// Handle post submission - create new post via API
    /// </summary>
    private async Task HandlePostSubmitAsync()
    {
        try
        {
            Console.WriteLine($"[Home] [HandlePostSubmitAsync] Called - _postText='{_postText}' (length={_postText?.Length ?? 0})");
            
            // Validate post content
            if (string.IsNullOrWhiteSpace(_postText))
            {
                Console.WriteLine("[Home] Post text is empty - cannot submit");
                return;
            }

            Console.WriteLine("[Home] Submitting new post...");

            // Convert string to PostType enum
            var postType = Enum.TryParse<PostType>(_selectedPostType, ignoreCase: true, out var pt) 
                ? pt 
                : PostType.General;
            
            // Build CreatePostDto with all fields from PostComposer - INCLUDE ProfileId from active profile
            var createPostDto = new CreatePostDto
            {
                ProfileId = _currentProfileId,  // Send active profile ID to server
                Content = _postText,
                PostType = postType,
                Visibility = _postVisibility,
                Language = _postLanguage,
                Tags = _postTags ?? new(),
                Location = !string.IsNullOrEmpty(_postLocation?.City) 
                    ? _postLocation
                    : null,
                BusinessMetadata = !string.IsNullOrEmpty(_postBusinessMetadata)
                    ? _postBusinessMetadata
                    : null,
                Attachments = new()  // TODO: Handle attachments from _activeAttachment
            };

            var newPost = await SivarClient.Posts.CreatePostAsync(createPostDto);
            
            if (newPost != null)
            {
                Console.WriteLine($"[Home] Post created successfully: {newPost.Id}");
                
                // Add new post to beginning of feed (most recent first)
                _posts.Insert(0, newPost);
                
                // Clear form
                _postText = string.Empty;
                _selectedPostType = "general";
                _activeAttachment = null;
                _scheduledDate = null;
                _scheduledTime = null;
                _scheduledLocation = string.Empty;
                
                // Clear advanced options
                _postVisibility = VisibilityLevel.Public;
                _postLanguage = "en";
                _postTags = new();
                _postLocation = new() { City = string.Empty };
                _postBusinessMetadata = string.Empty;
                
                StateHasChanged();
            }
        }
        catch (SivarApiException apiEx)
        {
            Console.WriteLine($"[Home] ❌ API Error submitting post:");
            Console.WriteLine($"[Home]   Status: {apiEx.StatusCode}");
            Console.WriteLine($"[Home]   Reason: {apiEx.ReasonPhrase}");
            Console.WriteLine($"[Home]   Details: {apiEx.Content}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Home] ❌ Error submitting post: {ex.GetType().Name}: {ex.Message}");
            Console.WriteLine($"[Home] Stack Trace: {ex.StackTrace}");
        }
    }
