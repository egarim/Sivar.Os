    protected override async Task OnInitializedAsync()
    {
        try
        {
            Console.WriteLine("[Home] ==================== OnInitializedAsync START ====================");
            
            // Initialize sample data
            InitializeSampleData();

            // Ensure user and profile are created after Keycloak login
            Console.WriteLine("[Home] Step 1: Ensuring user and profile are created");
            await EnsureUserAndProfileCreatedAsync();
            
            // Load current user info
