    {
        if (string.IsNullOrEmpty(_userName) || _userName.Length < 2)
            return "?";

        var parts = _userName.Split(' ');
        return parts.Length > 1
            ? $"{parts[0][0]}{parts[1][0]}"
            : _userName.Substring(0, Math.Min(2, _userName.Length));
    }

