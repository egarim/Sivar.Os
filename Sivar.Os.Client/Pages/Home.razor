    {
        Followers = 1234,
        Following = 567,
        Reach = 12450,
        ResponseRate = 89
    };

    private List<SavedResultItem> _savedResults = new();

    // Who to Follow
    private List<ProfileDto> _suggestedUsers = new();

    // AI Chat State
    private bool _chatOpen;
    private bool _historyOpen;
    private string _chatInput = string.Empty;
    private string _currentConversationId = string.Empty;
