    private async Task LoadCurrentUserAsync()
    {
        try
        {
            Console.WriteLine("[HOME-CLIENT] ======================================");
            Console.WriteLine("[HOME-CLIENT] 📍 START: LoadCurrentUserAsync");
            Console.WriteLine("[HOME-CLIENT] Time: " + DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss.fff"));
            Console.WriteLine("[HOME-CLIENT] ======================================");
            
            _isUserLoading = true;
            StateHasChanged();
            
            // Load user information
            Console.WriteLine("[HOME-CLIENT] 🔄 Calling SivarClient.Users.GetMeAsync()...");
            var userDto = await SivarClient.Users.GetMeAsync();
            
            if (userDto != null)
            {
                _userName = $"{userDto.FirstName} {userDto.LastName}".Trim();
                _userEmail = userDto.Email ?? "no-email";
                _currentUserId = userDto.Id;
                
                Console.WriteLine("[HOME-CLIENT] ✅ User DTO Received:");
                Console.WriteLine($"[HOME-CLIENT]   - ID: {userDto.Id}");
                Console.WriteLine($"[HOME-CLIENT]   - First Name: {userDto.FirstName}");
                Console.WriteLine($"[HOME-CLIENT]   - Last Name: {userDto.LastName}");
                Console.WriteLine($"[HOME-CLIENT]   - Email: {userDto.Email}");
                Console.WriteLine($"[HOME-CLIENT]   - Full Name: {_userName}");
                Console.WriteLine($"[HOME-CLIENT]   - Combined Email: {_userEmail}");
                
                // Also load the active profile to get profile-specific data
                Console.WriteLine("[HOME-CLIENT] 🔄 Calling SivarClient.Profiles.GetMyActiveProfileAsync()...");
                try
                {
                    var activeProfile = await SivarClient.Profiles.GetMyActiveProfileAsync();
                    
                    if (activeProfile != null)
                    {
                        // Use profile's display name if available, otherwise use user's full name
                        if (!string.IsNullOrWhiteSpace(activeProfile.DisplayName))
                        {
                            _userName = activeProfile.DisplayName;
                        }
                        
                        _currentProfileId = activeProfile.Id;
                        
                        Console.WriteLine("[HOME-CLIENT] ✅ Active Profile DTO Received:");
                        Console.WriteLine($"[HOME-CLIENT]   - ID: {activeProfile.Id}");
                        Console.WriteLine($"[HOME-CLIENT]   - DisplayName: {activeProfile.DisplayName}");
                        Console.WriteLine($"[HOME-CLIENT]   - Avatar: {activeProfile.Avatar}");
                        Console.WriteLine($"[HOME-CLIENT]   - LocationDisplay: {activeProfile.LocationDisplay}");
                    }
                    else
                    {
                        Console.WriteLine("[HOME-CLIENT] ⚠️  Active Profile DTO is NULL!");
                    }
                }
                catch (Exception profileEx)
                {
                    Console.WriteLine($"[HOME-CLIENT] ⚠️  Error loading active profile (non-fatal): {profileEx.Message}");
                    // Continue with user data even if profile loading fails
                }
                
                // Update UI with user data
                _isUserLoading = false;
                StateHasChanged();
                
                Console.WriteLine("[HOME-CLIENT] ✅ StateHasChanged() called");
                Console.WriteLine("[HOME-CLIENT] ✅ User loaded successfully!");
            }
            else
            {
                Console.WriteLine("[HOME-CLIENT] ⚠️  User DTO is NULL!");
                _isUserLoading = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("[HOME-CLIENT] ❌ ERROR in LoadCurrentUserAsync:");
            Console.WriteLine($"[HOME-CLIENT]   Exception: {ex.GetType().Name}");
            Console.WriteLine($"[HOME-CLIENT]   Message: {ex.Message}");
            Console.WriteLine($"[HOME-CLIENT]   Stack Trace: {ex.StackTrace}");
            
            _userName = "Error Loading";
            _userEmail = "Check console";
            _isUserLoading = false;
            StateHasChanged();
        }
        finally
        {
            Console.WriteLine("[HOME-CLIENT] ======================================");
            Console.WriteLine("[HOME-CLIENT] 📍 END: LoadCurrentUserAsync");
            Console.WriteLine("[HOME-CLIENT] ======================================");
        }
    }

    /// <summary>
    /// Get user initials from display name for avatar
    /// </summary>
    private string GetUserInitials()
    {
        if (string.IsNullOrEmpty(_userName)) return "?";
        var parts = _userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return $"{parts[0][0]}{parts[parts.Length - 1][0]}".ToUpper();
    }

