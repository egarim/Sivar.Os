@page "/weather"
@using Microsoft.Extensions.Localization
@using Sivar.Os.Shared.Services
@using System.Security.Claims
@* Using InteractiveServer (set at App.razor level) *@
@inject IWeatherService WeatherService
@inject IStringLocalizer<Weather> Localizer

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudText Typo="Typo.h3" GutterBottom="true">@Localizer["Heading"]</MudText>
        <MudText Typo="Typo.body1" Class="mb-8">@Localizer["Description"]</MudText>

        @if (forecasts == null)
        {
            <MudProgressCircular Color="Color.Default" Indeterminate="true" />
        }
        else
        {
          <MudTable Items="forecasts" Hover="true" SortLabel="@Localizer["SortBy"]" Elevation="0" AllowUnsorted="false">
                <HeaderContent>
                    <MudTh><MudTableSortLabel InitialDirection="SortDirection.Ascending" SortBy="new Func<WeatherForecast, object>(x=>x.Date)">@Localizer["DateColumn"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<WeatherForecast, object>(x=>x.TemperatureC)">@Localizer["TempCColumn"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<WeatherForecast, object>(x=>x.TemperatureF)">@Localizer["TempFColumn"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<WeatherForecast, object>(x=>x.Summary!)">@Localizer["SummaryColumn"]</MudTableSortLabel></MudTh>
                </HeaderContent>
                <RowTemplate Context="forecast">
                    <MudTd DataLabel="@Localizer["DateColumn"]">@forecast.Date</MudTd>
                    <MudTd DataLabel="@Localizer["TempCColumn"]">@forecast.TemperatureC</MudTd>
                    <MudTd DataLabel="@Localizer["TempFColumn"]">@forecast.TemperatureF</MudTd>
                    <MudTd DataLabel="@Localizer["SummaryColumn"]">@forecast.Summary</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[]{50, 100}" />
                </PagerContent>
            </MudTable>
        }
    </Authorized>
    <NotAuthorized>
        <MudAlert Severity="Severity.Warning" Class="mb-4">@Localizer["NotAuthorizedMessage"]</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/authentication/login">@Localizer["SignInButton"]</MudButton>
    </NotAuthorized>
</AuthorizeView>

@code {
    private WeatherForecast[]? forecasts;

    protected override async Task OnInitializedAsync()
    {
        // Only load data if user is authenticated
        // The AuthorizeView wrapper ensures we only render the data when authorized
        // Simulate asynchronous loading to demonstrate a loading indicator
        await Task.Delay(500);

        try
        {
            forecasts = await WeatherService.GetForecastAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading weather: {ex.Message}");
            forecasts = Array.Empty<WeatherForecast>();
        }
    }
}
