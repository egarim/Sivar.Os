@page "/app/explore/{Handle}"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using MudBlazor
@using Microsoft.Extensions.Localization
@using Sivar.Os.Client.Components.Feed
@using Sivar.Os.Client.Components.Shared
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Shared.Enums
@using Sivar.Os.Shared
@inject ISivarClient SivarClient
@inject NavigationManager Navigation
@inject IStringLocalizer<PublicProfile> Localizer
@inject ISnackbar Snackbar

<PageTitle>@(_profile?.DisplayName ?? Handle) - Sivar.Os</PageTitle>

<div class="public-profile-page">
    @if (_isLoading)
    {
        <div class="loading-container">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-3">Loading profile...</MudText>
        </div>
    }
    else if (_error != null)
    {
        <div class="error-container">
            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-3">@_error</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="@(() => Navigation.NavigateTo("/app/explore"))">
                Back to Explore
            </MudButton>
        </div>
    }
    else if (_profile != null)
    {
        <!-- Profile Header -->
        <div class="profile-header-section">
            <MudPaper Class="profile-card" Elevation="1">
                <div class="profile-main">
                    <MudAvatar Size="Size.Large" Color="Color.Primary" Class="profile-avatar">
                        @if (!string.IsNullOrEmpty(_profile.Avatar))
                        {
                            <MudImage Src="@_profile.Avatar" Alt="@_profile.DisplayName" />
                        }
                        else
                        {
                            @GetInitials(_profile.DisplayName)
                        }
                    </MudAvatar>
                    <div class="profile-details">
                        <MudText Typo="Typo.h6" Class="profile-name">@_profile.DisplayName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="profile-handle">@@@_profile.Handle</MudText>
                        @if (_profile.ProfileType != null)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                @_profile.ProfileType.DisplayName
                            </MudChip>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_profile.Bio))
                {
                    <div class="profile-bio">
                        <MudText Typo="Typo.body2">@_profile.Bio</MudText>
                    </div>
                }

                <div class="profile-stats">
                    <div class="stat">
                        <MudText Typo="Typo.subtitle1" Class="stat-value">@_totalPosts</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Posts</MudText>
                    </div>
                    <div class="stat">
                        <MudText Typo="Typo.subtitle1" Class="stat-value">@_profile.ViewCount</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Views</MudText>
                    </div>
                </div>

                <!-- CTA Buttons (prompt login) -->
                <div class="profile-actions">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="PromptLogin">
                        Follow
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.Message"
                               OnClick="PromptLogin">
                        Message
                    </MudButton>
                </div>
            </MudPaper>
        </div>

        <!-- Join CTA Banner -->
        <JoinCta DisplayVariant="banner" />

        <!-- Posts Section -->
        <div class="posts-section">
            <MudText Typo="Typo.h6" Class="section-title">Posts</MudText>
            
            @if (_isLoadingPosts)
            {
                <FeedSkeleton Count="3" />
            }
            else if (_posts.Count == 0)
            {
                <MudPaper Class="empty-state" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Outlined.Article" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary">No posts yet</MudText>
                </MudPaper>
            }
            else
            {
                <div class="posts-grid">
                    @foreach (var post in _posts)
                    {
                        @if (post.PostType == PostType.Blog)
                        {
                            <BlogCard Post="@post" 
                                      OnClick="@(p => NavigateToPost(p.Id))"
                                      OnAuthorClick="@(author => {})" />
                        }
                        else
                        {
                            <PublicPostCard Post="@post" 
                                            OnInteraction="HandleInteraction" />
                        }
                    }
                </div>
                
                @if (_hasMore)
                {
                    <div class="load-more-container">
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Primary"
                                   OnClick="LoadMorePosts"
                                   Disabled="_isLoadingMore">
                            @if (_isLoadingMore)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Load More
                        </MudButton>
                    </div>
                }
            }
        </div>
    }
</div>

<style>
    .public-profile-page {
        min-height: 100vh;
        background: var(--mud-palette-background-gray, #f5f7fa);
        padding: 16px;
    }

    .loading-container,
    .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        text-align: center;
    }

    .profile-header-section {
        max-width: 680px;
        margin: 0 auto 16px;
    }

    .profile-card {
        border-radius: 12px;
        padding: 20px;
        background: var(--mud-palette-surface);
    }

    .profile-main {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 16px;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        font-size: 28px;
        background: linear-gradient(135deg, var(--mud-palette-primary), #42a5f5);
    }

    .profile-details {
        flex: 1;
    }

    .profile-name {
        font-weight: 600;
        margin-bottom: 2px;
    }

    .profile-handle {
        margin-bottom: 8px;
    }

    .profile-bio {
        margin-bottom: 16px;
        padding-top: 12px;
        border-top: 1px solid var(--mud-palette-lines-default, #e0e0e0);
    }

    .profile-stats {
        display: flex;
        gap: 32px;
        padding: 12px 0;
        border-top: 1px solid var(--mud-palette-lines-default, #e0e0e0);
        border-bottom: 1px solid var(--mud-palette-lines-default, #e0e0e0);
        margin-bottom: 16px;
    }

    .stat {
        text-align: center;
    }

    .stat-value {
        font-weight: 700;
    }

    .profile-actions {
        display: flex;
        gap: 12px;
    }

    .posts-section {
        max-width: 680px;
        margin: 0 auto;
    }

    .section-title {
        margin-bottom: 16px;
        font-weight: 600;
    }

    .posts-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        background: var(--mud-palette-surface);
        border-radius: 12px;
    }

    .load-more-container {
        text-align: center;
        padding: 20px 0;
    }
</style>

@code {
    [Parameter]
    public string Handle { get; set; } = string.Empty;

    private ProfileDto? _profile;
    private List<PostDto> _posts = new();
    private bool _isLoading = true;
    private bool _isLoadingPosts = false;
    private bool _isLoadingMore = false;
    private bool _hasMore = false;
    private string? _error;
    private int _currentPage = 1;
    private int _totalPosts = 0;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reload if handle changes
        if (!_isLoading)
        {
            await LoadProfile();
        }
    }

    private async Task LoadProfile()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _profile = await SivarClient.Public.GetPublicProfileByHandleAsync(Handle);
            
            if (_profile == null)
            {
                _error = "Profile not found";
            }
            else
            {
                await LoadPosts();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PublicProfile] Error loading profile: {ex.Message}");
            _error = "Failed to load profile";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadPosts()
    {
        if (_profile == null) return;

        _isLoadingPosts = true;
        _currentPage = 1;

        try
        {
            var feed = await SivarClient.Public.GetPublicPostsByProfileAsync(_profile.Id, PageSize, _currentPage);
            _posts = feed.Posts?.ToList() ?? new List<PostDto>();
            _totalPosts = feed.TotalCount;
            _hasMore = _posts.Count >= PageSize && feed.TotalCount > _posts.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PublicProfile] Error loading posts: {ex.Message}");
            _posts = new List<PostDto>();
        }
        finally
        {
            _isLoadingPosts = false;
            StateHasChanged();
        }
    }

    private async Task LoadMorePosts()
    {
        if (_profile == null || _isLoadingMore) return;

        _isLoadingMore = true;
        _currentPage++;

        try
        {
            var feed = await SivarClient.Public.GetPublicPostsByProfileAsync(_profile.Id, PageSize, _currentPage);
            var newPosts = feed.Posts?.ToList() ?? new List<PostDto>();
            _posts.AddRange(newPosts);
            _hasMore = newPosts.Count >= PageSize && feed.TotalCount > _posts.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PublicProfile] Error loading more posts: {ex.Message}");
            _currentPage--;
        }
        finally
        {
            _isLoadingMore = false;
            StateHasChanged();
        }
    }

    private void NavigateToPost(Guid postId)
    {
        Navigation.NavigateTo($"/post/{postId}");
    }

    private void HandleInteraction(string action)
    {
        if (action.StartsWith("view:"))
        {
            var postId = action.Replace("view:", "");
            Navigation.NavigateTo($"/post/{postId}");
        }
        else
        {
            // All other actions require login
            PromptLogin();
        }
    }

    private void PromptLogin()
    {
        var returnUrl = System.Net.WebUtility.UrlEncode($"/app/explore/{Handle}");
        Snackbar.Add("Sign up to follow and interact with profiles", Severity.Info);
        Navigation.NavigateTo($"/authentication/login?returnUrl={returnUrl}");
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name[0].ToString().ToUpper();
    }
}
