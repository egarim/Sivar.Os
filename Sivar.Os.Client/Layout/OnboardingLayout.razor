@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject NavigationManager Navigation

<MudThemeProvider Theme="@_theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="onboarding-layout">
    <div class="onboarding-header">
        <a href="/" class="brand-link">
            <MudText Typo="Typo.h5" Class="brand-text">SivarOS</MudText>
        </a>
    </div>
    
    <div class="onboarding-content">
        @Body
    </div>
    
    <div class="onboarding-footer">
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            © 2026 SivarOS. All rights reserved.
        </MudText>
    </div>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#667eea",
            Secondary = "#764ba2",
            AppbarBackground = "#667eea",
            Background = "#f5f5f5",
            Surface = "#ffffff"
        }
    };
}

<style>
    .onboarding-layout {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .onboarding-header {
        padding: 24px 32px;
        text-align: center;
    }

    .brand-link {
        text-decoration: none;
        color: white;
    }

    .brand-text {
        color: white !important;
        font-weight: 700;
        letter-spacing: -1px;
    }

    .onboarding-content {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .onboarding-content > :first-child {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
        padding: 32px;
        max-width: 480px;
        width: 100%;
    }

    .onboarding-footer {
        padding: 24px;
        text-align: center;
        color: rgba(255, 255, 255, 0.7);
    }

    .onboarding-footer .mud-typography {
        color: rgba(255, 255, 255, 0.7) !important;
    }

    @@media (max-width: 600px) {
        .onboarding-content > :first-child {
            margin: 16px;
            padding: 24px;
        }
    }
</style>
