        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }

    .nav-menu-profile {
        padding: 16px 16px 8px 16px;
    }

    .guest-branding {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px;
        border-radius: 8px;
        background: var(--mud-palette-background-grey);
    }

    .brand-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
