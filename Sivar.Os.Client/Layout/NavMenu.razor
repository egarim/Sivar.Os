        .nav-menu-logout {
            padding: 0 10px 12px 10px;
        }
    }

    /* Chat Mode Styles */
    .nav-menu-chat-mode {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        height: 100%;
        overflow-y: auto;
        background: var(--mud-palette-surface);
    }

    .chat-mode-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 4px 16px 4px;
        border-bottom: 1px solid var(--mud-palette-lines-default);
        margin-bottom: 8px;
