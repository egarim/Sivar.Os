@code {
    private bool _isAuthenticated = false;
    private bool _isLoading = true;
    private string _userName = string.Empty;
    private CancellationTokenSource? _cts;

    // Profile switcher state - Blazor Server uses component state, not service cache
    private ProfileDto? _activeProfile;
    private List<ProfileDto> _userProfiles = new();
    private bool _isLoadingProfiles;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        
        // Initial auth state check
        await RefreshAuthState();
        
        // Only load profiles if user is authenticated
        if (_isAuthenticated)
        {
            Console.WriteLine("[NavMenu] User is authenticated, loading profiles...");
            await LoadActiveProfileAsync();
        }
        else
        {
            Console.WriteLine("[NavMenu] User is not authenticated, skipping profile load");
        }
        
        // Subscribe to auth state changes
        if (AuthStateProvider is not null)
        {
            AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        }
    }

    private async Task RefreshAuthState()
    {
        _isLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _isAuthenticated = user.Identity?.IsAuthenticated ?? false;
            _userName = user.Identity?.Name ?? string.Empty;
            Console.WriteLine($"[NavMenu] Auth state refreshed: IsAuthenticated={_isAuthenticated}, Name='{_userName}' (type={user.Identity?.GetType().Name})");
            Console.WriteLine($"[NavMenu] User identity type: {user.Identity?.AuthenticationType}");
            Console.WriteLine($"[NavMenu] User claims: {string.Join(", ", user.Claims.Select(c => $"{c.Type}={c.Value}"))}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavMenu] Error getting auth state: {ex.Message}");
            _isAuthenticated = false;
            _userName = string.Empty;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async void OnAuthenticationStateChanged(Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState> task)
    {
        Console.WriteLine($"[NavMenu] AuthenticationStateChanged event received");
        await RefreshAuthState();
        
        // Reload profiles when authentication state changes (e.g., after login)
        if (_isAuthenticated)
        {
            Console.WriteLine("[NavMenu] User is now authenticated, reloading profiles...");
            await LoadActiveProfileAsync();
        }
        else
        {
            Console.WriteLine("[NavMenu] User is no longer authenticated, clearing profiles");
            _activeProfile = null;
            _userProfiles = new();
        }
        
        await InvokeAsync(StateHasChanged);
    }

    private void Login() => Nav.NavigateTo("/authentication/login", forceLoad: true);
    
    private void Logout() => Nav.NavigateTo("/authentication/logout", forceLoad: true);

    // Profile switcher methods
    
    /// <summary>
    /// Load active profile from API and all user profiles
    /// Blazor Server: Uses component state, calls service methods directly
    /// </summary>
    private async Task LoadActiveProfileAsync()
    {
        try
        {
            Console.WriteLine("[NavMenu] ==================== LoadActiveProfileAsync START ====================");
            
            // Step 1: Load the active profile from the service
            Console.WriteLine("[NavMenu] Step 1: Getting active profile from service");
            _activeProfile = await ProfileSwitcherService.GetActiveProfileAsync();
            Console.WriteLine($"[NavMenu] Active profile from service: {_activeProfile?.DisplayName ?? "NULL"}");
            
            // Step 2: Load all user profiles
            Console.WriteLine("[NavMenu] Step 2: Loading all user profiles");
            await LoadUserProfilesAsync();
            
            // Step 3: If active profile is still null, use first from list
            if (_activeProfile == null && _userProfiles?.Any() == true)
            {
                _activeProfile = _userProfiles.FirstOrDefault(p => p.IsActive) ?? _userProfiles.FirstOrDefault();
                Console.WriteLine($"[NavMenu] Set active profile from list: {_activeProfile?.DisplayName}");
            }
            
            Console.WriteLine($"[NavMenu] ==================== LoadActiveProfileAsync END - Active: {_activeProfile?.DisplayName ?? "NULL"} ====================");
            
            // Trigger UI update with the loaded profile
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavMenu] ❌ Error in LoadActiveProfileAsync: {ex.Message}");
            Console.WriteLine($"[NavMenu] Stack trace: {ex.StackTrace}");
        }
    }
    
    /// <summary>
    /// Load all user profiles for the profile switcher
    /// </summary>
    private async Task LoadUserProfilesAsync()
    {
        try
        {
            _isLoadingProfiles = true;
            Console.WriteLine($"[NavMenu.LoadUserProfilesAsync] START - Current active: {_activeProfile?.DisplayName ?? "NULL"}");

            _userProfiles = await ProfileSwitcherService.GetUserProfilesAsync();
            Console.WriteLine($"[NavMenu.LoadUserProfilesAsync] Got {_userProfiles?.Count ?? 0} profiles from service");

            if (_userProfiles?.Any() == true)
            {
                foreach (var profile in _userProfiles)
                {
                    Console.WriteLine($"[NavMenu]   - Profile: {profile.DisplayName}, IsActive: {profile.IsActive}, ID: {profile.Id}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavMenu.LoadUserProfilesAsync] ERROR: {ex.Message}");
            _userProfiles = new();
        }
        finally
        {
            _isLoadingProfiles = false;
            Console.WriteLine($"[NavMenu.LoadUserProfilesAsync] END - Active: {_activeProfile?.DisplayName ?? "NULL"}");
        }
    }

    /// <summary>
    /// Handle profile change when user selects a different profile
    /// </summary>
    private async Task HandleProfileChanged(ProfileDto selectedProfile)
    {
        try
        {
            Console.WriteLine($"[NavMenu] Switching to profile: {selectedProfile.DisplayName}");

            if (await ProfileSwitcherService.SwitchProfileAsync(selectedProfile.Id))
            {
                Console.WriteLine($"[NavMenu] Profile switched successfully");
                
                // Update local state
                _activeProfile = selectedProfile;
                
                // Navigate to home to refresh the feed
                Nav.NavigateTo("/home", forceLoad: true);
            }
            else
            {
                Console.WriteLine("[NavMenu] Failed to switch profile on server");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavMenu] Error switching profile: {ex.Message}");
        }
    }

    /// <summary>
    /// Handle profile creation from the modal
    /// </summary>
    private async Task HandleCreateProfile(CreateAnyProfileDto request)
    {
        try
        {
            Console.WriteLine($"[NavMenu] Creating new profile: {request.DisplayName}");

            var newProfile = await SivarClient.Profiles.CreateProfileAsync(request);
            
            if (newProfile != null)
            {
                Console.WriteLine($"[NavMenu] Profile created successfully: {newProfile.DisplayName}");
                
                // Set as active if requested
                if (request.SetAsActive)
                {
                    try
                    {
                        await SivarClient.Profiles.SetMyActiveProfileAsync(newProfile.Id);
                        Console.WriteLine($"[NavMenu] Set new profile as active");
                    }
                    catch (Exception setActiveEx)
                    {
                        Console.WriteLine($"[NavMenu] Error setting profile as active: {setActiveEx.Message}");
                    }
                }
                
                // Reload profiles
                await LoadUserProfilesAsync();
                
                // Navigate to home to refresh
                Nav.NavigateTo("/home", forceLoad: true);
            }
            else
            {
                Console.WriteLine("[NavMenu] Profile creation returned null");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavMenu] Error creating profile: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (AuthStateProvider is not null)
        {
            AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        }
        
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
