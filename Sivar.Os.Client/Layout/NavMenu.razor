@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization
@using Sivar.Os.Client.Components.ProfileSwitcher
@using Sivar.Os.Client.Services
@using Sivar.Os.Shared
@using Sivar.Os.Shared.DTOs
@using Sivar.Os.Client.Pages
@inject IStringLocalizer<NavMenu> Localizer
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IProfileSwitcherService ProfileSwitcherService
@inject ISivarClient SivarClient
@implements IAsyncDisposable

<div class="nav-menu-container">
    @if (_layout?.IsAIChatVisible == true)
    {
        @* Chat Mode - Show Home button, New Chat, and conversation list *@
        <div class="nav-menu-chat-mode">
            <div class="chat-mode-header">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Medium" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Sivar AI</MudText>
            </div>
            
            <MudButton Variant="Variant.Outlined" 
                       StartIcon="@Icons.Material.Filled.Home" 
                       FullWidth="true" 
                       OnClick="@ExitChatMode"
                       Class="nav-chat-home-btn"
                       Color="Color.Default">
                Volver al Inicio
            </MudButton>
            
            <MudButton Variant="Variant.Filled" 
                       StartIcon="@Icons.Material.Filled.Add" 
                       FullWidth="true" 
                       OnClick="@HandleNewConversation"
                       Class="nav-new-chat-btn"
                       Color="Color.Primary">
                Nueva Conversación
            </MudButton>
            
            <div class="conversations-section">
                <MudText Typo="Typo.overline" Class="conversations-header">Conversaciones</MudText>
                
                <div class="nav-conversations-list">
                @if (_layout?.ChatConversations?.Any() != true)
                {
                    <div class="nav-empty-conversations">
                        <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Large" Style="opacity: 0.5;" />
                        <MudText Typo="Typo.body2" Style="opacity: 0.7; text-align: center;">No conversations yet</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.5; text-align: center;">Start chatting!</MudText>
                    </div>
                }
                else
                {
                    @foreach (var conversation in _layout.ChatConversations)
                    {
                        <MudNavLink OnClick="@(() => HandleConversationSelect(conversation.Id))"
                                    Icon="@Icons.Material.Filled.ChatBubbleOutline"
                                    Class="@(conversation.Id == _layout.CurrentConversationId ? "nav-conversation-active" : "")">
                            @(string.IsNullOrEmpty(conversation.Title) ? "New Chat" : TruncateTitle(conversation.Title, 25))
                        </MudNavLink>
                    }
                }
            </div>
            </div>
        </div>
    }
    else
    {
        @* Social Media Mode - Normal navigation *@
        <div class="nav-menu-profile">
            <AuthorizeView>
                <Authorized>
                    <ProfileSwitcher ActiveProfile="@_activeProfile"
                                     UserProfiles="@_userProfiles"
                                     OnProfileChanged="@HandleProfileChanged"
                                     OnCreateProfile="@HandleCreateProfile" />
                </Authorized>
                <NotAuthorized>
                    <div class="guest-branding">
                        <div class="brand-logo">
                            <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Large" Color="Color.Primary" />
                        </div>
                        <div class="brand-text">
                            <MudText Typo="Typo.h6" Class="brand-name">Sivar.Os</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localizer["ExploreElSalvador"]</MudText>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <MudNavMenu Class="nav-menu-items">
            <MudNavLink Href="home" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">@Localizer["Home"]</MudNavLink>
            <MudNavLink Href="search" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Search">@Localizer["Search"]</MudNavLink>
            <MudNavLink Href="bookings" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.EventAvailable">@Localizer["Bookings"]</MudNavLink>
            <MudNavLink Href="my-schedule" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.EventNote">@Localizer["MySchedule"]</MudNavLink>
            <MudNavLink @onclick="@ToggleAIChat" Icon="@Icons.Material.Filled.SmartToy">@Localizer["Chat"]</MudNavLink>
        </MudNavMenu>

        <div class="nav-theme-toggle">
            <MudIcon Icon="@Icons.Material.Filled.LightMode" Size="Size.Small" Class="@($"theme-icon-light {(!(_layout?.IsDarkMode ?? true) ? "active" : "")}")" />
            <MudSwitch T="bool" 
                       Value="@(_layout?.IsDarkMode ?? true)" 
                       ValueChanged="@OnThemeToggleChanged"
                       Color="Color.Primary"
                       Class="theme-switch"
                       ThumbIcon="@(_layout?.IsDarkMode ?? true ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                       ThumbIconColor="@(_layout?.IsDarkMode ?? true ? Color.Primary : Color.Warning)" />
            <MudIcon Icon="@Icons.Material.Filled.DarkMode" Size="Size.Small" Class="@($"theme-icon-dark {(_layout?.IsDarkMode ?? true ? "active" : "")}")" />
        </div>
    }

    <div class="nav-menu-spacer"></div>

    <AuthorizeView>
        <Authorized>
            <div class="nav-menu-logout">
                <MudDivider Class="mb-2" />
                <MudButton Variant="Variant.Text" 
                           StartIcon="@Icons.Material.Filled.Logout" 
                           FullWidth="true" 
                           OnClick="Logout" 
                           Class="justify-start"
                           Color="Color.Error">
                    @Localizer["Logout"]
                </MudButton>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-menu-guest-actions">
                <MudDivider Class="mb-2" />
                <MudButton Variant="Variant.Filled" 
                           StartIcon="@Icons.Material.Filled.PersonAdd" 
                           FullWidth="true" 
                           Href="/welcome?action=signup"
                           Class="mb-2"
                           Color="Color.Primary">
                    @Localizer["SignUp"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           StartIcon="@Icons.Material.Filled.Login" 
                           FullWidth="true" 
                           Href="/welcome"
                           Color="Color.Primary">
                    @Localizer["Login"]
                </MudButton>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<style>
