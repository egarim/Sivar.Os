        margin-top: 8px;
    }

    .theme-icon-light {
        color: var(--mud-palette-text-secondary);
        opacity: 0.5;
        transition: opacity 0.2s, color 0.2s;
    }

    .theme-icon-light.active {
        color: var(--mud-palette-warning);
