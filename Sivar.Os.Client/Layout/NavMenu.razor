            padding: 12px 12px 6px 12px;
        }

        .nav-menu-items {
            padding: 6px;
        }

        .nav-menu-items .mud-nav-link {
            padding: 10px 12px;
            font-size: 14px;
        }

        .nav-menu-logout {
            padding: 0 12px 12px 12px;
        }
    }

    /* Mobile responsive */
    @@media (max-width: 600px) {
        .nav-menu-profile {
            padding: 8px 8px 4px 8px;
        }

        .nav-menu-items {
            padding: 4px;
        }

        .nav-menu-items .mud-nav-link {
            padding: 12px 10px;
            font-size: 13px;
            min-height: 44px;
        }

        .nav-menu-items .mud-nav-link .mud-icon-root {
            font-size: 20px;
