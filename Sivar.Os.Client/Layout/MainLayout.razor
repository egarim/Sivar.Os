    // Phase 0: Location-Aware Chat Methods
    private async Task InitializeChatLocationAsync()
    {
        try
        {
            Logger.LogInformation("[MainLayout] Initializing chat location");
            
            // Try to load saved location first
            await ChatLocationService.LoadFromStorageAsync();
            
            if (ChatLocationService.CurrentLocation != null)
            {
                _chatLocation = ChatLocationService.CurrentLocation;
                Logger.LogInformation("[MainLayout] Loaded saved location: {Location}", _chatLocation.DisplayName);
            }
            else
            {
                // No saved location - show prompt
                Logger.LogInformation("[MainLayout] No saved location, showing location prompt");
                await ShowLocationPromptAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout] Error initializing chat location");
            // Default to San Salvador if there's an error
            _chatLocation = new ChatLocationContext
            {
                Latitude = 13.6929,
                Longitude = -89.2182,
                City = "San Salvador",
                Country = "El Salvador",
                DisplayName = "San Salvador, El Salvador",
                Source = "default"
            };
        }
    }

    private async Task ShowLocationPromptAsync()
    {
        try
        {
            var parameters = new DialogParameters<LocationPrompt>();
            var options = new DialogOptions 
            { 
                CloseButton = true, 
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                BackdropClick = false
            };
            
            var dialog = await DialogService.ShowAsync<LocationPrompt>("📍 Set Your Location", parameters, options);
            var result = await dialog.Result;
            
            if (result != null && !result.Canceled && result.Data is ChatLocationContext location)
            {
                _chatLocation = location;
                Logger.LogInformation("[MainLayout] Location set via prompt: {Location}", location.DisplayName);
                StateHasChanged();
            }
            else
            {
                // User skipped or cancelled - default to San Salvador
                _chatLocation = new ChatLocationContext
                {
                    Latitude = 13.6929,
                    Longitude = -89.2182,
                    City = "San Salvador",
                    Country = "El Salvador",
                    DisplayName = "San Salvador, El Salvador",
                    Source = "default"
                };
                Logger.LogInformation("[MainLayout] User skipped location, defaulting to San Salvador");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout] Error showing location prompt");
        }
    }

    private async Task OnLocationIndicatorClickAsync()
    {
        await ShowLocationPromptAsync();
    }

    #region DxAIChat Integration Methods

    /// <summary>
    /// Handle message sent from the DxAIChat component
    /// </summary>
    private async Task HandleDxChatMessageSent(MessageSentEventArgs args)
    {
        var chatId = Guid.NewGuid().ToString()[..8];
        Logger.LogInformation("[MainLayout.HandleDxChatMessageSent] START - ChatId={ChatId}, Content={Content}", 
            chatId, args.Content?.Length > 50 ? args.Content[..50] + "..." : args.Content);

        if (string.IsNullOrWhiteSpace(args.Content))
        {
            Logger.LogWarning("[MainLayout.HandleDxChatMessageSent] EMPTY_CONTENT - ChatId={ChatId}", chatId);
            return;
        }

        _isTyping = true;
        StateHasChanged();

        try
        {
            // Ensure we have a profile
            if (_currentProfile == null)
            {
                _currentProfile = await SivarClient.Profiles.GetMyActiveProfileAsync();
                if (_currentProfile == null)
                {
                    await _sivarAIChat?.SendErrorMessageAsync("Para usar el chat, primero necesitas crear un perfil.")!;
                    return;
                }
            }

            // Ensure conversation exists
            if (_currentConversationId == Guid.Empty)
            {
                await CreateNewConversationAsync();
            }

            // Call the backend API
            var sendMessageDto = new SendMessageDto
            {
                ConversationId = _currentConversationId,
                Content = args.Content,
                Location = _chatLocation
            };

            Logger.LogInformation("[MainLayout.HandleDxChatMessageSent] Calling API - ConversationId={ConversationId}", 
                _currentConversationId);

            var response = await SivarClient.Chat.SendMessageAsync(_currentConversationId, sendMessageDto);

            if (response?.AssistantMessage?.Content == null)
            {
                throw new InvalidOperationException("Received null response from AI");
            }

            // Send the assistant response to DxAIChat
            if (_sivarAIChat != null)
            {
                await _sivarAIChat.SendAssistantMessageAsync(
                    response.AssistantMessage.Content,
                    response.HasStructuredResults ? response.SearchResults : null);
            }

            Logger.LogInformation("[MainLayout.HandleDxChatMessageSent] SUCCESS - ChatId={ChatId}", chatId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout.HandleDxChatMessageSent] FAILED - ChatId={ChatId}", chatId);
            await _sivarAIChat?.SendErrorMessageAsync($"Error: {ex.Message}")!;
        }
        finally
        {
            _isTyping = false;
            StateHasChanged();
        }
    }

