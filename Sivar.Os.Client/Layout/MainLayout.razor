    // Phase 0: Location-Aware Chat Methods
    private async Task InitializeChatLocationAsync()
    {
        try
        {
            Logger.LogInformation("[MainLayout] Initializing chat location");
            
            // Try to load saved location first
            await ChatLocationService.LoadFromStorageAsync();
            
            if (ChatLocationService.CurrentLocation != null)
            {
                _chatLocation = ChatLocationService.CurrentLocation;
                Logger.LogInformation("[MainLayout] Loaded saved location: {Location}", _chatLocation.DisplayName);
            }
            else
            {
                // No saved location - show prompt
                Logger.LogInformation("[MainLayout] No saved location, showing location prompt");
                await ShowLocationPromptAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout] Error initializing chat location");
            // Default to San Salvador if there's an error
            _chatLocation = new ChatLocationContext
            {
                Latitude = 13.6929,
                Longitude = -89.2182,
                City = "San Salvador",
                Country = "El Salvador",
                DisplayName = "San Salvador, El Salvador",
                Source = "default"
            };
        }
    }

    private async Task ShowLocationPromptAsync()
    {
        try
        {
            var parameters = new DialogParameters<LocationPrompt>();
            var options = new DialogOptions 
            { 
                CloseButton = true, 
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                BackdropClick = false
            };
            
            var dialog = await DialogService.ShowAsync<LocationPrompt>("📍 Set Your Location", parameters, options);
            var result = await dialog.Result;
            
            if (result != null && !result.Canceled && result.Data is ChatLocationContext location)
            {
                _chatLocation = location;
                Logger.LogInformation("[MainLayout] Location set via prompt: {Location}", location.DisplayName);
                StateHasChanged();
            }
            else
            {
                // User skipped or cancelled - default to San Salvador
                _chatLocation = new ChatLocationContext
                {
                    Latitude = 13.6929,
                    Longitude = -89.2182,
                    City = "San Salvador",
                    Country = "El Salvador",
                    DisplayName = "San Salvador, El Salvador",
                    Source = "default"
                };
                Logger.LogInformation("[MainLayout] User skipped location, defaulting to San Salvador");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout] Error showing location prompt");
        }
    }

