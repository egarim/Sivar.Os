    private async Task HandleDxBusinessShared(BusinessSearchResultDto business)
    {
        Logger.LogInformation("[MainLayout.HandleDxBusinessShared] Sharing business: {Title}", business.Title);
        // TODO: Implement share functionality via JS interop
        try
        {
            await JS.InvokeVoidAsync("navigator.share", new
            {
                title = business.Title,
                text = business.Description,
                url = business.NavigationUrl
            });
        }
        catch
