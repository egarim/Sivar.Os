    /// <summary>
    /// Handle message sent from the DxAIChat component
    /// </summary>
    private async Task HandleDxChatMessageSent(MessageSentEventArgs args)
    {
        var chatId = Guid.NewGuid().ToString()[..8];
        Logger.LogInformation("[MainLayout.HandleDxChatMessageSent] START - ChatId={ChatId}, Content={Content}", 
            chatId, args.Content?.Length > 50 ? args.Content[..50] + "..." : args.Content);

        if (string.IsNullOrWhiteSpace(args.Content))
        {
            Logger.LogWarning("[MainLayout.HandleDxChatMessageSent] EMPTY_CONTENT - ChatId={ChatId}", chatId);
            return;
        }

        _isTyping = true;
        StateHasChanged();

        try
        {
            // Ensure we have a profile
            if (_currentProfile == null)
            {
                _currentProfile = await SivarClient.Profiles.GetMyActiveProfileAsync();
                if (_currentProfile == null)
                {
                    await _sivarAIChat?.SendErrorMessageAsync("Para usar el chat, primero necesitas crear un perfil.")!;
                    return;
                }
            }

            // Ensure conversation exists
            if (_currentConversationId == Guid.Empty)
            {
                await CreateNewConversationAsync();
            }

            // Call the backend API
            var sendMessageDto = new SendMessageDto
            {
                ConversationId = _currentConversationId,
                Content = args.Content,
                Location = _chatLocation
            };

            Logger.LogInformation("[MainLayout.HandleDxChatMessageSent] Calling API - ConversationId={ConversationId}", 
                _currentConversationId);

            var response = await SivarClient.Chat.SendMessageAsync(_currentConversationId, sendMessageDto);

            if (response?.AssistantMessage?.Content == null)
            {
                throw new InvalidOperationException("Received null response from AI");
            }

            // Send the assistant response to DxAIChat
            if (_sivarAIChat != null)
            {
                await _sivarAIChat.SendAssistantMessageAsync(
                    response.AssistantMessage.Content,
                    response.HasStructuredResults ? response.SearchResults : null);
            }

            Logger.LogInformation("[MainLayout.HandleDxChatMessageSent] SUCCESS - ChatId={ChatId}", chatId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout.HandleDxChatMessageSent] FAILED - ChatId={ChatId}", chatId);
            await _sivarAIChat?.SendErrorMessageAsync($"Error: {ex.Message}")!;
        }
        finally
        {
            _isTyping = false;
            StateHasChanged();
        }
    }

