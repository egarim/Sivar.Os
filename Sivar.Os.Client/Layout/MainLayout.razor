    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                // Get initial window width and set up resize listener
                _currentWindowWidth = await JS.InvokeAsync<int>("eval", "window.innerWidth");
                UpdateDrawerForWidth(_currentWindowWidth);
                
                // Add resize listener
                await JS.InvokeVoidAsync("eval", @"
                    window.sivarOsResizeHandler = function() {
                        DotNet.invokeMethodAsync('Sivar.Os.Client', 'OnWindowResize', window.innerWidth);
                    };
                    window.addEventListener('resize', window.sivarOsResizeHandler);
                ");
            }
            catch
            {
                // JS interop not available during prerender
            }
        }
    }

    [JSInvokable("OnWindowResize")]
