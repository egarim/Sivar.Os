    private async Task ToggleAIChatAsync()
    {
        var wasVisible = _aiChatVisible;
        _aiChatVisible = !_aiChatVisible;
        
        Logger.LogInformation("[MainLayout.ToggleAIChatAsync] Chat toggled - WasVisible={WasVisible}, IsNowVisible={IsNowVisible}, ConversationsCount={Count}, IsLoading={IsLoading}", 
            wasVisible, _aiChatVisible, _conversations.Count, _isLoadingConversations);
        
        // Log to browser console for debugging
        try
        {
            await JS.InvokeVoidAsync("console.log", $"[MainLayout] AI Chat toggled: visible={_aiChatVisible}, conversations={_conversations.Count}");
        }
        catch { /* Ignore JS errors */ }
        
        // Initialize chat on first open
        if (_aiChatVisible && !_conversations.Any() && !_isLoadingConversations)
        {
            Logger.LogInformation("[MainLayout.ToggleAIChatAsync] First open detected, initializing chat");
            try
            {
                await JS.InvokeVoidAsync("console.log", "[MainLayout] First open - initializing chat...");
            }
            catch { /* Ignore JS errors */ }
            await InitializeAIChatAsync();
        }
        
        // Phase 0: Initialize location on first chat open
        if (_aiChatVisible && _chatLocation == null)
        {
            await InitializeChatLocationAsync();
        }
        
        StateHasChanged();
    }

    private void ToggleAIChat()
    {
        // Fire and forget - use the async version
        _ = ToggleAIChatAsync();
    }

