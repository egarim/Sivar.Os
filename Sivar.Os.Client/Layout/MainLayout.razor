    /// <summary>
    /// Handle display mode change from DxAIChat - updates profile preference
    /// </summary>
    private async Task HandleDisplayModeChanged(ChatDisplayMode newMode)
    {
        Logger.LogInformation("[MainLayout.HandleDisplayModeChanged] Mode changed to {Mode}", newMode);
        
        if (_currentProfile == null)
        {
            Logger.LogWarning("[MainLayout.HandleDisplayModeChanged] No active profile to update");
            return;
        }
        
        try
        {
            // Update local state
            _currentProfile.ChatDisplayMode = newMode;
            
            // Persist to server
            var updateDto = new UpdateProfileDto { ChatDisplayMode = newMode };
            await SivarClient.Profiles.UpdateProfileAsync(_currentProfile.Id, updateDto);
            
            Logger.LogInformation("[MainLayout.HandleDisplayModeChanged] Profile {ProfileId} display mode saved as {Mode}", 
                _currentProfile.Id, newMode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout.HandleDisplayModeChanged] Failed to save display mode preference");
        }
    }

