        {
            _leftDrawerOpen = false;
            StateHasChanged();
        }
    }

    private async Task InitializeAIChatAsync()
    {
        var initId = Guid.NewGuid().ToString()[..8];
        Logger.LogInformation("[MainLayout.InitializeAIChatAsync] START - InitId={InitId}, IsLoading={IsLoading}", initId, _isLoadingConversations);
        
        if (_isLoadingConversations)
        {
            Logger.LogWarning("[MainLayout.InitializeAIChatAsync] SKIPPED - Already loading - InitId={InitId}", initId);
            return;
        }
        _isLoadingConversations = true;
        StateHasChanged();

        try
        {
            // Phase 0.5: Load chat settings from database
            Logger.LogInformation("[MainLayout.InitializeAIChatAsync] Loading chat settings - InitId={InitId}", initId);
            await ChatSettings.LoadSettingsAsync();
            
            // Initialize DxChat quick actions
            InitializeDxQuickActions();
            
            // Get current user's profile
            Logger.LogInformation("[MainLayout.InitializeAIChatAsync] Fetching active profile - InitId={InitId}", initId);
            _currentProfile = await SivarClient.Profiles.GetMyActiveProfileAsync();
            
            if (_currentProfile == null)
            {
                Logger.LogWarning("[MainLayout.InitializeAIChatAsync] NO_ACTIVE_PROFILE - Using local mode - InitId={InitId}", initId);
                CreateLocalWelcomeConversation();
                return;
            }

            Logger.LogInformation("[MainLayout.InitializeAIChatAsync] Profile found - ProfileId={ProfileId}, DisplayName={DisplayName}, InitId={InitId}", 
                _currentProfile.Id, _currentProfile.DisplayName, initId);

            // Load existing conversations from backend
            Logger.LogInformation("[MainLayout.InitializeAIChatAsync] Fetching conversations from API - ProfileId={ProfileId}, InitId={InitId}", 
                _currentProfile.Id, initId);
            
            var conversationsDto = await SivarClient.Chat.GetConversationsAsync(_currentProfile.Id);
            var conversationsList = conversationsDto?.ToList() ?? new List<ConversationDto>();
            
            Logger.LogInformation("[MainLayout.InitializeAIChatAsync] Conversations received - Count={Count}, InitId={InitId}", 
                conversationsList.Count, initId);
            
            _conversations = conversationsList.Select(MapConversationFromDto).ToList();

            if (_conversations.Any())
            {
                // Load the most recent conversation
                var mostRecent = _conversations.First();
                Logger.LogInformation("[MainLayout.InitializeAIChatAsync] Loading most recent conversation - ConversationId={ConversationId}, Title={Title}, InitId={InitId}", 
                    mostRecent.GuidId, mostRecent.Title, initId);
                await LoadConversationAsync(mostRecent.GuidId);
            }
            else
            {
                // Create initial conversation
                Logger.LogInformation("[MainLayout.InitializeAIChatAsync] No existing conversations, creating new - InitId={InitId}", initId);
                await CreateNewConversationAsync();
            }
            
            Logger.LogInformation("[MainLayout.InitializeAIChatAsync] SUCCESS - InitId={InitId}", initId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout.InitializeAIChatAsync] FAILED - InitId={InitId}, Error={Error}", initId, ex.Message);
            CreateLocalWelcomeConversation();
        }
        finally
        {
            _isLoadingConversations = false;
            StateHasChanged();
        }
    }

    private void CreateLocalWelcomeConversation()
    {
        Logger.LogInformation("[MainLayout.CreateLocalWelcomeConversation] Creating local welcome conversation");
        
        var initialConversation = new Conversation("Welcome");
        _conversations.Add(initialConversation);
        _currentConversationId = initialConversation.GuidId;
        
        Logger.LogInformation("[MainLayout.CreateLocalWelcomeConversation] Created - ConversationId={ConversationId}", _currentConversationId);
        
        // Phase 0.5: Use ChatSettingsService for configurable welcome message and quick actions
        // Phase 0.6: Use QuickActionItems (relational) - stores full DTO for DefaultQuery support
        var quickActionItems = ChatSettings.GetQuickActionItems()
            .Where(qa => qa.IsActive)
            .OrderBy(qa => qa.SortOrder)
            .ToList();
        
        var welcomeMessage = new ChatMessage("ai", ChatSettings.GetWelcomeMessage(), "welcome")
        {
            QuickActionItems = quickActionItems
        };
        
        _chatMessages = new List<ChatMessage> { welcomeMessage };
        _conversationMessages[_currentConversationId] = _chatMessages;
    }

