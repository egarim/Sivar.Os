    public async ValueTask DisposeAsync()
    {
        try
        {
            // Remove resize listener
            await JS.InvokeVoidAsync("eval", @"
                if (window.sivarOsResizeHandler) {
                    window.removeEventListener('resize', window.sivarOsResizeHandler);
                    window.sivarOsResizeHandler = null;
                }
            ");
        }
        catch
        {
            // Ignore errors during disposal
        }
        
        _dotNetRef?.Dispose();
    }
