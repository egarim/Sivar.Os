    // AI Chat Methods
    private async Task CreateNewConversationAsync()
    {
        var createId = Guid.NewGuid().ToString()[..8];
        Logger.LogInformation("[MainLayout.CreateNewConversationAsync] START - CreateId={CreateId}, HasProfile={HasProfile}", 
            createId, _currentProfile != null);
        
        if (_currentProfile == null)
        {
            Logger.LogWarning("[MainLayout.CreateNewConversationAsync] No profile, using local mode - CreateId={CreateId}", createId);
            // Fallback to local mode
            var localConversation = new Conversation($"Conversation {_conversations.Count + 1}");
            _conversations.Insert(0, localConversation);
            _conversationMessages[localConversation.GuidId] = new List<ChatMessage>();
            await LoadConversationAsync(localConversation.GuidId);
            return;
        }

        try
        {
            var createDto = new CreateConversationDto
            {
                ProfileId = _currentProfile.Id,
                Title = $"Conversation {_conversations.Count + 1}"
            };
            
            Logger.LogInformation("[MainLayout.CreateNewConversationAsync] Calling API - ProfileId={ProfileId}, Title={Title}, CreateId={CreateId}", 
                createDto.ProfileId, createDto.Title, createId);
            
            var conversationDto = await SivarClient.Chat.CreateConversationAsync(createDto);
            
            Logger.LogInformation("[MainLayout.CreateNewConversationAsync] SUCCESS - ConversationId={ConversationId}, CreateId={CreateId}", 
                conversationDto?.Id, createId);
            
            var conversation = MapConversationFromDto(conversationDto);
            _conversations.Insert(0, conversation);
            await LoadConversationAsync(conversation.GuidId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout.CreateNewConversationAsync] FAILED - CreateId={CreateId}, Error={Error}", createId, ex.Message);
            // Fallback to local
            var localConversation = new Conversation($"Conversation {_conversations.Count + 1}");
            _conversations.Insert(0, localConversation);
            _conversationMessages[localConversation.GuidId] = new List<ChatMessage>();
            await LoadConversationAsync(localConversation.GuidId);
        }
    }

    private void NewConversation()
    {
        Logger.LogInformation("[MainLayout.NewConversation] Button clicked");
        _ = CreateNewConversationAsync();
    }

    private void SelectConversationById(string conversationId)
    {
        Logger.LogInformation("[MainLayout.SelectConversationById] Selected - ConversationId={ConversationId}", conversationId);
        
        if (!Guid.TryParse(conversationId, out var guidId))
        {
            Logger.LogWarning("[MainLayout.SelectConversationById] Invalid GUID - ConversationId={ConversationId}", conversationId);
            return;
        }
        
        var conversation = _conversations.FirstOrDefault(c => c.GuidId == guidId);
        if (conversation == null || conversation.GuidId == _currentConversationId)
        {
            Logger.LogInformation("[MainLayout.SelectConversationById] No change needed - NotFound={NotFound}, SameAsCurrent={Same}", 
                conversation == null, conversation?.GuidId == _currentConversationId);
            return;
        }

        _conversationMessages[_currentConversationId] = _chatMessages;
        
        _ = LoadConversationAsync(conversation.GuidId);
    }

    private async Task LoadConversationAsync(Guid conversationId)
    {
        var loadId = Guid.NewGuid().ToString()[..8];
        Logger.LogInformation("[MainLayout.LoadConversationAsync] START - ConversationId={ConversationId}, LoadId={LoadId}", 
            conversationId, loadId);
        
        _currentConversationId = conversationId;
        
        // Check if we already have messages cached
        if (_conversationMessages.TryGetValue(conversationId, out var cachedMessages) && cachedMessages.Any())
        {
            Logger.LogInformation("[MainLayout.LoadConversationAsync] Using cached messages - Count={Count}, LoadId={LoadId}", 
                cachedMessages.Count, loadId);
            _chatMessages = cachedMessages;
            UpdateConversationPreview(conversationId);
            await ScrollChatToBottom();
            StateHasChanged();
            return;
        }

        // Try to load from backend
        if (_currentProfile != null)
        {
            try
            {
                Logger.LogInformation("[MainLayout.LoadConversationAsync] Fetching from backend - ConversationId={ConversationId}, LoadId={LoadId}", 
                    conversationId, loadId);
                var conversationWithMessages = await SivarClient.Chat.GetConversationAsync(conversationId);
                Logger.LogInformation("[MainLayout.LoadConversationAsync] Backend returned - MessageCount={Count}, LoadId={LoadId}", 
                    conversationWithMessages?.Messages?.Count ?? 0, loadId);
                
                // Map backend messages to UI ChatMessage objects
                if (conversationWithMessages?.Messages != null && conversationWithMessages.Messages.Any())
                {
                    var loadedMessages = new List<ChatMessage>();
                    foreach (var msg in conversationWithMessages.Messages.OrderBy(m => m.MessageOrder))
                    {
                        var role = msg.Role == "user" ? "user" : "ai";
                        loadedMessages.Add(new ChatMessage(role, msg.Content));
                    }
                    _conversationMessages[conversationId] = loadedMessages;
                    _chatMessages = loadedMessages;
                    
                    Logger.LogInformation("[MainLayout.LoadConversationAsync] Loaded {Count} messages from backend - LoadId={LoadId}", 
                        loadedMessages.Count, loadId);
                    
                    UpdateConversationPreview(conversationId);
                    await ScrollChatToBottom();
                    StateHasChanged();
                    return;
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "[MainLayout.LoadConversationAsync] Backend fetch failed - ConversationId={ConversationId}, LoadId={LoadId}, Error={Error}", 
                    conversationId, loadId, ex.Message);
            }
        }
        else
        {
            Logger.LogInformation("[MainLayout.LoadConversationAsync] No profile, skipping backend fetch - LoadId={LoadId}", loadId);
        }

        // Initialize with welcome message if no messages
        if (!_conversationMessages.ContainsKey(conversationId))
        {
            Logger.LogInformation("[MainLayout.LoadConversationAsync] Creating new message list - ConversationId={ConversationId}, LoadId={LoadId}", 
                conversationId, loadId);
            _conversationMessages[conversationId] = new List<ChatMessage>();
        }

        _chatMessages = _conversationMessages[conversationId];
        if (!_chatMessages.Any())
        {
            Logger.LogInformation("[MainLayout.LoadConversationAsync] Adding welcome message - ConversationId={ConversationId}, LoadId={LoadId}", 
                conversationId, loadId);
            var welcome = new ChatMessage("ai", @"Hi! I'm your Sivar AI assistant. I can help you:

🔍 Find profiles and businesses
📝 Search posts and content
🏪 Discover local services
📊 Explore activity streams

Try asking me something like ""I want a pizza"" or ""Find tech companies""!", "welcome")
            {
                QuickActions = new List<string> { "🍕 Find pizza", "💼 Tech companies", "🎉 Events", "💼 Jobs" }
            };
            _chatMessages.Add(welcome);
        }

        Logger.LogInformation("[MainLayout.LoadConversationAsync] COMPLETE - ConversationId={ConversationId}, MessageCount={Count}, LoadId={LoadId}", 
            conversationId, _chatMessages.Count, loadId);
        
        UpdateConversationPreview(conversationId);
        await ScrollChatToBottom();
        StateHasChanged();
    }

    private void AddMessage(Guid conversationId, ChatMessage message)
    {
        if (!_conversationMessages.ContainsKey(conversationId))
        {
            _conversationMessages[conversationId] = new List<ChatMessage>();
        }

        _conversationMessages[conversationId].Add(message);

        if (_currentConversationId == conversationId)
        {
            _chatMessages = _conversationMessages[conversationId];
        }
    }

    private void UpdateConversationPreview(Guid conversationId)
    {
        var conversation = _conversations.FirstOrDefault(c => c.GuidId == conversationId);
        if (conversation is null) return;

        if (_conversationMessages.TryGetValue(conversationId, out var messages) && messages.Any())
        {
            var last = messages.Last();
            var previewText = !string.IsNullOrWhiteSpace(last.Text) ? last.Text : "View results";
            conversation.Preview = previewText.Length > 60 ? $"{previewText[..57]}..." : previewText;
            conversation.LastUpdated = last.Time;
            conversation.MessageCount = messages.Count;
            conversation.ResultCount = messages.Count(m => m.MessageType == "result-card");

            if (conversation.Title.StartsWith("Conversation ") && messages.Count > 2)
            {
                var firstUserMessage = messages.FirstOrDefault(m => m.Sender == "user");
                if (firstUserMessage != null)
                {
                    var titleText = firstUserMessage.Text.Length > 30 ? $"{firstUserMessage.Text[..27]}..." : firstUserMessage.Text;
                    conversation.Title = titleText;
                }
            }
        }
    }

    private async Task SendChat()
    {
        var chatId = Guid.NewGuid().ToString()[..8];
        Logger.LogInformation("[MainLayout.SendChat] START - ChatId={ChatId}, ConversationId={ConversationId}, InputLength={Length}", 
            chatId, _currentConversationId, _chatInput?.Length ?? 0);
        
        if (string.IsNullOrWhiteSpace(_chatInput))
        {
            Logger.LogWarning("[MainLayout.SendChat] EMPTY_INPUT - ChatId={ChatId}", chatId);
            return;
        }

        var userMessage = new ChatMessage("user", _chatInput);
        AddMessage(_currentConversationId, userMessage);
        Logger.LogInformation("[MainLayout.SendChat] User message added to UI - ChatId={ChatId}", chatId);

        var userQuery = _chatInput;
        _chatInput = string.Empty;
        _isTyping = true;
        StateHasChanged();
        await ScrollChatToBottom();

        try
        {
            // Call the real AI backend
            var sendMessageDto = new SendMessageDto
            {
                ConversationId = _currentConversationId,
                Content = userQuery
            };

            Logger.LogInformation("[MainLayout.SendChat] Calling API - ChatId={ChatId}, ConversationId={ConversationId}, Query={Query}", 
                chatId, _currentConversationId, userQuery.Length > 50 ? userQuery[..50] + "..." : userQuery);
            
            var startTime = DateTime.UtcNow;
            var response = await SivarClient.Chat.SendMessageAsync(_currentConversationId, sendMessageDto);
            var elapsed = (DateTime.UtcNow - startTime).TotalMilliseconds;
            
            Logger.LogInformation("[MainLayout.SendChat] API response received - ChatId={ChatId}, Duration={Duration}ms, ResponseLength={Length}", 
                chatId, elapsed, response?.AssistantMessage?.Content?.Length ?? 0);
            
            if (response?.AssistantMessage?.Content == null)
            {
                Logger.LogWarning("[MainLayout.SendChat] NULL_RESPONSE - ChatId={ChatId}", chatId);
                throw new InvalidOperationException("Received null response from AI");
            }
            
            // Map the response to UI ChatMessage
            var aiMessage = new ChatMessage("ai", response.AssistantMessage.Content);
            AddMessage(_currentConversationId, aiMessage);
            
            Logger.LogInformation("[MainLayout.SendChat] SUCCESS - ChatId={ChatId}, ResponsePreview={Preview}", 
                chatId, response.AssistantMessage.Content.Length > 100 ? response.AssistantMessage.Content[..100] + "..." : response.AssistantMessage.Content);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[MainLayout.SendChat] FAILED - ChatId={ChatId}, Error={Error}, StackTrace={StackTrace}", 
                chatId, ex.Message, ex.StackTrace);
            var errorMessage = new ChatMessage("ai", $"I'm sorry, I encountered an error: {ex.Message}");
            AddMessage(_currentConversationId, errorMessage);
        }
        finally
        {
            _isTyping = false;
        }

        UpdateConversationPreview(_currentConversationId);
        StateHasChanged();
        await ScrollChatToBottom();
    }

    private void HandleQuickAction(string action)
    {
        _chatInput = action;
        _ = SendChat();
    }

    private async Task ScrollChatToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('chatMessages')?.scrollTo(0, document.getElementById('chatMessages').scrollHeight)");
        }
        catch
        {
            // ignore when DOM is unavailable
        }
    }

    // DTO to UI Model Mappers
    private static Conversation MapConversationFromDto(ConversationDto dto)
    {
        return new Conversation(dto.Id, dto.Title)
        {
            Preview = "Start chatting...",
            LastUpdated = dto.LastMessageAt,
            MessageCount = dto.MessageCount
        };
    }

    private static ChatMessage MapChatMessageFromDto(ChatMessageDto dto)
    {
        var sender = dto.Role.ToLowerInvariant() == "user" ? "user" : "ai";
        return new ChatMessage(sender, dto.Content)
        {
            Time = dto.CreatedAt
        };
    }

