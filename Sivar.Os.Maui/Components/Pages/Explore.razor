@page "/explore"

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Explore</MudText>
    
    <MudGrid>
        @for (int i = 1; i <= 6; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard>
                    <MudCardMedia Image="https://picsum.photos/400/300?random=@i" Height="200" />
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Sample Content @i</MudText>
                        <MudText Typo="Typo.body2">Discover interesting content in your area.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Favorite" Color="Color.Error" />
                        <MudIconButton Icon="@Icons.Material.Filled.Share" Color="Color.Default" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>
