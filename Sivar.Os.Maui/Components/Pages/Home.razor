@page "/"

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h4">Welcome to Sivar.Os</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText>
                Your mobile companion for the Sivar.Os platform.
            </MudText>
            <MudText Class="mt-4">
                Explore content, connect with others, and stay updated on the go.
            </MudText>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/explore">
                Get Started
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>
